---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LatestPostFeatured from '../components/studio/LatestPostFeatured.astro';
import LatestPostFeedItem from '../components/studio/LatestPostFeedItem.astro';
import LatestSidebar from '../components/studio/LatestSidebar.astro';
import LatestFilterBar from '../components/studio/LatestFilterBar.astro';
import { supabase } from '../lib/supabase';
import { getSite, getNavItems, getMediaAssets } from '../lib/queries';

const SITE_SLUG = 'signal_studio';
const SEO_PAGE_ID = 'b4d696e4-2046-42c3-b708-a567f1cea822';

export interface LatestPost {
  id: string;
  title: string;
  slug: string;
  summary: string | null;
  published_at: string | null;
  category: string | null;
  tags: string[] | null;
  is_featured_latest_news: boolean | null;
  hero_media_asset_id: string | null;
  reading_time_minutes: number | null;
}

// ── Parallel fetches ──────────────────────────────────────────
const [site, headerNav, footerNav, postsResult, seoResult, sidebarPagesResult] = await Promise.all([
  getSite(SITE_SLUG),
  getNavItems(SITE_SLUG, 'header'),
  getNavItems(SITE_SLUG, 'footer'),

  supabase
    .from('posts')
    .select('id, title, slug, summary, published_at, category, tags, is_featured_latest_news, hero_media_asset_id, reading_time_minutes')
    .contains('site_show', ['signal_studio'])
    .eq('status', 'published')
    .order('published_at', { ascending: false })
    .limit(40),

  supabase
    .from('page_seo')
    .select('seo_title_override, seo_description_override, aeo_summary, jsonld')
    .eq('site_page_id', SEO_PAGE_ID)
    .maybeSingle(),

  supabase
    .from('site_pages')
    .select('slug, url_path')
    .eq('site_slug', SITE_SLUG)
    .in('slug', ['ai-readiness', 'services']),
]);

if (!site) return Astro.redirect('/500');

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const allPosts = (postsResult.data ?? []) as LatestPost[];

// ── Featured post logic ───────────────────────────────────────
// Prefer is_featured_latest_news = true (most recently published first).
// Fall back to posts[0] if none is explicitly flagged.
const featuredIdx = allPosts.findIndex((p) => p.is_featured_latest_news === true);
const excludeIdx = featuredIdx >= 0 ? featuredIdx : 0;
const featuredPost: LatestPost | null = allPosts[excludeIdx] ?? null;
const feedPosts = featuredPost
  ? allPosts.filter((_, i) => i !== excludeIdx)
  : allPosts;

// ── Media assets ──────────────────────────────────────────────
const allImageIds = allPosts
  .map((p) => p.hero_media_asset_id)
  .filter((id): id is string => Boolean(id));
const mediaAssets = await getMediaAssets(allImageIds);

// ── Sidebar page URLs ─────────────────────────────────────────
const sidebarPages = (sidebarPagesResult.data ?? []) as { slug: string; url_path: string }[];
const aiReadinessUrl = sidebarPages.find((p) => p.slug === 'ai-readiness')?.url_path ?? '/ai-readiness';
const servicesUrl = sidebarPages.find((p) => p.slug === 'services')?.url_path ?? '/services';

// ── Filter data — derived from all fetched posts ──────────────
const categories = [
  ...new Set(allPosts.map((p) => p.category).filter((c): c is string => Boolean(c))),
];

// ── SEO ───────────────────────────────────────────────────────
const seo = seoResult.data;
const seoTitle       = seo?.seo_title_override ?? null;
const seoDescription = seo?.seo_description_override ?? site.meta_description ?? null;
const aeoSummary     = seo?.aeo_summary ?? undefined;
const jsonld         = (seo?.jsonld as any[]) ?? [];

// ── Image resolver ────────────────────────────────────────────
function getImage(post: LatestPost) {
  if (!post.hero_media_asset_id) return { url: null, alt: null };
  const asset = mediaAssets[post.hero_media_asset_id];
  return { url: asset?.image_url ?? null, alt: asset?.alt_text ?? null };
}
---

<Layout
  title={seoTitle}
  description={seoDescription}
  aeoSummary={aeoSummary}
  jsonld={jsonld}
  siteName={site.name}
  brandKey={site.brand_key || 'signal_studio'}
>
  <Nav navItems={headerNav} site={site} />

  <main id="main-content">

    <!-- ── Section 1 + 2: Page intro + Filter bar ── -->
    <section style="background: var(--color_background); padding-top: clamp(3rem, 6vw, 5rem); padding-bottom: clamp(1.5rem, 3vw, 2.5rem); border-bottom: 1px solid var(--color_border);">
      <div style="max-width: var(--layout_max_width); margin-inline: auto; padding-inline: var(--layout_padding_x);">

        <h1 style="font-family: var(--font_heading); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: var(--font_weight_bold); line-height: var(--leading_tight); letter-spacing: -0.02em; color: var(--color_text_heading); margin: 0 0 var(--gap_sm);">
          Latest
        </h1>

        <p style="font-size: var(--text_lg); font-family: var(--font_body); color: var(--color_text_secondary); line-height: var(--leading_relaxed); max-width: 52ch; margin: 0 0 clamp(1.5rem, 3vw, 2rem);">
          Practical signals, insights, and system thinking across AI, workflows, and real-world implementation.
        </p>

        <LatestFilterBar categories={categories} />

      </div>
    </section>

    <!-- ── Section 3: Featured post ── -->
    {featuredPost && (
      <LatestPostFeatured
        post={featuredPost}
        imageUrl={getImage(featuredPost).url}
        imageAlt={getImage(featuredPost).alt}
      />
    )}

    <!-- ── Section 4: Feed + Sidebar ── -->
    <section style="background: var(--color_background); padding-block: clamp(3rem, 5vw, 4.5rem);">
      <div
        style="max-width: var(--layout_max_width); margin-inline: auto; padding-inline: var(--layout_padding_x);"
        class="latest-layout"
      >

        <!-- Feed -->
        <div id="latest-feed" class="latest-feed">
          {feedPosts.length > 0 ? (
            feedPosts.map((post) => {
              const img = getImage(post);
              return (
                <LatestPostFeedItem
                  post={post}
                  imageUrl={img.url}
                  imageAlt={img.alt}
                />
              );
            })
          ) : (
            <p style="color: var(--color_text_secondary); font-size: var(--text_base); font-family: var(--font_body);">
              No posts yet.
            </p>
          )}
        </div>

        <!-- Sidebar -->
        <div class="latest-sidebar">
          <LatestSidebar aiReadinessUrl={aiReadinessUrl} servicesUrl={servicesUrl} />
        </div>

      </div>
    </section>

  </main>

  <Footer footerItems={footerNav} site={site} acknowledgement={site.acknowledgement} />
</Layout>

<style>
  .latest-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .latest-feed,
  .latest-sidebar {
    min-width: 0;
    max-width: 100%;
  }

  .latest-sidebar {
    position: sticky;
    top: 2rem;
  }

  @media (max-width: 900px) {
    .latest-layout {
      grid-template-columns: 1fr;
    }

    .latest-sidebar {
      position: static;
      border-top: 1px solid var(--color_border);
      padding-top: clamp(2rem, 4vw, 3rem);
    }
  }
</style>
