<script>
  // ── Header join form ──────────────────────────────────────
  const joinForm    = document.getElementById('rm-join-form') as HTMLFormElement | null;
  const joinSuccess = document.getElementById('rm-join-success') as HTMLElement | null;
  const joinEmail   = document.getElementById('rm-join-email') as HTMLInputElement | null;

  joinForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = joinEmail?.value?.trim();
    if (!email) { joinEmail?.focus(); return; }

    const submitBtn = joinForm.querySelector<HTMLButtonElement>('.rm-join-btn');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Joining…'; }

    try {
      const res  = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'header_join', site_slug: 'remix' }),
      });
      const json = await res.json();
      if (res.ok && json.success) {
        if (joinForm)    joinForm.style.display = 'none';
        if (joinSuccess) joinSuccess.hidden = false;
      } else {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Join The Remix'; }
      }
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Join The Remix'; }
    }
  });

  // ── Share button ──────────────────────────────────────────
  const shareBtn   = document.getElementById('ev-share-btn') as HTMLButtonElement | null;
  const shareLabel = document.getElementById('ev-share-label');

  shareBtn?.addEventListener('click', async () => {
    const title = shareBtn.dataset.title ?? '';
    const url   = shareBtn.dataset.url   ?? window.location.href;

    if (navigator.share) {
      try {
        await navigator.share({ title, url });
      } catch { /* user cancelled */ }
      return;
    }

    // Clipboard fallback
    try {
      await navigator.clipboard.writeText(url);
      if (shareLabel) {
        shareLabel.textContent = 'Link copied';
        setTimeout(() => { if (shareLabel) shareLabel.textContent = 'Share'; }, 2000);
      }
    } catch {
      // Silent — clipboard not available
    }
  });
</script>
