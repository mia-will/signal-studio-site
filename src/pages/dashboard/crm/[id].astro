---
export const prerender = false

import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'

const { id } = Astro.params

const { data: contact } = await supabase
  .from('contacts_crm')
  .select('*')
  .eq('id', id)
  .maybeSingle()

if (!contact) return Astro.redirect('/dashboard/crm')

const [activityRes, clientRes, enrolmentsRes] = await Promise.all([
  supabase
    .from('contact_activity')
    .select('id,activity_type,source,summary,created_at')
    .eq('contact_id', id)
    .order('created_at', { ascending: false }),
  supabase
    .from('client_projects')
    .select('id,project_name,scope_summary,current_status_note,deadline,created_at,stage')
    .eq('contact_id', id)
    .maybeSingle(),
  supabase
    .from('pathway_enrolments')
    .select('id,status,pathway_cohorts(cohort_name,pathways(title))')
    .eq('contact_id', id)
    .order('enrolled_at', { ascending: false }),
])

const activity   = activityRes.data   ?? []
const client     = clientRes.data     ?? null
const enrolments = enrolmentsRes.data ?? []

function fullName(c: typeof contact): string {
  return [c.first_name, c.last_name].filter(Boolean).join(' ') || c.email || '—'
}

function formatDate(ts: string | null): string {
  if (!ts) return '—'
  return new Date(ts).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })
}

function formatDateTime(ts: string | null): string {
  if (!ts) return '—'
  return new Date(ts).toLocaleString('en-AU', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })
}

function formatMonthYear(ts: string | null): string {
  if (!ts) return '—'
  return new Date(ts).toLocaleDateString('en-AU', { month: 'short', year: 'numeric' })
}

function formatDeadline(date: string | null): string {
  if (!date) return '—'
  return 'due ' + new Date(date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })
}

function relativeDate(ts: string | null): string {
  if (!ts) return '—'
  const diff = Date.now() - new Date(ts).getTime()
  const mins = Math.floor(diff / 60000)
  if (mins < 1)  return 'Just now'
  if (mins < 60) return `${mins}m ago`
  const h = Math.floor(mins / 60)
  if (h < 24)    return `${h}h ago`
  const d = Math.floor(h / 24)
  if (d < 7)     return `${d}d ago`
  if (d < 30)    return `${Math.floor(d / 7)}w ago`
  return `${Math.floor(d / 30)}mo ago`
}

function relativeWithDate(ts: string | null): string {
  if (!ts) return '—'
  return `${relativeDate(ts)} (${formatDate(ts)})`
}

function trackBadgeClass(track: string | null): string {
  if (!track) return 'badge-grey'
  const map: Record<string, string> = { builder: 'badge-blue', applier: 'badge-green', both: 'badge-purple' }
  return map[track.toLowerCase()] ?? 'badge-grey'
}

function trackLabel(track: string | null): string {
  if (!track) return 'Unassigned'
  const labels: Record<string, string> = { builder: 'Builder', applier: 'Applier', both: 'Both' }
  return labels[track.toLowerCase()] ?? track
}

function activityDotColor(type: string | null): string {
  if (!type) return 'var(--color-border-secondary)'
  const map: Record<string, string> = {
    email_open:       '#1D9E75',
    event_attended:   '#378ADD',
    form_submission:  '#7F77DD',
  }
  return map[type] ?? 'var(--color-border-secondary)'
}

function pathwayName(e: any): string {
  return e?.pathway_cohorts?.pathways?.title
    ?? e?.pathway_cohorts?.cohort_name
    ?? '—'
}

function dedupeEmailOpens(rows: any[]): any[] {
  const groups = new Map<string, any[]>()
  const other: any[] = []
  for (const row of rows) {
    if (row.activity_type !== 'email_open') { other.push(row); continue }
    const day = row.created_at ? new Date(row.created_at).toISOString().slice(0, 10) : ''
    const key = `${day}__${row.summary ?? ''}`
    if (!groups.has(key)) groups.set(key, [])
    groups.get(key)!.push(row)
  }
  const collapsed = Array.from(groups.values()).map(group => {
    const earliest = group.reduce((a, b) => a.created_at < b.created_at ? a : b)
    const count = group.length
    return { ...earliest, summary: count > 1 ? `${earliest.summary ?? 'opened'} × ${count}` : earliest.summary }
  })
  return [...other, ...collapsed].sort((a, b) =>
    new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
  )
}

const notesCount = contact.notes ? 1 : 0
const dedupedActivity = dedupeEmailOpens(activity)
const activityVisible = dedupedActivity.slice(0, 10)
const activityHidden  = dedupedActivity.slice(10)
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Signal OS — {fullName(contact)}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F4F1;
      --surface: #FFFFFF;
      --text-primary: #2F2F2F;
      --text-secondary: #505050;
      --text-muted: #909090;
      --border: rgba(47,47,47,0.08);
      --teal: #3C8A7E;
      --heading: 'DM Sans', sans-serif;
      --body: 'Inter', sans-serif;
      --radius: 12px;
      --shadow: 0 1px 3px rgba(47,47,47,0.06);

      --color-border-tertiary: rgba(47,47,47,0.06);
      --color-border-secondary: rgba(47,47,47,0.10);
      --color-background-secondary: #F5F4F1;
      --color-text-tertiary: #909090;
      --border-radius-lg: 12px;
    }

    body { background: var(--bg); color: var(--text-primary); font-family: var(--body); }

    .os-shell { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }

    /* ── SIDEBAR ────────────────────────────── */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 20px 16px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border);
    }

    .nav-section-label {
      font-family: var(--body);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 20px 16px 4px;
    }

    .nav-item {
      display: block;
      font-family: var(--body);
      font-size: 13px;
      font-weight: 400;
      color: var(--text-secondary);
      padding: 6px 16px;
      border-radius: 6px;
      margin: 1px 8px;
      text-decoration: none;
      cursor: default;
    }

    .nav-item.active { background: rgba(60,138,126,0.10); color: var(--teal); font-weight: 500; }
    .nav-item.link { cursor: pointer; }
    .nav-item.link:hover { background: rgba(47,47,47,0.04); }

    .sidebar-footer {
      margin-top: auto;
      padding: 14px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--teal);
      color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; flex-shrink: 0;
    }

    .footer-name { font-size: 12px; font-weight: 500; color: var(--text-primary); line-height: 1.2; }
    .footer-role { font-size: 11px; color: var(--text-muted); }

    /* ── MAIN ───────────────────────────────── */
    .main-area { display: flex; flex-direction: column; overflow-x: hidden; }

    /* ── PAGE HEADER ────────────────────────── */
    .page-header {
      background: var(--surface);
      border-bottom: 0.5px solid var(--color-border-tertiary);
      padding: 12px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .header-left { display: flex; flex-direction: column; gap: 3px; min-width: 0; }

    .header-breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-muted);
      text-decoration: none;
      margin-bottom: 2px;
    }
    .header-breadcrumb:hover { color: var(--text-secondary); }

    .header-name-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .header-name {
      font-family: var(--heading);
      font-size: 18px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.1;
    }

    .header-email {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 1px;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .score-block {
      text-align: right;
    }
    .score-value {
      font-family: var(--heading);
      font-size: 18px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1;
    }
    .score-label {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 2px;
    }

    .btn-edit {
      background: transparent;
      border: 0.5px solid var(--color-border-secondary);
      border-radius: 6px;
      padding: 5px 12px;
      font-family: var(--body);
      font-size: 12px;
      font-weight: 400;
      color: var(--text-secondary);
      cursor: pointer;
    }
    .btn-edit:hover { background: rgba(47,47,47,0.04); }

    /* ── BADGES ─────────────────────────────── */
    .badge {
      display: inline-block;
      border-radius: 20px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 500;
      line-height: 1.4;
    }

    .badge-blue   { background: #E6F1FB; color: #0C447C; }
    .badge-stage  { background: #F1EFE8; color: #444441; }
    .badge-client { background: #EEEDFE; color: #3C3489; }
    .badge-green  { background: #EAF3DE; color: #3B6D11; }
    .badge-grey   { background: rgba(47,47,47,0.07); color: var(--text-secondary); }
    .badge-orange { background: rgba(255,138,51,0.12); color: #E07020; }

    /* ── 3-COLUMN GRID ──────────────────────── */
    .columns-grid {
      display: grid;
      grid-template-columns: 220px 1fr minmax(210px, 210px);
      gap: 12px;
      padding: 16px 20px;
      align-items: start;
    }

    /* ── CARD ───────────────────────────────── */
    .card {
      background: var(--surface);
      border: 0.5px solid var(--color-border-secondary);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      margin-bottom: 10px;
      overflow: hidden;
    }

    .card:last-child { margin-bottom: 0; }

    .card-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 10px 14px 0;
    }

    .card-sub-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 10px 14px 4px;
    }

    /* ── DATA ROWS ──────────────────────────── */
    .data-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      padding: 5px 14px;
      border-bottom: 0.5px solid var(--color-border-tertiary);
    }

    .data-row:last-child { border-bottom: none; }

    .data-key {
      font-size: 11px;
      color: var(--text-muted);
      flex-shrink: 0;
      width: 76px;
    }

    .data-val {
      font-size: 12px;
      color: var(--text-secondary);
      text-align: right;
      flex: 1;
      min-width: 0;
    }

    .data-val.muted { color: var(--color-text-tertiary); }

    .org-link {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 12px;
    }
    .org-link:hover { color: var(--teal); }

    /* ── ACTIVITY ───────────────────────────── */
    .activity-item {
      display: flex;
      gap: 10px;
      padding: 8px 14px;
      border-bottom: 0.5px solid var(--color-border-tertiary);
    }

    .activity-item:last-child { border-bottom: none; }

    .act-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 4px;
    }

    .act-body { flex: 1; min-width: 0; }

    .act-type {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1px;
    }

    .act-summary {
      font-size: 12px;
      color: var(--text-primary);
      line-height: 1.35;
      margin-bottom: 2px;
    }

    .act-meta {
      font-size: 11px;
      color: var(--color-text-tertiary);
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .show-more-row {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      font-size: 12px;
      color: var(--text-muted);
      cursor: pointer;
      border-top: 0.5px solid var(--color-border-tertiary);
    }
    .show-more-row:hover { color: var(--text-secondary); }

    .hidden-activities { display: none; }
    .hidden-activities.expanded { display: block; }

    /* ── CLIENT BANNER ──────────────────────── */
    .client-banner {
      background: #3C3489;
      border-radius: var(--border-radius-lg);
      padding: 14px;
      margin-bottom: 10px;
    }

    .client-banner-top {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 6px;
    }

    .client-banner-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #AFA9EC;
    }

    .client-stage-pill {
      display: inline-block;
      background: rgba(61,213,152,0.18);
      color: #3DD598;
      border-radius: 20px;
      padding: 1px 8px;
      font-size: 10px;
      font-weight: 500;
    }

    .client-project-name {
      font-size: 15px;
      font-weight: 500;
      color: #FFFFFF;
      line-height: 1.2;
      margin-bottom: 3px;
    }

    .client-scope {
      font-size: 12px;
      color: #AFA9EC;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-bottom: 10px;
    }

    .client-milestone {
      background: rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 8px 10px;
      margin-bottom: 10px;
    }

    .milestone-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #AFA9EC;
      margin-bottom: 4px;
    }

    .milestone-desc {
      font-size: 12px;
      font-weight: 500;
      color: #FFFFFF;
      line-height: 1.35;
      margin-bottom: 3px;
    }

    .milestone-due {
      font-size: 11px;
      color: #AFA9EC;
    }

    .client-link {
      font-size: 12px;
      color: #CECBF6;
      text-decoration: none;
      display: block;
    }
    .client-link:hover { opacity: 0.8; }

    /* ── PATHWAY ROWS ───────────────────────── */
    .pathway-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      border-bottom: 0.5px solid var(--color-border-tertiary);
      cursor: default;
    }

    .pathway-row:last-child { border-bottom: none; }

    .pathway-name {
      font-size: 12px;
      color: var(--text-primary);
      flex: 1;
      min-width: 0;
      line-height: 1.3;
    }

    .pathway-status {
      font-size: 11px;
      color: var(--text-muted);
    }

    .pathway-arrow {
      font-size: 11px;
      color: var(--text-muted);
      flex-shrink: 0;
    }

    .view-all-link {
      display: block;
      padding: 7px 14px;
      font-size: 11px;
      color: var(--text-muted);
      text-decoration: none;
      border-top: 0.5px solid var(--color-border-tertiary);
    }
    .view-all-link:hover { color: var(--text-secondary); }

    /* ── UPCOMING PLACEHOLDER ───────────────── */
    .upcoming-placeholder {
      border: 0.5px dashed var(--color-border-tertiary);
      border-radius: var(--radius);
      background: var(--color-background-secondary);
      padding: 14px;
      text-align: center;
      margin-bottom: 10px;
    }

    .upcoming-placeholder p {
      font-size: 11px;
      color: var(--color-text-tertiary);
    }

    /* ── NOTES TRIGGER ──────────────────────── */
    .notes-trigger {
      background: var(--surface);
      border: 0.5px solid var(--color-border-secondary);
      border-radius: var(--radius);
      padding: 8px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      box-shadow: var(--shadow);
    }
    .notes-trigger:hover { background: rgba(47,47,47,0.02); }

    .notes-icon { font-size: 15px; color: var(--text-muted); }
    .notes-label { font-size: 12px; color: var(--text-secondary); flex: 1; }

    .notes-count {
      background: rgba(47,47,47,0.07);
      color: var(--text-secondary);
      border-radius: 20px;
      padding: 1px 7px;
      font-size: 11px;
      font-weight: 500;
    }

    .notes-chevron { font-size: 11px; color: var(--text-muted); }

    /* ── NOTES PANEL ────────────────────────── */
    .notes-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.25);
      z-index: 100;
    }

    .notes-backdrop.open { display: block; }

    .notes-panel {
      position: fixed;
      top: 0; right: -360px;
      width: 360px;
      height: 100vh;
      background: var(--surface);
      border-left: 0.5px solid var(--color-border-secondary);
      z-index: 101;
      display: flex;
      flex-direction: column;
      transition: right 0.22s ease;
      overflow: hidden;
    }

    .notes-panel.open { right: 0; }

    .notes-panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px;
      border-bottom: 0.5px solid var(--color-border-tertiary);
    }

    .notes-panel-title {
      font-family: var(--heading);
      font-size: 14px;
      font-weight: 500;
      color: var(--text-primary);
    }

    .notes-panel-close {
      background: none;
      border: none;
      font-size: 16px;
      color: var(--text-muted);
      cursor: pointer;
      padding: 2px 6px;
      border-radius: 4px;
    }
    .notes-panel-close:hover { background: rgba(47,47,47,0.06); }

    .notes-panel-add {
      background: transparent;
      border: 0.5px solid var(--color-border-secondary);
      border-radius: 6px;
      padding: 6px 12px;
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-secondary);
      cursor: pointer;
      margin: 12px 16px 0;
    }

    .notes-panel-body {
      flex: 1;
      overflow-y: auto;
      padding: 12px 16px;
    }

    .notes-text {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.55;
      white-space: pre-wrap;
    }

    .notes-empty {
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
    }

    /* ── EMPTY STATE ────────────────────────── */
    .empty-muted {
      font-size: 12px;
      color: var(--text-muted);
      padding: 10px 14px;
      font-style: italic;
    }

    /* ── INLINE EDITING ──────────────────────── */
    .edit-field-row {
      display: flex; gap: 10px; align-items: flex-start;
      padding: 7px 14px; border-bottom: 0.5px solid var(--color-border-tertiary);
      font-size: 12px;
    }
    .edit-field-row:last-child { border-bottom: none; }
    .edit-field-key { color: var(--text-muted); min-width: 110px; flex-shrink: 0; font-size: 11px; padding-top: 2px; }
    .editable-wrap { display: flex; align-items: flex-start; gap: 6px; flex: 1; }
    .field-display { color: var(--text-secondary); flex: 1; }
    .pencil-btn {
      display: none; background: none; border: none; cursor: pointer;
      font-size: 11px; color: var(--text-muted); padding: 0 2px; line-height: 1.4;
      flex-shrink: 0; opacity: 0.7; transition: opacity 0.12s; margin-top: 1px;
    }
    .edit-field-row:hover .pencil-btn { display: inline-block; }
    .pencil-btn:hover { opacity: 1; color: var(--color-teal); }
    .edit-input, .edit-textarea {
      font-family: var(--font-body, sans-serif); font-size: 12px; color: var(--text-primary);
      border: 1px solid var(--color-teal); border-radius: 5px; padding: 3px 7px;
      background: var(--color-surface); outline: none; width: 100%; box-sizing: border-box;
    }
    .edit-textarea { resize: vertical; }
    .edit-actions { display: flex; gap: 5px; margin-top: 4px; }
    .edit-save, .edit-cancel {
      font-size: 11px; font-weight: 500; border-radius: 4px; padding: 2px 9px;
      cursor: pointer; border: 1px solid; transition: opacity 0.12s;
    }
    .edit-save { background: var(--color-teal); color: #fff; border-color: var(--color-teal); }
    .edit-save:hover { opacity: 0.85; }
    .edit-cancel { background: none; color: var(--text-muted); border-color: var(--color-border-secondary); }
    .edit-cancel:hover { color: var(--text-primary); }
    .edit-error { font-size: 10px; color: #C0392B; margin-top: 2px; }
  </style>
</head>
<body>
<div class="os-shell">

  <!-- SIDEBAR -->
  <nav class="sidebar">
