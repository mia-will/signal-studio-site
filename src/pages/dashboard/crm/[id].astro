<script>
// ── Inline editing ─────────────────────────────────────────────────────────
function makeEditable(row: HTMLElement) {
  const api = row.dataset.api!
  const field = row.dataset.field!
  const type = row.dataset.type!
  const rawValue = row.dataset.raw ?? ''
  const wrap = row.querySelector<HTMLElement>('.editable-wrap')!
  const display = wrap.querySelector<HTMLElement>('.field-display')!
  const pencil = wrap.querySelector<HTMLButtonElement>('.pencil-btn')!

  pencil.addEventListener('click', () => {
    pencil.style.display = 'none'
    display.style.display = 'none'

    let input: HTMLInputElement | HTMLTextAreaElement
    if (type === 'textarea' || type === 'tags') {
      const ta = document.createElement('textarea')
      ta.className = 'edit-textarea'
      ta.rows = Number(row.dataset.rows ?? 3)
      ta.value = rawValue
      input = ta
    } else {
      const inp = document.createElement('input')
      inp.className = 'edit-input'
      inp.type = 'text'
      inp.value = rawValue
      input = inp
    }

    const actionsDiv = document.createElement('div')
    actionsDiv.className = 'edit-actions'
    const saveBtn = document.createElement('button')
    saveBtn.className = 'edit-save'; saveBtn.type = 'button'; saveBtn.textContent = 'Save'
    const cancelBtn = document.createElement('button')
    cancelBtn.className = 'edit-cancel'; cancelBtn.type = 'button'; cancelBtn.textContent = 'Cancel'
    actionsDiv.appendChild(saveBtn); actionsDiv.appendChild(cancelBtn)

    const errorEl = document.createElement('div')
    errorEl.className = 'edit-error'; errorEl.style.display = 'none'

    const editWrap = document.createElement('div')
    editWrap.style.flex = '1'
    editWrap.appendChild(input)
    editWrap.appendChild(actionsDiv)
    editWrap.appendChild(errorEl)
    wrap.appendChild(editWrap)

    input.focus()

    function revert() {
      editWrap.remove()
      display.style.display = ''
      pencil.style.display = ''
    }

    cancelBtn.addEventListener('click', revert)

    saveBtn.addEventListener('click', async () => {
      let value: unknown = input.value
      if (type === 'tags') {
        value = (input.value as string).split(',').map((s: string) => s.trim()).filter(Boolean)
      }

      saveBtn.disabled = true; saveBtn.textContent = 'Saving…'
      errorEl.style.display = 'none'

      try {
        const res = await fetch(api, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ field, value }),
        })
        const data = await res.json()
        if (!res.ok) throw new Error(data.error ?? `Error ${res.status}`)

        if (type === 'tags' && Array.isArray(value)) {
          row.dataset.raw = (value as string[]).join(', ')
          display.textContent = (value as string[]).length > 0 ? (value as string[]).join(', ') : '—'
        } else {
          row.dataset.raw = String(value ?? '')
          display.textContent = String(value ?? '') || '—'
          if (type === 'textarea') display.style.whiteSpace = 'pre-wrap'
        }
        revert()
      } catch (err: unknown) {
        errorEl.textContent = err instanceof Error ? err.message : 'Save failed'
        errorEl.style.display = 'block'
        saveBtn.disabled = false; saveBtn.textContent = 'Save'
      }
    })
  })
}

document.querySelectorAll<HTMLElement>('[data-field]').forEach(makeEditable)
</script>

<script is:inline>
  (function () {
    // Notes panel
    const trigger  = document.getElementById('notes-trigger')
    const backdrop = document.getElementById('notes-backdrop')
    const panel    = document.getElementById('notes-panel')
    const closeBtn = document.getElementById('notes-close')

    function openNotes() {
      backdrop.classList.add('open')
      panel.classList.add('open')
    }

    function closeNotes() {
      backdrop.classList.remove('open')
      panel.classList.remove('open')
    }

    trigger.addEventListener('click', openNotes)
    backdrop.addEventListener('click', closeNotes)
    closeBtn.addEventListener('click', closeNotes)

    // Activity show more
    const showMore = document.getElementById('activity-show-more')
    const hidden   = document.getElementById('activity-hidden')

    if (showMore && hidden) {
      showMore.addEventListener('click', function () {
        hidden.classList.add('expanded')
        showMore.style.display = 'none'
      })
    }
  })()
</script>

