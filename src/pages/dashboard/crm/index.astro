---
export const prerender = false
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'
import DashboardLayout from '../../../layouts/DashboardLayout.astro'

type OrgRaw = { name: string | null; type: string | null } | null
type ProjectRaw = { stage: string | null; client_business_name: string | null }

function flattenContact(c: Record<string, unknown>) {
  const org = c.organisations as OrgRaw
  const rawProjects = c.client_projects
  const projects: ProjectRaw[] = Array.isArray(rawProjects)
    ? rawProjects as ProjectRaw[]
    : rawProjects ? [rawProjects as ProjectRaw] : []
  const activeProject = projects.find(p => p.stage === 'Active') ?? projects[0] ?? null
  return {
    id:                   c.id as string,
    first_name:           c.first_name as string | null,
    last_name:            c.last_name as string | null,
    email:                c.email as string | null,
    phone:                c.phone as string | null,
    audience_track:       c.audience_track as string | null,
    readiness_stage:      c.readiness_stage as string | null,
    engagement_score:     c.engagement_score as number | null,
    last_active:          c.last_active as string | null,
    source:               c.source as string | null,
    subscriber:           c.subscriber as boolean | null,
    do_not_contact:       c.do_not_contact as boolean | null,
    suburb:               c.suburb as string | null,
    state:                c.state as string | null,
    leaders_group:        c.leaders_group as boolean | null,
    created_at:           c.created_at as string | null,
    organisation_name:    org?.name ?? null,
    organisation_type:    org?.type ?? null,
    client_stage:         activeProject?.stage ?? null,
    client_business_name: activeProject?.client_business_name ?? null,
  }
}

const SELECT = `
  id, first_name, last_name, email, phone,
  audience_track, readiness_stage, engagement_score,
  last_active, source, subscriber, do_not_contact,
  suburb, state, leaders_group, created_at,
  organisations!organisation_id ( name, type ),
  client_projects!contact_id ( stage, client_business_name )
`

const [contactsRes, michelleRes] = await Promise.all([
  supabase
    .from('contacts_crm')
    .select(SELECT)
    .neq('email', 'michelle@theremix.au')
    .order('engagement_score', { ascending: false, nullsFirst: false }),
  supabase
    .from('contacts_crm')
    .select(SELECT)
    .eq('email', 'michelle@theremix.au')
    .maybeSingle(),
])

const contacts       = (contactsRes.data ?? []).map(c => flattenContact(c as Record<string, unknown>))
const michelle       = michelleRes.data ? flattenContact(michelleRes.data as Record<string, unknown>) : null

const totalCount      = contacts.length
const subscribedCount = contacts.filter(c => c.subscriber === true).length
const generalCount    = contacts.filter(c => c.subscriber === false || c.subscriber === null).length
const clientsCount    = contacts.filter(c => c.client_stage !== null).length
---

<DashboardLayout title="The Signal OS — CRM">
<style>
  .content { padding: 0; overflow-x: hidden; min-height: 100vh; }

  /* ── PAGE HEADER ─── */
  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    padding: 20px 24px 12px; gap: 16px;
  }
  .page-header h1 {
    font-family: var(--heading); font-size: 22px; font-weight: 500;
    color: var(--color-text-primary); line-height: 1.2;
  }
  .page-header-sub {
    font-family: var(--body); font-size: 13px;
    color: var(--color-text-tertiary); margin-top: 3px;
  }
  .header-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

  .btn-ghost {
    font-family: var(--body); font-size: 12px; color: var(--color-text-tertiary);
    background: none; border: none; cursor: pointer; padding: 4px 8px;
    border-radius: var(--border-radius-md); transition: background 0.12s;
  }
  .btn-ghost:hover { background: var(--color-background-tertiary); }
  .btn-ghost span { color: var(--color-text-secondary); text-decoration: underline; }

  .btn-primary {
    font-family: var(--body); font-size: 12px; font-weight: 500;
    background: var(--color-text-primary); color: var(--color-background-primary);
    border: none; border-radius: var(--border-radius-md); padding: 6px 14px; cursor: pointer;
    transition: opacity 0.12s;
  }
  .btn-primary:hover { opacity: 0.85; }

  /* ── STAT CARDS ─── */
  .stat-cards {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 14px; padding: 0 24px 20px; align-items: start;
  }
  .stat-card {
    align-self: start;
    background: var(--color-background-secondary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 1rem 1.25rem;
    cursor: pointer; transition: border-color 0.15s;
  }
  .stat-card:hover { border-color: var(--color-border-secondary); }
  .stat-card.active { border: 1.5px solid var(--color-border-info); }
  .stat-card-top { display: flex; align-items: center; gap: 5px; margin-bottom: 8px; }
  .stat-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .stat-value {
    font-family: var(--heading); font-size: 1.75rem; font-weight: 500;
    color: var(--color-text-primary); line-height: 1;
  }
  .stat-label {
    font-family: var(--body); font-size: 11px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-tertiary);
  }

  /* ── AUDIENCE TABS ─── */
  .tab-bar {
    display: flex; align-items: center;
    border-bottom: 1px solid var(--color-border-tertiary);
    margin: 0 24px 14px;
  }
  .tab {
    font-family: var(--body); font-size: 13px; font-weight: 400;
    color: var(--color-text-secondary);
    background: none; border: none; cursor: pointer;
    padding: 8px 14px;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.12s, border-color 0.12s;
  }
  .tab:hover { color: var(--color-text-primary); }
  .tab.active { color: var(--color-text-primary); font-weight: 500; border-bottom-color: var(--color-text-primary); }

  /* ── TOOLBAR ─── */
  .toolbar { display: flex; align-items: center; gap: 8px; margin: 0 24px 10px; }
  .search-input {
    flex: 1;
    border: 1px solid var(--color-border-tertiary); border-radius: var(--border-radius-md);
    padding: 7px 12px;
    font-family: var(--body); font-size: 13px; color: var(--color-text-primary);
    background: var(--color-background-primary); outline: none; transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--color-border-secondary); }
  .search-input::placeholder { color: var(--color-text-tertiary); }
  .sort-select {
    border: 1px solid var(--color-border-tertiary); border-radius: var(--border-radius-md);
    padding: 7px 10px;
    font-family: var(--body); font-size: 12px; color: var(--color-text-secondary);
    background: var(--color-background-primary); outline: none; cursor: pointer;
  }

  /* ── COLUMN TOGGLES ─── */
  .col-toggles {
    display: flex; align-items: center; gap: 6px;
    margin: 0 24px 12px; flex-wrap: wrap;
  }
  .col-label { font-family: var(--body); font-size: 11px; color: var(--color-text-tertiary); margin-right: 2px; }
  .col-pill {
    font-family: var(--body); font-size: 11px; font-weight: 500;
    border-radius: 20px; padding: 3px 10px;
    cursor: pointer; border: 1px solid var(--color-border-tertiary);
    transition: background 0.12s, color 0.12s, border-color 0.12s;
    user-select: none;
  }
  .col-pill.on  { background: var(--color-text-primary); color: var(--color-background-primary); border-color: var(--color-text-primary); }
  .col-pill.off { background: transparent; color: var(--color-text-tertiary); border-color: var(--color-border-tertiary); }

  /* ── TABLE ─── */
  .table-wrap {
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    overflow: hidden; margin: 0 24px;
  }
  table {
    width: 100%; border-collapse: collapse;
    font-family: var(--body); font-size: 13px; table-layout: fixed;
  }
  col.col-name         { width: 220px; }
  col.col-track        { width: 90px; }
  col.col-stage        { width: 130px; }
  col.col-score        { width: 60px; }
  col.col-last_active  { width: 100px; }
  col.col-phone        { width: 130px; }
  col.col-organisation { width: 140px; }
  col.col-type         { width: 90px; }
  col.col-source       { width: 100px; }
  col.col-location     { width: 140px; }

  thead th {
    text-align: left; padding: 9px 12px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--color-text-tertiary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    white-space: nowrap; user-select: none; background: var(--color-background-primary);
  }

  tbody td {
    padding: 20px 12px; color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    vertical-align: middle; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  tbody td:first-child { padding: 20px 24px; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr { cursor: pointer; transition: background 0.1s; }
  tbody tr:hover td { background: var(--color-background-secondary); }

  /* ── TRACK PILL ─── */
  .track-pill {
    font-size: 11px; font-weight: 500; border-radius: var(--border-radius-sm);
    padding: 2px 7px; display: inline-block; cursor: pointer;
  }
  .track-builder { background: #E1F5EE; color: #085041; }
  .track-applier { background: #E6F1FB; color: #0C447C; }
  .track-both    { background: #EEEDFE; color: #3C3489; }

  .track-select {
    font-family: var(--body); font-size: 11px;
    border: 1px solid var(--color-border-secondary); border-radius: var(--border-radius-sm);
    padding: 2px 4px; background: var(--color-background-primary);
    color: var(--color-text-primary); outline: none; cursor: pointer;
  }

  /* ── TYPE PILL ─── */
  .type-pill-client {
    font-size: 11px; font-weight: 500; border-radius: var(--border-radius-sm);
    padding: 2px 7px; display: inline-block;
    background: var(--color-background-success); color: var(--color-text-success);
  }
  .type-pill-past {
    font-size: 11px; font-weight: 500; border-radius: var(--border-radius-sm);
    padding: 2px 7px; display: inline-block;
    background: var(--color-background-tertiary); color: var(--color-text-tertiary);
  }

  /* ── EMPTY STATE ─── */
  .table-message {
    padding: 36px 20px; text-align: center;
    color: var(--color-text-tertiary); font-family: var(--body); font-size: 13px; font-style: italic;
  }

  /* ── PAGINATION ─── */
  .pagination-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 24px 0;
    font-family: var(--body); font-size: 13px; color: var(--color-text-tertiary);
  }
  .pagination-left { display: flex; align-items: center; gap: 8px; }
  .pagination-right { display: flex; align-items: center; gap: 6px; }
  .page-size-select {
    font-family: var(--body); font-size: 12px; color: var(--color-text-secondary);
    border: 1px solid var(--color-border-tertiary); border-radius: var(--border-radius-md);
    padding: 3px 8px; background: var(--color-background-primary); cursor: pointer; outline: none;
  }
  .page-btn {
    background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md); padding: 4px 10px;
    font-family: var(--body); font-size: 12px; color: var(--color-text-secondary);
    cursor: pointer; transition: border-color 0.12s, color 0.12s;
  }
  .page-btn:hover:not(:disabled) { border-color: var(--color-border-secondary); color: var(--color-text-primary); }
  .page-btn:disabled { opacity: 0.35; cursor: default; }
  .page-btn.active { background: var(--color-text-primary); color: var(--color-background-primary); border-color: var(--color-text-primary); }
</style>

<main class="content">

  <!-- Page header -->
  <header class="page-header">
    <div>
      <h1>CRM</h1>
      <p class="page-header-sub" id="header-subtitle">{totalCount} contacts · sorted by engagement</p>
    </div>
    <div class="header-actions">
      <button class="btn-ghost" id="toggle-michelle">
        Hiding you · <span id="toggle-label">show anyway</span>
      </button>
      <button class="btn-primary">+ Add contact</button>
    </div>
  </header>

  <!-- Stat cards -->
  <div class="stat-cards" id="stat-cards">
    <div class="stat-card active" data-filter="all">
      <div class="stat-card-top">
        <div class="stat-dot" style="background:var(--color-text-tertiary)"></div>
        <div class="stat-label">All</div>
      </div>
      <div class="stat-value" id="count-all">{totalCount}</div>
    </div>
    <div class="stat-card" data-filter="subscribed">
      <div class="stat-card-top">
        <div class="stat-dot" style="background:var(--color-border-success)"></div>
        <div class="stat-label">Subscribed</div>
      </div>
      <div class="stat-value">{subscribedCount}</div>
    </div>
    <div class="stat-card" data-filter="general">
      <div class="stat-card-top">
        <div class="stat-dot" style="background:var(--color-border-info)"></div>
        <div class="stat-label">General</div>
      </div>
      <div class="stat-value">{generalCount}</div>
    </div>
    <div class="stat-card" data-filter="clients">
      <div class="stat-card-top">
        <div class="stat-dot" style="background:var(--color-text-success)"></div>
        <div class="stat-label">Clients</div>
      </div>
      <div class="stat-value">{clientsCount}</div>
    </div>
  </div>

  <!-- Audience tab row -->
  <div class="tab-bar">
    <button class="tab active" data-tab="all">All</button>
    <button class="tab" data-tab="builder">Builders</button>
    <button class="tab" data-tab="applier">Appliers</button>
    <button class="tab" data-tab="both">Both</button>
    <button class="tab" data-tab="unassigned">Unassigned</button>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <input
      type="text" id="crm-search" class="search-input"
      placeholder="Search by name or email…" autocomplete="off"
    />
    <select id="sort-select" class="sort-select">
      <option value="engagement_score">Engagement score</option>
      <option value="last_active">Last active</option>
      <option value="created_at">Date added</option>
      <option value="name">Name A–Z</option>
    </select>
  </div>

  <!-- Column toggle pills -->
  <div class="col-toggles" id="col-toggles">
    <span class="col-label">Columns:</span>
    <button class="col-pill on"  data-col="track">Track</button>
    <button class="col-pill on"  data-col="stage">Stage</button>
    <button class="col-pill on"  data-col="score">Score</button>
    <button class="col-pill on"  data-col="last_active">Last active</button>
    <button class="col-pill off" data-col="phone">Phone</button>
    <button class="col-pill off" data-col="organisation">Organisation</button>
    <button class="col-pill off" data-col="type">Type</button>
    <button class="col-pill off" data-col="source">Source</button>
    <button class="col-pill off" data-col="location">Location</button>
  </div>

  <!-- Contact table -->
  <div class="table-wrap">
    <table>
      <colgroup>
        <col class="col-name">
        <col class="col-track"        data-col="track">
        <col class="col-stage"        data-col="stage">
        <col class="col-score"        data-col="score">
        <col class="col-last_active"  data-col="last_active">
        <col class="col-phone"        data-col="phone">
        <col class="col-organisation" data-col="organisation">
        <col class="col-type"         data-col="type">
        <col class="col-source"       data-col="source">
        <col class="col-location"     data-col="location">
      </colgroup>
      <thead>
        <tr>
          <th>Name</th>
          <th data-col="track">Track</th>
          <th data-col="stage">Stage</th>
          <th data-col="score">Score</th>
          <th data-col="last_active">Last active</th>
          <th data-col="phone">Phone</th>
          <th data-col="organisation">Organisation</th>
          <th data-col="type">Type</th>
          <th data-col="source">Source</th>
          <th data-col="location">Location</th>
        </tr>
      </thead>
      <tbody id="contacts-tbody">
        <tr><td colspan="10" class="table-message">Loading…</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="pagination-row" id="pagination-row">
    <div class="pagination-left">
      <span id="pagination-info"></span>
      <select class="page-size-select" id="page-size-select">
        <option value="10">Show 10</option>
        <option value="20">Show 20</option>
      </select>
    </div>
    <div class="pagination-right">
      <button class="page-btn" id="btn-prev">←</button>
      <span id="page-numbers"></span>
      <button class="page-btn" id="btn-next">→</button>
    </div>
  </div>

</main>

<!-- Embedded data -->
<script is:inline type="application/json" id="contacts-data" set:html={JSON.stringify(contacts)}></script>
<script is:inline type="application/json" id="michelle-data" set:html={JSON.stringify(michelle)}></script>

<script>
  type Contact = {
    id: string
    first_name: string | null
    last_name: string | null
    email: string | null
    phone: string | null
    audience_track: string | null
    readiness_stage: string | null
    engagement_score: number | null
    last_active: string | null
    source: string | null
    subscriber: boolean | null
    do_not_contact: boolean | null
    suburb: string | null
    state: string | null
    leaders_group: boolean | null
    created_at: string | null
    organisation_name: string | null
    organisation_type: string | null
    client_stage: string | null
    client_business_name: string | null
  }

  // ── Data ──────────────────────────────────
  const baseContacts: Contact[] = JSON.parse(document.getElementById('contacts-data')!.textContent ?? '[]')
  const michelleContact: Contact | null = JSON.parse(document.getElementById('michelle-data')!.textContent ?? 'null')

  // ── State ─────────────────────────────────
  const LS_COL  = 'crm_columns_v2'
  const LS_SORT = 'crm_sort'

  const DEFAULT_VISIBLE = new Set(['track','stage','score','last_active'])

  function loadColumns(): Set<string> {
    try {
      const saved = JSON.parse(localStorage.getItem(LS_COL) ?? 'null')
      if (Array.isArray(saved)) return new Set(saved)
    } catch {}
    return new Set(DEFAULT_VISIBLE)
  }

  function loadSort(): { col: string; dir: 'asc' | 'desc' } {
    try {
      const saved = JSON.parse(localStorage.getItem(LS_SORT) ?? 'null')
      if (saved?.col) return saved
    } catch {}
    return { col: 'engagement_score', dir: 'desc' }
  }

  let showMichelle  = false
  let activeSegment = 'all'
  let activeTrack   = 'all'
  let currentSort   = loadSort()
  let currentPage   = 0
  let pageSize      = 20
  let visibleCols   = loadColumns()
  let searchQuery   = ''

  function allContacts(): Contact[] {
    return showMichelle && michelleContact ? [...baseContacts, michelleContact] : baseContacts
  }

  // ── Helpers ───────────────────────────────
  function fullName(c: Contact): string {
    return [c.first_name, c.last_name].filter(Boolean).join(' ') || '—'
  }

  function relativeDate(ts: string | null): string {
    if (!ts) return '—'
    const diff = Date.now() - new Date(ts).getTime()
    const m = Math.floor(diff / 60000)
    if (m < 1)  return 'just now'
    if (m < 60) return `${m}m ago`
    const h = Math.floor(m / 60)
    if (h < 24) return `${h}h ago`
    const d = Math.floor(h / 24)
    if (d < 7)  return `${d}d ago`
    if (d < 30) return `${Math.floor(d / 7)}w ago`
    return `${Math.floor(d / 30)}mo ago`
  }

  function scoreColor(score: number | null): string {
    if (score === null) return 'var(--color-text-tertiary)'
    if (score >= 20) return 'var(--color-text-success)'
    if (score >= 8)  return 'var(--color-text-warning)'
    return 'var(--color-text-tertiary)'
  }

  function trackPillHtml(track: string | null): string {
    if (!track) return '<span style="color:var(--color-text-tertiary)">—</span>'
    const map: Record<string, string> = {
      builder: '<span class="track-pill track-builder">Builder</span>',
      applier: '<span class="track-pill track-applier">Applier</span>',
      both:    '<span class="track-pill track-both">Both</span>',
    }
    return map[track.toLowerCase()] ??
      `<span class="track-pill" style="background:var(--color-background-tertiary);color:var(--color-text-secondary)">${track}</span>`
  }

  function typePillHtml(clientStage: string | null): string {
    if (!clientStage) return ''
    if (clientStage === 'Active') return '<span class="type-pill-client">Client</span>'
    return '<span class="type-pill-past">Past client</span>'
  }

  // ── Filter ────────────────────────────────
  function filtered(): Contact[] {
    let list = allContacts()

    if (activeSegment === 'subscribed') {
      list = list.filter(c => c.subscriber === true)
    } else if (activeSegment === 'general') {
      list = list.filter(c => c.subscriber === false || c.subscriber === null)
    } else if (activeSegment === 'clients') {
      list = list.filter(c => c.client_stage !== null)
    }

    if (activeTrack === 'builder')    list = list.filter(c => c.audience_track === 'builder')
    else if (activeTrack === 'applier') list = list.filter(c => c.audience_track === 'applier')
    else if (activeTrack === 'both')    list = list.filter(c => c.audience_track === 'both')
    else if (activeTrack === 'unassigned') list = list.filter(c => !c.audience_track)

    if (searchQuery) {
      const q = searchQuery.toLowerCase()
      list = list.filter(c =>
        fullName(c).toLowerCase().includes(q) ||
        (c.email ?? '').toLowerCase().includes(q)
      )
    }

    return [...list].sort((a, b) => {
      const dir = currentSort.dir === 'asc' ? 1 : -1
      if (currentSort.col === 'name') {
        return dir * fullName(a).localeCompare(fullName(b))
      }
      if (currentSort.col === 'engagement_score') {
        return dir * ((a.engagement_score ?? -1) - (b.engagement_score ?? -1))
      }
      if (currentSort.col === 'last_active') {
        const ta = a.last_active ? new Date(a.last_active).getTime() : 0
        const tb = b.last_active ? new Date(b.last_active).getTime() : 0
        return dir * (ta - tb)
      }
      if (currentSort.col === 'created_at') {
        const ta = a.created_at ? new Date(a.created_at).getTime() : 0
        const tb = b.created_at ? new Date(b.created_at).getTime() : 0
        return dir * (ta - tb)
      }
      return 0
    })
  }

  // ── Column visibility ─────────────────────
  const ALL_COLS = ['track','stage','score','last_active','phone','organisation','type','source','location']

  function applyColumnVisibility() {
    ALL_COLS.forEach(col => {
      const on = visibleCols.has(col)
      document.querySelectorAll(`col[data-col="${col}"]`).forEach(el => {
        (el as HTMLElement).style.display = on ? '' : 'none'
      })
      document.querySelectorAll(`th[data-col="${col}"]`).forEach(el => {
        (el as HTMLElement).style.display = on ? '' : 'none'
      })
    })
  }

  function syncColPills() {
    document.querySelectorAll('.col-pill').forEach(el => {
      const col = (el as HTMLElement).dataset.col!
      el.classList.toggle('on',  visibleCols.has(col))
      el.classList.toggle('off', !visibleCols.has(col))
    })
    applyColumnVisibility()
  }

  // ── Inline track edit ─────────────────────
  async function patchTrack(id: string, value: string | null) {
    const res = await fetch(`/api/dashboard/contacts/${id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ field: 'audience_track', value: value || null }),
    })
    if (!res.ok) return false
    const contact = baseContacts.find(c => c.id === id)
    if (contact) contact.audience_track = value || null
    return true
  }

  function openTrackSelect(cell: HTMLElement, contactId: string, currentTrack: string | null) {
    const select = document.createElement('select')
    select.className = 'track-select'
    select.innerHTML = `
      <option value="">—</option>
      <option value="builder"${currentTrack === 'builder' ? ' selected' : ''}>Builder</option>
      <option value="applier"${currentTrack === 'applier' ? ' selected' : ''}>Applier</option>
      <option value="both"${currentTrack === 'both' ? ' selected' : ''}>Both</option>
    `

    select.addEventListener('change', async () => {
      const newVal = select.value || null
      const ok = await patchTrack(contactId, newVal)
      if (ok) {
        cell.innerHTML = trackPillHtml(newVal)
        attachTrackClick(cell, contactId, newVal)
      } else {
        cell.innerHTML = trackPillHtml(currentTrack)
        attachTrackClick(cell, contactId, currentTrack)
      }
    })

    select.addEventListener('blur', () => {
      cell.innerHTML = trackPillHtml(currentTrack)
      attachTrackClick(cell, contactId, currentTrack)
    })

    cell.innerHTML = ''
    cell.appendChild(select)
    select.focus()
  }

  function attachTrackClick(cell: HTMLElement, contactId: string, track: string | null) {
    cell.onclick = (e) => {
      e.stopPropagation()
      openTrackSelect(cell, contactId, track)
    }
  }

  // ── Render table ──────────────────────────
  function render() {
    const list  = filtered()
    const total = list.length
    const start = currentPage * pageSize
    const page  = list.slice(start, start + pageSize)
    const cols  = visibleCols

    const sortLabels: Record<string, string> = {
      engagement_score: 'engagement score',
      last_active: 'last active',
      created_at: 'date added',
      name: 'name A–Z',
    }
    document.getElementById('header-subtitle')!.textContent =
      `${total} contact${total !== 1 ? 's' : ''} · sorted by ${sortLabels[currentSort.col] ?? currentSort.col}`

    const tbody = document.getElementById('contacts-tbody')!
    if (page.length === 0) {
      tbody.innerHTML = `<tr><td colspan="10" class="table-message">No contacts match this filter.</td></tr>`
    } else {
      tbody.innerHTML = page.map(c => {
        const score = c.engagement_score
        const stage = c.readiness_stage ? c.readiness_stage.replace(/_/g, ' ') : '—'
        return `<tr data-id="${c.id}" onclick="window.location='/dashboard/crm/${c.id}'">
          <td>
            <div style="font-size:13px;font-weight:500;color:var(--color-text-primary)">${fullName(c)}</div>
            <div style="font-size:12px;color:var(--color-text-secondary)">${c.email ?? '—'}</div>
          </td>
          ${cols.has('track')        ? `<td class="track-cell" data-id="${c.id}" data-track="${c.audience_track ?? ''}">${trackPillHtml(c.audience_track)}</td>` : ''}
          ${cols.has('stage')        ? `<td style="font-size:11px;color:var(--color-text-tertiary)">${stage}</td>` : ''}
          ${cols.has('score')        ? `<td style="font-variant-numeric:tabular-nums;font-weight:500;color:${scoreColor(score)}">${score ?? '—'}</td>` : ''}
          ${cols.has('last_active')  ? `<td style="font-size:12px;color:var(--color-text-tertiary)">${relativeDate(c.last_active)}</td>` : ''}
          ${cols.has('phone')        ? `<td style="font-size:12px">${c.phone ?? '—'}</td>` : ''}
          ${cols.has('organisation') ? `<td style="font-size:12px">${c.organisation_name ?? '—'}</td>` : ''}
          ${cols.has('type')         ? `<td>${typePillHtml(c.client_stage)}</td>` : ''}
          ${cols.has('source')       ? `<td style="font-size:12px;color:var(--color-text-tertiary)">${c.source ?? '—'}</td>` : ''}
          ${cols.has('location')     ? `<td style="font-size:12px;color:var(--color-text-tertiary)">${[c.suburb, c.state].filter(Boolean).join(' · ') || '—'}</td>` : ''}
        </tr>`
      }).join('')

      // Attach track cell click handlers
      tbody.querySelectorAll('.track-cell').forEach(cell => {
        const el = cell as HTMLElement
        const id = el.dataset.id!
        const track = el.dataset.track || null
        attachTrackClick(el, id, track)
      })
    }

    // Pagination info
    const pageCount = Math.ceil(total / pageSize)
    const s = total === 0 ? 0 : start + 1
    const e = Math.min(start + pageSize, total)
    document.getElementById('pagination-info')!.textContent =
      total === 0 ? '' : `Showing ${s}–${e} of ${total}`

    ;(document.getElementById('btn-prev') as HTMLButtonElement).disabled = currentPage === 0
    ;(document.getElementById('btn-next') as HTMLButtonElement).disabled = currentPage >= pageCount - 1

    const pageNumEl = document.getElementById('page-numbers')!
    if (pageCount <= 1) {
      pageNumEl.innerHTML = ''
    } else {
      const pages: Array<number | '...'> = []
      if (pageCount <= 5) {
        for (let i = 0; i < pageCount; i++) pages.push(i)
      } else {
        pages.push(0)
        if (currentPage > 2) pages.push('...')
        for (let i = Math.max(1, currentPage - 1); i <= Math.min(pageCount - 2, currentPage + 1); i++) pages.push(i)
        if (currentPage < pageCount - 3) pages.push('...')
        pages.push(pageCount - 1)
      }
      pageNumEl.innerHTML = pages.map(p =>
        p === '...'
          ? `<span style="padding:0 4px;color:var(--color-text-tertiary)">…</span>`
          : `<button class="page-btn${p === currentPage ? ' active' : ''}" data-page="${p}">${(p as number) + 1}</button>`
      ).join('')
      pageNumEl.querySelectorAll('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => {
          currentPage = parseInt((btn as HTMLElement).dataset.page!)
          render()
        })
      })
    }
  }

  // ── Init ──────────────────────────────────
  applyColumnVisibility()
  syncColPills()
  render()

  // ── Events: stat cards ────────────────────
  document.getElementById('stat-cards')!.addEventListener('click', e => {
    const card = (e.target as HTMLElement).closest('[data-filter]') as HTMLElement | null
    if (!card) return
    activeSegment = card.dataset.filter!
    currentPage = 0
    document.querySelectorAll('.stat-card').forEach(c =>
      c.classList.toggle('active', (c as HTMLElement).dataset.filter === activeSegment)
    )
    render()
  })

  // ── Events: tabs ──────────────────────────
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeTrack = (btn as HTMLElement).dataset.tab!
      currentPage = 0
      document.querySelectorAll('.tab').forEach(b => b.classList.toggle('active', b === btn))
      render()
    })
  })

  // ── Events: search ────────────────────────
  document.getElementById('crm-search')!.addEventListener('input', e => {
    searchQuery = (e.target as HTMLInputElement).value
    currentPage = 0
    render()
  })

  // ── Events: sort select ───────────────────
  document.getElementById('sort-select')!.addEventListener('change', e => {
    const val = (e.target as HTMLSelectElement).value
    currentSort = { col: val, dir: val === 'name' ? 'asc' : 'desc' }
    currentPage = 0
    localStorage.setItem(LS_SORT, JSON.stringify(currentSort))
    render()
  })

  // ── Events: page size ─────────────────────
  document.getElementById('page-size-select')!.addEventListener('change', e => {
    pageSize = parseInt((e.target as HTMLSelectElement).value)
    currentPage = 0
    render()
  })

  // ── Events: column toggles ────────────────
  document.getElementById('col-toggles')!.addEventListener('click', e => {
    const pill = (e.target as HTMLElement).closest('.col-pill') as HTMLElement | null
    if (!pill) return
    const col = pill.dataset.col!
    if (visibleCols.has(col)) visibleCols.delete(col)
    else visibleCols.add(col)
    localStorage.setItem(LS_COL, JSON.stringify([...visibleCols]))
    syncColPills()
    render()
  })

  // ── Events: Michelle toggle ───────────────
  document.getElementById('toggle-michelle')!.addEventListener('click', () => {
    showMichelle = !showMichelle
    const label = document.getElementById('toggle-label')!
    const btn   = document.getElementById('toggle-michelle')!
    if (showMichelle) {
      label.textContent = 'hide again'
      btn.childNodes[0].textContent = 'Showing you · '
    } else {
      label.textContent = 'show anyway'
      btn.childNodes[0].textContent = 'Hiding you · '
    }
    currentPage = 0
    render()
  })

  // ── Events: pagination ────────────────────
  document.getElementById('btn-prev')!.addEventListener('click', () => { currentPage--; render() })
  document.getElementById('btn-next')!.addEventListener('click', () => { currentPage++; render() })
</script>
</DashboardLayout>
