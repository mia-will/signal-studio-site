---
export const prerender = false
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'

const { data: agents } = await supabase
  .from('agents_registry')
  .select('id, name, status, area, type')
  .order('created_at', { ascending: false })

const agentsList = agents ?? []
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Signal OS — New Agent</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:             #F5F4F1;
      --surface:        #FFFFFF;
      --text-primary:   #2F2F2F;
      --text-secondary: #505050;
      --text-muted:     #909090;
      --border:         rgba(47,47,47,0.08);
      --teal:           #3C8A7E;
      --orange:         #FF8A33;
      --green:          #7BBE9A;
      --red:            #C0392B;
      --dark:           #111111;
      --heading:        'DM Sans', sans-serif;
      --body:           'Inter', sans-serif;
    }

    body { background: var(--bg); color: var(--text-primary); font-family: var(--body); overflow: hidden; }

    /* ── SHELL ─────────────────────────────────────────────────────────────── */
    .os-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
      height: 100vh;
      overflow: hidden;
    }

    /* ── SIDEBAR ───────────────────────────────────────────────────────────── */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 20px 16px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 20px 16px 4px;
    }
    .nav-item {
      display: block;
      font-size: 13px;
      color: var(--text-secondary);
      padding: 6px 16px;
      border-radius: 6px;
      margin: 1px 8px;
      text-decoration: none;
    }
    .nav-item.active { background: rgba(60,138,126,0.10); color: var(--teal); font-weight: 500; }
    .sidebar-footer {
      margin-top: auto;
      padding: 14px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--teal); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; flex-shrink: 0;
    }
    .footer-name { font-size: 12px; font-weight: 500; color: var(--text-primary); line-height: 1.2; }
    .footer-role { font-size: 11px; color: var(--text-muted); }

    /* ── BUILDER LAYOUT ────────────────────────────────────────────────────── */
    .builder-main {
      display: grid;
      grid-template-columns: 2fr 3fr;
      height: 100vh;
      overflow: hidden;
    }

    /* ── AGENTS PANEL (left) ───────────────────────────────────────────────── */
    .agents-panel {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      background: var(--surface);
      overflow: hidden;
    }
    .panel-header {
      padding: 16px 18px 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    .panel-header h2 {
      font-family: var(--heading);
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
    }
    .badge-count {
      background: var(--orange);
      color: white;
      font-size: 11px;
      font-weight: 600;
      border-radius: 20px;
      padding: 1px 7px;
    }
    .back-link {
      margin-left: auto;
      font-size: 12px;
      color: var(--teal);
      text-decoration: none;
    }
    .back-link:hover { text-decoration: underline; }

    .filter-bar {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }
    .filter-bar select {
      flex: 1;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 8px;
      font-size: 12px;
      font-family: var(--body);
      color: var(--text-secondary);
      background: var(--bg);
      cursor: pointer;
    }

    .agents-list {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }
    .agent-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 18px;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      gap: 8px;
    }
    .agent-row:hover { background: rgba(60,138,126,0.03); }
    .agent-row:last-child { border-bottom: none; }
    .agent-row-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
      flex: 1;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .agent-row-badges {
      display: flex;
      align-items: center;
      gap: 5px;
      flex-shrink: 0;
    }
    .badge {
      display: inline-block;
      border-radius: 20px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 500;
    }
    .badge-area { background: rgba(60,138,126,0.08); color: var(--teal); }
    .status-live, .status-active    { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .status-draft, .status-to_build { background: rgba(47,47,47,0.08);   color: var(--text-secondary); }
    .status-paused                  { background: rgba(255,138,51,0.12);  color: #E07020; }
    .status-deprecated              { background: rgba(192,57,43,0.12);   color: var(--red); }
    .empty-state {
      padding: 24px 18px;
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
    }

    /* ── CHAT PANEL (right) ────────────────────────────────────────────────── */
    .chat-panel {
      display: flex;
      flex-direction: column;
      background: var(--bg);
      overflow: hidden;
    }
    .chat-header {
      padding: 16px 24px 14px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }
    .chat-header h2 {
      font-family: var(--heading);
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .chat-header p {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 2px;
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .message {
      max-width: 85%;
      font-size: 13px;
      line-height: 1.55;
      border-radius: 10px;
      padding: 10px 14px;
    }
    .message-assistant {
      background: var(--surface);
      color: var(--text-primary);
      border: 1px solid var(--border);
      align-self: flex-start;
      border-bottom-left-radius: 3px;
    }
    .message-user {
      background: var(--dark);
      color: #FFFFFF;
      align-self: flex-end;
      border-bottom-right-radius: 3px;
    }
    .message-system {
      background: rgba(60,138,126,0.08);
      color: var(--teal);
      border: 1px solid rgba(60,138,126,0.15);
      align-self: center;
      font-size: 12px;
      border-radius: 6px;
    }

    .chat-footer {
      padding: 14px 24px;
      border-top: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }
    .chat-input-row {
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }
    .chat-input {
      flex: 1;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 13px;
      font-family: var(--body);
      color: var(--text-primary);
      background: var(--bg);
      resize: none;
      min-height: 38px;
      max-height: 120px;
      line-height: 1.4;
    }
    .chat-input:focus { outline: none; border-color: var(--teal); }
    .chat-input:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-send {
      background: var(--dark);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 9px 18px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      flex-shrink: 0;
      height: 38px;
    }
    .btn-send:hover { background: #2a2a2a; }
    .btn-send:disabled { opacity: 0.4; cursor: not-allowed; }

    .save-status {
      margin-top: 10px;
      font-size: 12px;
      padding: 8px 12px;
      border-radius: 6px;
    }
    .save-status-pending { background: rgba(47,47,47,0.06); color: var(--text-muted); }
    .save-status-success { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .save-status-error   { background: rgba(192,57,43,0.10); color: var(--red); }
  </style>
</head>
<body>
<div class="os-shell">

  <!-- ── SIDEBAR ───────────────────────────────────────────────────────────── -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <span>✦</span>
      <span>THE SIGNAL OS</span>
    </div>
    <div style="padding: 8px 0;">
      <span class="nav-item">🏠 Snapshot</span>
      <div class="nav-section-label">Relationships</div>
      <a href="/dashboard/crm" class="nav-item">CRM</a>
      <span class="nav-item">Growth</span>
      <span class="nav-item">Clients</span>
      <div class="nav-section-label">Delivery</div>
      <span class="nav-item">Projects</span>
      <span class="nav-item">Pathways</span>
      <span class="nav-item">Events</span>
      <div class="nav-section-label">Content</div>
      <span class="nav-item">Content</span>
      <span class="nav-item">Campaigns</span>
      <span class="nav-item">EDMs</span>
      <div class="nav-section-label">Operations</div>
      <span class="nav-item">Finance</span>
      <a href="/dashboard/governance" class="nav-item">Governance</a>
      <span class="nav-item">Automations</span>
      <a href="/dashboard/agents" class="nav-item active">Agents</a>
    </div>
    <div class="sidebar-footer">
      <div class="avatar">M</div>
      <div>
        <div class="footer-name">Michelle</div>
        <div class="footer-role">System Operator</div>
      </div>
    </div>
  </nav>

  <!-- ── BUILDER MAIN ──────────────────────────────────────────────────────── -->
  <div class="builder-main">

    <!-- LEFT: Registered Agents ─────────────────────────────────────────── -->
    <section class="agents-panel">
      <div class="panel-header">
        <h2>Registered Agents</h2>
        <span class="badge-count">{agentsList.length}</span>
        <a href="/dashboard/agents" class="back-link">← All agents</a>
      </div>

      <div class="filter-bar">
        <select id="filter-status">
          <option value="">All status</option>
          <option value="to_build">To build</option>
          <option value="draft">Draft</option>
          <option value="active">Active</option>
          <option value="live">Live</option>
          <option value="paused">Paused</option>
          <option value="deprecated">Deprecated</option>
        </select>
        <select id="filter-area">
          <option value="">All areas</option>
          <option value="contact_management">Contact management</option>
          <option value="email">Email</option>
          <option value="marketing_flow">Marketing flow</option>
          <option value="edm_build">EDM build</option>
          <option value="event_build">Event build</option>
          <option value="content">Content</option>
          <option value="studio_pipeline">Studio pipeline</option>
          <option value="system_ops">System ops</option>
          <option value="finance">Finance</option>
          <option value="personal">Personal</option>
        </select>
      </div>

      <div class="agents-list" id="agents-list">
        {agentsList.length === 0 ? (
          <div class="empty-state">No agents registered yet.</div>
        ) : (
          agentsList.map((agent: any) => (
            <a
              href={`/dashboard/agents/${agent.id}`}
              class="agent-row"
              data-status={agent.status ?? ''}
              data-area={agent.area ?? ''}
              target="_blank"
              rel="noopener"
            >
              <span class="agent-row-name">{agent.name}</span>
              <span class="agent-row-badges">
                {agent.area && (
                  <span class="badge badge-area">
                    {(agent.area as string).replace(/_/g, ' ')}
                  </span>
                )}
                <span class={`badge status-${(agent.status ?? '').replace(/[^a-z_]/g, '')}`}>
                  {agent.status ?? '—'}
                </span>
              </span>
            </a>
          ))
        )}
      </div>
    </section>

    <!-- RIGHT: Chat Builder ──────────────────────────────────────────────── -->
    <section class="chat-panel">
      <div class="chat-header">
        <h2>Agent Builder</h2>
        <p>Claude asks questions one at a time — answer each in turn. It will show a summary and ask you to confirm before saving anything.</p>
      </div>

      <div class="chat-messages" id="chat-messages"></div>

      <div class="chat-footer">
        <div class="chat-input-row">
          <textarea
            id="chat-input"
            class="chat-input"
            rows="2"
            placeholder="Type your answer… (Enter to send, Shift+Enter for new line)"
          ></textarea>
          <button id="send-btn" class="btn-send">Send</button>
        </div>
        <div id="save-status" class="save-status" style="display:none;"></div>
      </div>
    </section>

  </div>
</div>

<script>
  // ── FILTERING ──────────────────────────────────────────────────────────────
  document.getElementById('filter-status')!.addEventListener('change', filterAgents)
  document.getElementById('filter-area')!.addEventListener('change', filterAgents)

  function filterAgents() {
    const status = (document.getElementById('filter-status') as HTMLSelectElement).value
    const area   = (document.getElementById('filter-area')   as HTMLSelectElement).value
    document.querySelectorAll<HTMLElement>('.agent-row').forEach(row => {
      const matchStatus = !status || row.dataset.status === status
      const matchArea   = !area   || row.dataset.area   === area
      row.style.display = (matchStatus && matchArea) ? '' : 'none'
    })
  }

  // ── CHAT ───────────────────────────────────────────────────────────────────
  const FIRST_MESSAGE = "Let's register a new agent. What's the name?"
  const messages: { role: string; content: string }[] = [
    { role: 'assistant', content: FIRST_MESSAGE },
  ]
  let isStreaming = false

  appendMessage('assistant', FIRST_MESSAGE)

  document.getElementById('send-btn')!.addEventListener('click', sendMessage)
  document.getElementById('chat-input')!.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      sendMessage()
    }
  })

  async function sendMessage() {
    if (isStreaming) return
    const input  = document.getElementById('chat-input')  as HTMLTextAreaElement
    const sendBtn = document.getElementById('send-btn')   as HTMLButtonElement
    const text = input.value.trim()
    if (!text) return

    input.value = ''
    input.disabled = true
    sendBtn.disabled = true
    isStreaming = true

    messages.push({ role: 'user', content: text })
    appendMessage('user', text)

    const bubble = appendMessage('assistant', '')

    try {
      const res = await fetch('/api/agents/builder-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      })

      if (!res.ok || !res.body) {
        bubble.textContent = 'Error — could not reach the builder.'
        return
      }

      const reader  = res.body.getReader()
      const decoder = new TextDecoder()
      let fullText  = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        const chunk = decoder.decode(value, { stream: true })
        for (const line of chunk.split('\n')) {
          if (!line.startsWith('data: ')) continue
          const data = line.slice(6).trim()
          if (!data || data === '[DONE]') continue
          try {
            const parsed = JSON.parse(data)
            if (parsed.type === 'content_block_delta' && parsed.delta?.text) {
              fullText += parsed.delta.text as string
              bubble.innerHTML = renderText(fullText)
              scrollToBottom()
            }
          } catch { /* ignore malformed SSE lines */ }
        }
      }

      messages.push({ role: 'assistant', content: fullText })

      // Detect AGENT_READY and trigger create
      const match = fullText.match(/<AGENT_READY>([\s\S]*?)<\/AGENT_READY>/)
      if (match) {
        bubble.innerHTML = renderText(fullText)
        try {
          const agentData = JSON.parse(match[1].trim())
          await createAgent(agentData)
        } catch {
          showStatus('Could not parse agent data — ask Claude to try again.', 'error')
        }
      }
    } finally {
      isStreaming = false
      input.disabled = false
      sendBtn.disabled = false
      input.focus()
    }
  }

  function renderText(raw: string): string {
    // Strip complete AGENT_READY block, or truncate at opening tag if incomplete
    const cleaned = raw
      .replace(/<AGENT_READY>[\s\S]*?<\/AGENT_READY>/g, '')
      .replace(/<AGENT_READY>[\s\S]*$/, '')
      .trim()
    // Escape HTML then restore line breaks
    return cleaned
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>')
  }

  function appendMessage(role: string, text: string): HTMLElement {
    const container = document.getElementById('chat-messages')!
    const el = document.createElement('div')
    el.className = `message message-${role}`
    if (text) el.innerHTML = renderText(text)
    container.appendChild(el)
    scrollToBottom()
    return el
  }

  function scrollToBottom() {
    const container = document.getElementById('chat-messages')!
    container.scrollTop = container.scrollHeight
  }

  async function createAgent(agentData: Record<string, unknown>) {
    showStatus('Saving agent…', 'pending')

    try {
      const res = await fetch('/api/agents/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(agentData),
      })
      const result = await res.json() as { success?: boolean; agent_id?: string; error?: string }

      if (res.ok && result.success && result.agent_id) {
        showStatus(
          `Agent registered — <a href="/dashboard/agents/${result.agent_id}" target="_blank" style="color:#2D5A35;font-weight:600;">View agent →</a>`,
          'success',
        )
        // Append a system message in the chat
        const sys = document.createElement('div')
        sys.className = 'message message-system'
        sys.textContent = 'Agent saved to agents_registry with status: to_build.'
        document.getElementById('chat-messages')!.appendChild(sys)
        scrollToBottom()
      } else {
        showStatus(`Error: ${result.error ?? 'Unknown error'}`, 'error')
      }
    } catch {
      showStatus('Network error — agent not saved. Try again.', 'error')
    }
  }

  function showStatus(html: string, type: 'pending' | 'success' | 'error') {
    const el = document.getElementById('save-status') as HTMLElement
    el.innerHTML = html
    el.className = `save-status save-status-${type}`
    el.style.display = ''
  }
</script>
</body>
</html>
