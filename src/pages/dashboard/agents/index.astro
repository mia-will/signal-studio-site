---
export const prerender = false
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'
import DashboardLayout from '../../../layouts/DashboardLayout.astro'

// ── QUERIES ───────────────────────────────────────────────────────────────────

const [
  activeAgentsResult,
  attentionAgentsResult,
  qaLogFailResult,
  automationsResult,
  toBuildResult,
] = await Promise.all([

  supabase
    .from('agents_registry')
    .select('id, name, status, area, last_run, last_status, qa_status')
    .in('status', ['active', 'in_progress', 'to_build'])
    .limit(30),

  supabase
    .from('agents_registry')
    .select('id, name, status, qa_status, security_approved, last_status')
    .or('qa_status.eq.fail,last_status.eq.error,and(security_approved.eq.false,status.eq.active)'),

  supabase
    .from('agent_qa_log')
    .select('id, agent_id, result')
    .eq('result', 'fail')
    .limit(10),

  supabase
    .from('automations')
    .select('id, name, status, last_run, last_status')
    .order('last_run', { ascending: false, nullsFirst: false })
    .limit(20),

  supabase
    .from('agents_registry')
    .select('id, name, area, phase')
    .eq('status', 'to_build')
    .order('phase', { ascending: true, nullsFirst: false })
    .limit(10),
])

// ── DERIVED ───────────────────────────────────────────────────────────────────

const STATUS_ORDER: Record<string, number> = { active: 1, in_progress: 2, to_build: 3 }
const activeAgents = (activeAgentsResult.data ?? [])
  .sort((a, b) => (STATUS_ORDER[a.status] ?? 99) - (STATUS_ORDER[b.status] ?? 99))
  .slice(0, 10)

type AttentionItem = {
  label: string
  agentName: string
  agentId: string
  priority: 'high' | 'medium'
}
const seen = new Set<string>()
const attentionItems: AttentionItem[] = []

for (const a of attentionAgentsResult.data ?? []) {
  if (seen.has(a.id)) continue
  seen.add(a.id)
  if (a.last_status === 'error') {
    attentionItems.push({ label: 'Run error', agentName: a.name, agentId: a.id, priority: 'high' })
  } else if (a.qa_status === 'fail') {
    attentionItems.push({ label: 'QA failed', agentName: a.name, agentId: a.id, priority: 'high' })
  } else if (!a.security_approved && a.status === 'active') {
    attentionItems.push({ label: 'Security not approved', agentName: a.name, agentId: a.id, priority: 'medium' })
  }
}

const allKnownAgents = [...(activeAgentsResult.data ?? []), ...(attentionAgentsResult.data ?? [])]
for (const log of qaLogFailResult.data ?? []) {
  if (seen.has(log.agent_id)) continue
  const agent = allKnownAgents.find(a => a.id === log.agent_id)
  if (agent) {
    attentionItems.push({ label: 'QA log fail', agentName: agent.name, agentId: agent.id, priority: 'high' })
    seen.add(agent.id)
  }
}

const needsAttention = attentionItems.slice(0, 10)

const automations = (automationsResult.data ?? [])
  .filter(a => a.status === 'active' || a.last_run !== null)
  .slice(0, 10)

const toBuild = toBuildResult.data ?? []

// ── HELPERS ───────────────────────────────────────────────────────────────────

function formatRelative(ts: string | null): string {
  if (!ts) return 'Never'
  const diff = Date.now() - new Date(ts).getTime()
  const mins = Math.floor(diff / 60000)
  if (mins < 1) return 'Just now'
  if (mins < 60) return `${mins}m ago`
  const hours = Math.floor(mins / 60)
  if (hours < 24) return `${hours}h ago`
  return `${Math.floor(hours / 24)}d ago`
}

function areaLabel(a: string | null): string {
  return a ? a.replace(/_/g, ' ') : '—'
}
---

<DashboardLayout title="The Signal OS — Agents">
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:             #F5F4F1;
      --surface:        #FFFFFF;
      --text-primary:   #2F2F2F;
      --text-secondary: #505050;
      --text-muted:     #909090;
      --border:         rgba(47,47,47,0.08);
      --teal:           #3C8A7E;
      --orange:         #FF8A33;
      --green:          #7BBE9A;
      --red:            #C0392B;
      --dark:           #111111;
      --heading:        'DM Sans', sans-serif;
      --body:           'Inter', sans-serif;
    }

    html, body { height: 100vh; overflow: hidden; background: var(--bg); color: var(--text-primary); font-family: var(--body); }

    /* ── SHELL ─────────────────────────────────────────────────────────── */
    .os-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
      height: 100vh;
      overflow: hidden;
    }

    /* ── SIDEBAR ───────────────────────────────────────────────────────── */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 20px 16px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 20px 16px 4px;
    }
    .nav-item {
      display: block;
      font-size: 13px;
      color: var(--text-secondary);
      padding: 6px 16px;
      border-radius: 6px;
      margin: 1px 8px;
      text-decoration: none;
    }
    .nav-item.active { background: rgba(60,138,126,0.10); color: var(--teal); font-weight: 500; }
    .sidebar-footer {
      margin-top: auto;
      padding: 14px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--teal); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; flex-shrink: 0;
    }
    .footer-name { font-size: 12px; font-weight: 500; color: var(--text-primary); line-height: 1.2; }
    .footer-role { font-size: 11px; color: var(--text-muted); }

    /* ── MAIN AREA (flex row — houses dashboard + slide-over panel) ──── */
    .main-area {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* ── DASHBOARD CONTENT ─────────────────────────────────────────────── */
    .dashboard-content {
      flex: 1;
      min-width: 0;
      overflow-y: auto;
      padding: 28px 32px;
    }

    /* ── PAGE HEADER ───────────────────────────────────────────────────── */
    .page-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 24px;
      gap: 16px;
    }
    .page-header h1 {
      font-family: var(--heading);
      font-size: 28px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.1;
    }
    .page-header p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
    .header-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; padding-top: 4px; }
    .btn-dark {
      background: var(--dark);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 7px 14px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-dark:hover { background: #2a2a2a; }

    /* ── LAYOUT ROWS ───────────────────────────────────────────────────── */
    .row-2-3 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 16px; }
    .row-half { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }

    /* ── PANELS ────────────────────────────────────────────────────────── */
    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(47,47,47,0.06);
    }
    .panel-header {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .panel-header h2 {
      font-family: var(--heading);
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
    }
    .panel-header a {
      margin-left: auto;
      font-size: 12px;
      color: var(--teal);
      text-decoration: none;
    }
    .badge-count {
      background: var(--orange);
      color: white;
      font-size: 11px;
      font-weight: 600;
      border-radius: 20px;
      padding: 1px 7px;
    }
    .empty-state {
      padding: 20px 16px;
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
    }

    /* ── TABLES ────────────────────────────────────────────────────────── */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th {
      text-align: left;
      padding: 8px 16px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    tbody td {
      padding: 9px 16px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr.clickable { cursor: pointer; }
    tbody tr.clickable:hover td { background: rgba(60,138,126,0.03); }

    /* ── STATUS BADGES ─────────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      border-radius: 20px;
      padding: 2px 9px;
      font-size: 11px;
      font-weight: 500;
    }
    .status-active, .status-live       { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .status-in_progress                { background: rgba(157,220,227,0.18); color: #1F7A82; }
    .status-to_build, .status-draft    { background: rgba(47,47,47,0.08);    color: var(--text-secondary); }
    .status-error, .status-blocked     { background: rgba(192,57,43,0.12);   color: var(--red); }
    .status-success                    { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .status-not_tested, .status-pending { background: rgba(255,138,51,0.12); color: #E07020; }
    .status-pass, .status-in_progress-qa { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .status-fail                       { background: rgba(192,57,43,0.12);   color: var(--red); }

    /* ── ATTENTION LABEL ───────────────────────────────────────────────── */
    .attention-label {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 500;
      border-radius: 4px;
      padding: 2px 7px;
    }
    .attention-high   { background: rgba(192,57,43,0.10); color: var(--red); }
    .attention-medium { background: rgba(255,138,51,0.10); color: #E07020; }

    /* ── LINK STYLE ────────────────────────────────────────────────────── */
    .link-teal { color: var(--teal); text-decoration: none; font-size: 12px; }
    .link-teal:hover { text-decoration: underline; }

    /* ── BUILDER SLIDE-OVER PANEL ──────────────────────────────────────── */
    .builder-panel {
      width: 0;
      flex-shrink: 0;
      overflow: hidden;
      background: var(--bg);
      border-left: 0 solid var(--border);
      display: flex;
      flex-direction: column;
      transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .main-area.panel-open .builder-panel {
      width: 50%;
      border-left-width: 1px;
    }

    .builder-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      width: 100%;
      min-width: 0;
    }

    .builder-header {
      padding: 16px 20px 14px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .builder-header h2 {
      font-family: var(--heading);
      font-size: 15px;
      font-weight: 700;
      color: var(--text-primary);
      flex: 1;
    }
    .builder-header p {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 1px;
    }
    .btn-close-panel {
      background: none;
      border: none;
      font-size: 16px;
      color: var(--text-muted);
      cursor: pointer;
      padding: 2px 4px;
      line-height: 1;
      flex-shrink: 0;
    }
    .btn-close-panel:hover { color: var(--text-primary); }

    .builder-messages {
      flex: 1;
      overflow-y: auto;
      padding: 18px 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .bld-msg {
      max-width: 88%;
      font-size: 13px;
      line-height: 1.55;
      border-radius: 10px;
      padding: 10px 14px;
    }
    .bld-msg-assistant {
      background: var(--surface);
      color: var(--text-primary);
      border: 1px solid var(--border);
      align-self: flex-start;
      border-bottom-left-radius: 3px;
    }
    .bld-msg-user {
      background: var(--dark);
      color: #FFFFFF;
      align-self: flex-end;
      border-bottom-right-radius: 3px;
    }
    .bld-msg-system {
      background: rgba(60,138,126,0.08);
      color: var(--teal);
      border: 1px solid rgba(60,138,126,0.15);
      align-self: center;
      font-size: 12px;
      border-radius: 6px;
    }

    .builder-footer {
      padding: 12px 20px;
      border-top: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }
    .builder-input-row {
      display: flex;
      gap: 8px;
      align-items: flex-end;
    }
    .builder-input {
      flex: 1;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 13px;
      font-family: var(--body);
      color: var(--text-primary);
      background: var(--bg);
      resize: none;
      min-height: 38px;
      max-height: 100px;
      line-height: 1.4;
    }
    .builder-input:focus { outline: none; border-color: var(--teal); }
    .builder-input:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-send {
      background: var(--dark);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 9px 16px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      height: 38px;
      flex-shrink: 0;
    }
    .btn-send:hover { background: #2a2a2a; }
    .btn-send:disabled { opacity: 0.4; cursor: not-allowed; }
    .save-status {
      margin-top: 8px;
      font-size: 12px;
      padding: 7px 11px;
      border-radius: 6px;
    }
    .save-status-pending { background: rgba(47,47,47,0.06); color: var(--text-muted); }
    .save-status-success { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .save-status-error   { background: rgba(192,57,43,0.10); color: var(--red); }
  </style>

  <!-- ── MAIN AREA ─────────────────────────────────────────────────────── -->
  <div id="main-area" class="main-area">

    <!-- Dashboard content -->
    <div class="dashboard-content">

      <header class="page-header">
        <div>
          <h1>Agents</h1>
          <p>Active agents, attention items, automations, and build queue.</p>
        </div>
        <div class="header-actions">
          <button id="btn-new-agent" class="btn-dark">+ New Agent</button>
        </div>
      </header>

      <!-- ── ROW 1: Active agents + Needs attention ─────────────────── -->
      <div class="row-2-3">

        <!-- Active Agents -->
        <div class="panel">
          <div class="panel-header">
            <h2>Active Agents</h2>
            {activeAgents.length > 0 && <span class="badge-count">{activeAgents.length}</span>}
          </div>
          {activeAgents.length === 0 ? (
            <div class="empty-state">No active, in-progress, or to-build agents found.</div>
          ) : (
            <table>
              <thead>
                <tr>
                  <th>Agent</th>
                  <th>Status</th>
                  <th>Area</th>
                  <th>Last run</th>
                  <th>Last status</th>
                  <th>QA</th>
                  <th style="width:48px;"></th>
                </tr>
              </thead>
              <tbody>
                {activeAgents.map((agent: any) => (
                  <tr
                    class="clickable"
                    onclick={`location.href='/dashboard/agents/${agent.id}'`}
                  >
                    <td style="font-weight:500; color:var(--text-primary);">{agent.name}</td>
                    <td>
                      <span class={`badge status-${(agent.status ?? '').replace(/[^a-z_]/g, '')}`}>
                        {agent.status?.replace(/_/g, ' ') ?? '—'}
                      </span>
                    </td>
                    <td style="font-size:12px; color:var(--text-muted);">{areaLabel(agent.area)}</td>
                    <td style="font-size:12px; color:var(--text-muted);">{formatRelative(agent.last_run)}</td>
                    <td>
                      {agent.last_status ? (
                        <span class={`badge status-${agent.last_status.replace(/[^a-z_]/g, '')}`}>
                          {agent.last_status}
                        </span>
                      ) : <span style="color:var(--text-muted); font-size:12px;">—</span>}
                    </td>
                    <td>
                      {agent.qa_status ? (
                        <span class={`badge status-${agent.qa_status.replace(/[^a-z_]/g, '')}`}>
                          {agent.qa_status.replace(/_/g, ' ')}
                        </span>
                      ) : <span style="color:var(--text-muted); font-size:12px;">—</span>}
                    </td>
                    <td>
                      <a href={`/dashboard/agents/${agent.id}`} class="link-teal">Open →</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        <!-- Needs Attention -->
        <div class="panel">
          <div class="panel-header">
            <h2>Needs Attention</h2>
            {needsAttention.length > 0 && <span class="badge-count">{needsAttention.length}</span>}
          </div>
          {needsAttention.length === 0 ? (
            <div class="empty-state">Nothing flagged — all clear.</div>
          ) : (
            <table>
              <thead>
                <tr>
                  <th>Issue</th>
                  <th>Agent</th>
                  <th style="width:48px;"></th>
                </tr>
              </thead>
              <tbody>
                {needsAttention.map((item: any) => (
                  <tr class="clickable" onclick={`location.href='/dashboard/agents/${item.agentId}'`}>
                    <td>
                      <span class={`attention-label attention-${item.priority}`}>
                        {item.label}
                      </span>
                    </td>
                    <td style="font-size:12px; color:var(--text-secondary);">{item.agentName}</td>
                    <td>
                      <a href={`/dashboard/agents/${item.agentId}`} class="link-teal">View →</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

      </div>

      <!-- ── ROW 2: Automations firing + Next to build ──────────────── -->
      <div class="row-half">

        <!-- Automations Firing -->
        <div class="panel">
          <div class="panel-header">
            <h2>Automations Firing</h2>
            {automations.length > 0 && <span class="badge-count">{automations.length}</span>}
          </div>
          {automations.length === 0 ? (
            <div class="empty-state">No active automations or recent runs.</div>
          ) : (
            <table>
              <thead>
                <tr>
                  <th>Automation</th>
                  <th>Last run</th>
                  <th>Last status</th>
                </tr>
              </thead>
              <tbody>
                {automations.map((a: any) => (
                  <tr>
                    <td style="font-weight:500; color:var(--text-primary);">{a.name}</td>
                    <td style="font-size:12px; color:var(--text-muted);">{formatRelative(a.last_run)}</td>
                    <td>
                      {a.last_status ? (
                        <span class={`badge status-${a.last_status.replace(/[^a-z_]/g, '')}`}>
                          {a.last_status}
                        </span>
                      ) : <span style="color:var(--text-muted); font-size:12px;">—</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        <!-- Next to Build -->
        <div class="panel">
          <div class="panel-header">
            <h2>Next to Build</h2>
            {toBuild.length > 0 && <span class="badge-count">{toBuild.length}</span>}
          </div>
          {toBuild.length === 0 ? (
            <div class="empty-state">No agents in the build queue.</div>
          ) : (
            <table>
              <thead>
                <tr>
                  <th>Agent</th>
                  <th>Phase</th>
                  <th>Area</th>
                </tr>
              </thead>
              <tbody>
                {toBuild.map((agent: any) => (
                  <tr class="clickable" onclick={`location.href='/dashboard/agents/${agent.id}'`}>
                    <td style="font-weight:500; color:var(--text-primary);">{agent.name}</td>
                    <td style="font-size:12px; color:var(--text-muted);">{agent.phase ?? '—'}</td>
                    <td style="font-size:12px; color:var(--text-muted);">{areaLabel(agent.area)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

      </div>

    </div>
    <!-- /dashboard-content -->

    <!-- ── BUILDER SLIDE-OVER ─────────────────────────────────────────── -->
    <div id="builder-panel" class="builder-panel" aria-hidden="true">
      <div class="builder-inner">

        <div class="builder-header">
          <div style="flex:1; min-width:0;">
            <h2>Agent Builder</h2>
            <p>Claude asks questions one at a time. Answer each in turn — it will confirm before saving.</p>
          </div>
          <button id="btn-close-panel" class="btn-close-panel" aria-label="Close panel">✕</button>
        </div>

        <div class="builder-messages" id="builder-messages"></div>

        <div class="builder-footer">
          <div class="builder-input-row">
            <textarea
              id="builder-input"
              class="builder-input"
              rows="2"
              placeholder="Type your answer… (Enter to send)"
            ></textarea>
            <button id="builder-send" class="btn-send">Send</button>
          </div>
          <div id="builder-save-status" class="save-status" style="display:none;"></div>
        </div>

      </div>
    </div>

  </div>
  <!-- /main-area -->


<script>
  // ── PANEL TOGGLE ────────────────────────────────────────────────────────────
  const mainArea    = document.getElementById('main-area')!
  const builderPanel = document.getElementById('builder-panel')!
  const btnOpen     = document.getElementById('btn-new-agent')!
  const btnClose    = document.getElementById('btn-close-panel')!

  let chatInitialised = false

  btnOpen.addEventListener('click', () => {
    mainArea.classList.add('panel-open')
    builderPanel.setAttribute('aria-hidden', 'false')
    if (!chatInitialised) {
      initBuilderChat()
      chatInitialised = true
    }
    document.getElementById('builder-input')?.focus()
  })

  btnClose.addEventListener('click', () => {
    mainArea.classList.remove('panel-open')
    builderPanel.setAttribute('aria-hidden', 'true')
  })

  // ── AGENT BUILDER CHAT ──────────────────────────────────────────────────────
  const FIRST_MSG = "Let's register a new agent. What's the name?"
  const messages: { role: string; content: string }[] = [
    { role: 'assistant', content: FIRST_MSG },
  ]
  let isStreaming = false

  function initBuilderChat() {
    appendMsg('assistant', FIRST_MSG)
  }

  document.getElementById('builder-send')!.addEventListener('click', sendMsg)
  document.getElementById('builder-input')!.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      sendMsg()
    }
  })
  document.getElementById('builder-input')!.addEventListener('input', function(this: HTMLTextAreaElement) {
    this.style.height = 'auto'
    this.style.height = `${Math.min(this.scrollHeight, 100)}px`
  })

  async function sendMsg() {
    if (isStreaming) return
    const input   = document.getElementById('builder-input')   as HTMLTextAreaElement
    const sendBtn = document.getElementById('builder-send')    as HTMLButtonElement
    const text = input.value.trim()
    if (!text) return

    input.value = ''
    input.style.height = 'auto'
    input.disabled  = true
    sendBtn.disabled = true
    isStreaming = true

    messages.push({ role: 'user', content: text })
    appendMsg('user', text)
    const bubble = appendMsg('assistant', '')

    try {
      const res = await fetch('/api/agents/builder-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      })

      if (!res.ok || !res.body) {
        bubble.textContent = 'Error — could not reach the builder.'
        return
      }

      const reader  = res.body.getReader()
      const decoder = new TextDecoder()
      let fullText  = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        for (const line of decoder.decode(value, { stream: true }).split('\n')) {
          if (!line.startsWith('data: ')) continue
          const data = line.slice(6).trim()
          if (!data || data === '[DONE]') continue
          try {
            const parsed = JSON.parse(data)
            if (parsed.type === 'content_block_delta' && parsed.delta?.text) {
              fullText += parsed.delta.text as string
              bubble.innerHTML = renderText(fullText)
              scrollMsgs()
            }
          } catch { /* ignore malformed SSE lines */ }
        }
      }

      messages.push({ role: 'assistant', content: fullText })

      const match = fullText.match(/<AGENT_READY>([\s\S]*?)<\/AGENT_READY>/)
      if (match) {
        bubble.innerHTML = renderText(fullText)
        try {
          await createAgent(JSON.parse(match[1].trim()))
        } catch {
          showSaveStatus('Could not parse agent data — ask Claude to try again.', 'error')
        }
      }
    } finally {
      isStreaming = false
      input.disabled  = false
      sendBtn.disabled = false
      input.focus()
    }
  }

  function renderText(raw: string): string {
    return raw
      .replace(/<AGENT_READY>[\s\S]*?<\/AGENT_READY>/g, '')
      .replace(/<AGENT_READY>[\s\S]*$/, '')
      .trim()
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>')
  }

  function appendMsg(role: string, text: string): HTMLElement {
    const container = document.getElementById('builder-messages')!
    const el = document.createElement('div')
    el.className = `bld-msg bld-msg-${role}`
    if (text) el.innerHTML = renderText(text)
    container.appendChild(el)
    scrollMsgs()
    return el
  }

  function scrollMsgs() {
    const c = document.getElementById('builder-messages')!
    c.scrollTop = c.scrollHeight
  }

  async function createAgent(agentData: Record<string, unknown>) {
    showSaveStatus('Saving agent…', 'pending')
    try {
      const res = await fetch('/api/agents/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(agentData),
      })
      const result = await res.json() as { success?: boolean; agent_id?: string; error?: string }
      if (res.ok && result.success && result.agent_id) {
        showSaveStatus(
          `Agent registered — <a href="/dashboard/agents/${result.agent_id}" style="color:#2D5A35;font-weight:600;">View agent →</a>`,
          'success',
        )
        const sys = document.createElement('div')
        sys.className = 'bld-msg bld-msg-system'
        sys.textContent = 'Agent saved to agents_registry with status: to_build.'
        document.getElementById('builder-messages')!.appendChild(sys)
        scrollMsgs()
      } else {
        showSaveStatus(`Error: ${result.error ?? 'Unknown error'}`, 'error')
      }
    } catch {
      showSaveStatus('Network error — agent not saved. Try again.', 'error')
    }
  }

  function showSaveStatus(html: string, type: 'pending' | 'success' | 'error') {
    const el = document.getElementById('builder-save-status') as HTMLElement
    el.innerHTML = html
    el.className = `save-status save-status-${type}`
    el.style.display = ''
  }
</script>
</DashboardLayout>
