---
export const prerender = false
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'
import DashboardLayout from '../../../layouts/DashboardLayout.astro'

const [allAgentsResult, workflowsResult, runLogsResult] = await Promise.all([
  supabase
    .from('agents_registry')
    .select('id, name, area, status, last_run, security_approved')
    .order('name', { ascending: true }),

  supabase
    .from('workflow_registry')
    .select('name, purpose, status, area, version_label, verification_status, last_reviewed')
    .order('name', { ascending: true }),

  supabase
    .from('agent_run_logs')
    .select('id, agent_key, run_started_at, run_completed_at, status, action_summary')
    .order('run_started_at', { ascending: false, nullsFirst: false })
    .limit(50),
])

const allAgents = allAgentsResult.data ?? []
const totalCount = allAgents.length
const activeCount = allAgents.filter((a: any) => a.status === 'active').length
const inProgressCount = allAgents.filter((a: any) => a.status === 'in_progress').length
const workflows = workflowsResult.data ?? []
const runLogs = runLogsResult.data ?? []

const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000

type NeedsItem = { name: string; id: string; label: string }
const needsAttention: NeedsItem[] = []
const needsSeen = new Set<string>()

for (const a of allAgents as any[]) {
  if (a.status !== 'active') continue
  const stale = !a.last_run || (Date.now() - new Date(a.last_run).getTime() > SEVEN_DAYS_MS)
  if (stale && !needsSeen.has(a.id + '-stale')) {
    needsSeen.add(a.id + '-stale')
    needsAttention.push({ name: a.name, id: a.id, label: 'check needed' })
  }
  if (a.security_approved === false && !needsSeen.has(a.id + '-sec')) {
    needsSeen.add(a.id + '-sec')
    needsAttention.push({ name: a.name, id: a.id, label: 'security not approved' })
  }
}

function formatRelative(ts: string | null): string {
  if (!ts) return 'Never'
  const diff = Date.now() - new Date(ts).getTime()
  const mins = Math.floor(diff / 60000)
  if (mins < 1) return 'Just now'
  if (mins < 60) return `${mins}m ago`
  const hours = Math.floor(mins / 60)
  if (hours < 24) return `${hours}h ago`
  return `${Math.floor(hours / 24)}d ago`
}

function formatDate(ts: string | null): string {
  if (!ts) return '—'
  return new Intl.DateTimeFormat('en-AU', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(new Date(ts))
}

function healthFlag(a: { status: string; last_run: string | null }): { label: string; cls: string } {
  if (a.status === 'active') {
    return a.last_run && Date.now() - new Date(a.last_run).getTime() <= SEVEN_DAYS_MS
      ? { label: 'Running', cls: 'hf-success' }
      : { label: 'Check needed', cls: 'hf-warning' }
  }
  if (a.status === 'in_progress') return { label: 'In progress', cls: 'hf-info' }
  if (a.status === 'draft') return { label: 'Draft', cls: 'hf-muted' }
  return { label: 'Not started', cls: 'hf-muted' }
}
---

<DashboardLayout title="The Signal OS — Agents">
<style>
  .page-content-wrapper { transition: width 0.25s ease; width: 100%; }
  .page-content-wrapper.chat-open { width: calc(100% - 380px); }

  #main-area { display: flex; height: 100vh; overflow: hidden; }

  .dashboard-content { flex: 1; min-width: 0; overflow-y: auto; padding: 18px; }

  /* ── Page header ──────────────────────────────────────────── */
  .page-header {
    padding: 20px 24px 12px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }
  .page-header h1 {
    font-family: 'DM Sans', sans-serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  .page-header p { font-size: 13px; color: var(--color-text-secondary); margin-top: 4px; }
  .header-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; padding-top: 4px; }
  .btn-dark {
    background: var(--color-text-primary);
    color: #fff;
    border: none;
    border-radius: var(--border-radius-md);
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  /* ── Stat cards ───────────────────────────────────────────── */
  .stat-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    padding: 0 24px 14px;
    align-items: start;
  }
  .stat-card {
    background: var(--color-background-secondary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 1rem 1.25rem;
    cursor: pointer;
    align-self: start;
    transition: border-color 0.15s;
  }
  .stat-card:hover { border-color: var(--color-border-secondary); }
  .stat-card.card-highlight { border: 1.5px solid var(--color-border-info); }
  .stat-number { font-size: 1.75rem; font-weight: 500; color: var(--color-text-primary); line-height: 1; }
  .stat-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin-top: 6px;
  }

  /* ── Tab row ──────────────────────────────────────────────── */
  .tab-row {
    display: flex;
    align-items: flex-end;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    padding: 0 24px;
    margin-bottom: 14px;
  }
  .tab-btn {
    padding: 8px 16px 9px;
    font-size: 13px;
    color: var(--color-text-secondary);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    margin-bottom: -0.5px;
  }
  .tab-btn.active {
    font-weight: 500;
    color: var(--color-text-primary);
    border-bottom: 2px solid var(--color-text-primary);
  }

  /* ── Content grid ─────────────────────────────────────────── */
  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 185px;
    gap: 10px;
    align-items: start;
    padding: 0 24px 18px;
  }
  .table-column {
    min-width: 0;
  }

  /* ── Tab panels ───────────────────────────────────────────── */
  .tab-panel { display: none; }
  .tab-panel.active-panel { display: block; }

  /* ── Secondary controls ───────────────────────────────────── */
  .tab-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .search-input {
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    padding: 5px 10px;
    font-size: 12px;
    color: var(--color-text-primary);
    background: var(--color-background-primary);
    width: 180px;
    outline: none;
    font-family: 'Inter', sans-serif;
  }
  .search-input:focus { border-color: var(--color-border-secondary); }
  .pill-group { display: flex; gap: 4px; }
  .status-pill {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    background: none;
    color: var(--color-text-secondary);
    border: 0.5px solid var(--color-border-tertiary);
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
  }
  .status-pill.active { border: 0.5px solid var(--color-border-secondary); color: var(--color-text-primary); }
  .columns-pill-wrap { margin-left: auto; position: relative; }
  .columns-pill {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    background: none;
    color: var(--color-text-secondary);
    border: 0.5px solid var(--color-border-tertiary);
    font-family: 'Inter', sans-serif;
  }
  .col-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    padding: 4px 0;
    z-index: 10;
    min-width: 140px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .col-dropdown.open { display: block; }
  .col-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--color-text-secondary);
    cursor: pointer;
    white-space: nowrap;
    user-select: none;
  }
  .col-option:hover { background: var(--color-background-secondary); }
  .col-option input[type=checkbox] { cursor: pointer; }

  /* ── Registry table ───────────────────────────────────────── */
  .agents-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }
  .agents-table thead th {
    text-align: left;
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    white-space: nowrap;
  }
  .agents-table thead th.sortable { cursor: pointer; }
  .agents-table thead th.sortable:hover { color: var(--color-text-secondary); }
  .agents-table tbody td {
    padding: 9px 12px;
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    vertical-align: middle;
  }
  .agents-table tbody tr:last-child td { border-bottom: none; }
  .agents-table tbody tr { cursor: pointer; }
  .agents-table tbody tr:hover td { background: var(--color-background-secondary); }
  .agents-table tbody tr.row-muted td { color: var(--color-text-tertiary); opacity: 0.6; }
  .show-more-row td {
    text-align: center;
    padding: 10px 12px !important;
    color: var(--color-text-secondary);
    font-size: 12px;
    border-bottom: none !important;
    opacity: 1 !important;
  }
  .show-more-btn {
    background: none; border: none; cursor: pointer;
    color: var(--color-text-secondary); font-size: 12px; padding: 0; text-decoration: underline;
    font-family: 'Inter', sans-serif;
  }
  .view-all-btn {
    background: none; border: none; cursor: pointer;
    color: var(--color-text-tertiary); font-size: 12px; margin-left: 12px;
    font-family: 'Inter', sans-serif; text-decoration: underline;
  }
  .hf-success { color: var(--color-text-success); font-size: 12px; font-weight: 500; }
  .hf-warning { color: var(--color-text-warning); font-size: 12px; font-weight: 500; }
  .hf-info    { color: var(--color-text-info);    font-size: 12px; font-weight: 500; }
  .hf-muted   { color: var(--color-text-tertiary); font-size: 12px; }
  .hidden-col { display: none !important; }

  /* ── Placeholder text ─────────────────────────────────────── */
  .placeholder-text { padding: 24px 0; font-size: 13px; color: var(--color-text-tertiary); font-style: italic; }

  /* ── Run logs table ───────────────────────────────────────── */
  .logs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }
  .logs-table thead th {
    text-align: left;
    padding: 7px 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    white-space: nowrap;
  }
  .logs-table tbody td {
    padding: 8px 12px;
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    vertical-align: middle;
  }
  .logs-table tbody tr:last-child td { border-bottom: none; }

  /* ── Needs attention rail ─────────────────────────────────── */
  .needs-rail {
    align-self: start;
    width: 185px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 12px 14px;
  }
  .rail-heading {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-warning);
    margin-bottom: 10px;
  }
  .rail-item {
    padding: 6px 0;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    color: var(--color-text-secondary);
    font-size: 12px;
    line-height: 1.4;
  }
  .rail-item:last-child { border-bottom: none; }
  .rail-item a { color: var(--color-text-secondary); text-decoration: none; }
  .rail-item a:hover { text-decoration: underline; }
  .rail-healthy { color: var(--color-text-tertiary); font-style: italic; font-size: 12px; }

  /* ── Builder slide-over ───────────────────────────────────── */
  .builder-panel {
    width: 0;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-background-secondary);
    border-left: 0 solid var(--color-border-tertiary);
    display: flex;
    flex-direction: column;
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #main-area.panel-open .builder-panel { width: 50%; border-left-width: 1px; }
  .builder-inner { display: flex; flex-direction: column; height: 100%; width: 100%; min-width: 0; }
  .builder-header {
    padding: 16px 20px 14px;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    background: var(--color-background-primary);
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
  }
  .builder-header h2 { font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; color: var(--color-text-primary); flex: 1; }
  .builder-header p { font-size: 11px; color: var(--color-text-tertiary); margin-top: 1px; }
  .btn-close-panel { background: none; border: none; font-size: 16px; color: var(--color-text-tertiary); cursor: pointer; padding: 2px 4px; line-height: 1; }
  .btn-close-panel:hover { color: var(--color-text-primary); }
  .builder-messages { flex: 1; overflow-y: auto; padding: 18px 20px; display: flex; flex-direction: column; gap: 12px; }
  .bld-msg { max-width: 88%; font-size: 13px; line-height: 1.55; border-radius: 10px; padding: 10px 14px; }
  .bld-msg-assistant { background: var(--color-background-primary); color: var(--color-text-primary); border: 0.5px solid var(--color-border-tertiary); align-self: flex-start; border-bottom-left-radius: 3px; }
  .bld-msg-user { background: var(--color-text-primary); color: #fff; align-self: flex-end; border-bottom-right-radius: 3px; }
  .bld-msg-system { background: var(--color-background-info); color: var(--color-text-info); border: 0.5px solid var(--color-border-info); align-self: center; font-size: 12px; border-radius: 6px; }
  .builder-footer { padding: 12px 20px; border-top: 0.5px solid var(--color-border-tertiary); background: var(--color-background-primary); flex-shrink: 0; }
  .builder-input-row { display: flex; gap: 8px; align-items: flex-end; }
  .builder-input { flex: 1; border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-md); padding: 9px 12px; font-size: 13px; color: var(--color-text-primary); background: var(--color-background-secondary); resize: none; min-height: 38px; max-height: 100px; line-height: 1.4; font-family: 'Inter', sans-serif; }
  .builder-input:focus { outline: none; border-color: var(--color-border-secondary); }
  .builder-input:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-send { background: var(--color-text-primary); color: white; border: none; border-radius: var(--border-radius-md); padding: 9px 16px; font-size: 13px; font-weight: 600; cursor: pointer; height: 38px; flex-shrink: 0; }
  .btn-send:disabled { opacity: 0.4; cursor: not-allowed; }
  .save-status { margin-top: 8px; font-size: 12px; padding: 7px 11px; border-radius: 6px; }
  .save-status-pending { background: var(--color-background-tertiary); color: var(--color-text-tertiary); }
  .save-status-success { background: var(--color-background-success); color: var(--color-text-success); }
  .save-status-error   { background: var(--color-background-danger);  color: var(--color-text-danger); }
</style>

<div class="page-content-wrapper" id="page-content-wrapper">
<div id="main-area" class="main-area">

  <div class="dashboard-content">

    <!-- ── Page header ─────────────────────────────────────────── -->
    <header class="page-header">
      <div>
        <h1>Agents</h1>
        <p>All registered agents, workflows, and run logs across Signal OS.</p>
      </div>
      <div class="header-actions">
        <button id="btn-new-agent" class="btn-dark">+ New Agent</button>
      </div>
    </header>

    <!-- ── Stat cards ──────────────────────────────────────────── -->
    <div class="stat-cards">
      <div class="stat-card card-highlight" data-card-tab="registry" data-card-filter="all" role="button" tabindex="0">
        <div class="stat-number">{totalCount}</div>
        <div class="stat-label">Registry</div>
      </div>
      <div class="stat-card" data-card-tab="registry" data-card-filter="active" role="button" tabindex="0">
        <div class="stat-number">{activeCount}</div>
        <div class="stat-label">Active</div>
      </div>
      <div class="stat-card" data-card-tab="registry" data-card-filter="in_progress" role="button" tabindex="0">
        <div class="stat-number">{inProgressCount}</div>
        <div class="stat-label">In progress</div>
      </div>
    </div>

    <!-- ── Tab row ─────────────────────────────────────────────── -->
    <div class="tab-row">
      <button class="tab-btn active" data-tab="registry">Registry · {totalCount}</button>
      <button class="tab-btn" data-tab="workflows">Workflows</button>
      <button class="tab-btn" data-tab="runlogs">Run logs</button>
    </div>

    <!-- ── Content grid (table col + needs-attention rail) ─────── -->
    <div class="content-grid">

      <div class="table-column">

        <!-- Registry panel -->
        <div id="tab-registry" class="tab-panel active-panel">
          <div class="tab-controls">
            <input id="agent-search" class="search-input" type="text" placeholder="Search agents…" autocomplete="off" />
            <div class="pill-group">
              <button class="status-pill active" data-status="all">All</button>
              <button class="status-pill" data-status="active">Active</button>
              <button class="status-pill" data-status="draft">Draft</button>
              <button class="status-pill" data-status="in_progress">In progress</button>
            </div>
            <div class="columns-pill-wrap">
              <button id="columns-toggle" class="columns-pill">Columns ▾</button>
              <div id="col-dropdown" class="col-dropdown">
                <label class="col-option"><input type="checkbox" data-col="area" checked /> Area</label>
                <label class="col-option"><input type="checkbox" data-col="status" checked /> Status</label>
                <label class="col-option"><input type="checkbox" data-col="last_run" checked /> Last run</label>
                <label class="col-option"><input type="checkbox" data-col="health" checked /> Health</label>
              </div>
            </div>
          </div>

          <table class="agents-table" id="registry-table">
            <thead>
              <tr>
                <th class="sortable" data-sort="name">Name ↕</th>
                <th data-col="area">Area</th>
                <th data-col="status">Status</th>
                <th class="sortable" data-sort="last_run" data-col="last_run">Last run ↕</th>
                <th data-col="health">Health</th>
              </tr>
            </thead>
            <tbody id="registry-tbody">
              {(allAgents as any[]).map((agent) => {
                const hf = healthFlag(agent)
                const isMuted = agent.status === 'draft' || agent.status === 'to_build'
                const lastRunMs = agent.last_run ? new Date(agent.last_run).getTime() : 0
                return (
                  <tr
                    class={isMuted ? 'row-muted' : ''}
                    data-name={String(agent.name ?? '').toLowerCase()}
                    data-status={agent.status ?? ''}
                    data-lastrun={String(lastRunMs)}
                    onclick={`location.href='/dashboard/agents/${agent.id}'`}
                  >
                    <td style="font-weight:500; color:var(--color-text-primary);">{agent.name ?? '—'}</td>
                    <td data-col="area">{agent.area ?? '—'}</td>
                    <td data-col="status">{agent.status ?? '—'}</td>
                    <td data-col="last_run">{formatRelative(agent.last_run)}</td>
                    <td data-col="health"><span class={hf.cls}>{hf.label}</span></td>
                  </tr>
                )
              })}
            </tbody>
            <tfoot>
              <tr class="show-more-row" id="show-more-row" style="display:none;">
                <td colspan="5">
                  <button class="show-more-btn" id="show-more-btn">Show more</button>
                  <button class="view-all-btn" id="view-all-btn">View all →</button>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- Workflows panel -->
        <div id="tab-workflows" class="tab-panel">
          <table class="agents-table" id="workflows-table">
            <thead>
              <tr>
                <th class="sortable" data-workflow-sort="name">Name ↕</th>
                <th class="sortable" data-workflow-sort="purpose">Purpose ↕</th>
                <th class="sortable" data-workflow-sort="status">Status ↕</th>
                <th class="sortable" data-workflow-sort="area">Area ↕</th>
                <th class="sortable" data-workflow-sort="version_label">Version ↕</th>
                <th class="sortable" data-workflow-sort="verification_status">Verification ↕</th>
                <th class="sortable" data-workflow-sort="last_reviewed">Last reviewed ↕</th>
              </tr>
            </thead>
            <tbody id="workflows-tbody">
              {(workflows as any[]).map((workflow) => {
                const isMuted = workflow.status !== 'active'
                const lastReviewedMs = workflow.last_reviewed ? new Date(workflow.last_reviewed).getTime() : 0
                return (
                  <tr
                    class={isMuted ? 'row-muted' : ''}
                    data-name={String(workflow.name ?? '').toLowerCase()}
                    data-purpose={String(workflow.purpose ?? '').toLowerCase()}
                    data-status={String(workflow.status ?? '').toLowerCase()}
                    data-area={String(workflow.area ?? '').toLowerCase()}
                    data-version_label={String(workflow.version_label ?? '').toLowerCase()}
                    data-verification_status={String(workflow.verification_status ?? '').toLowerCase()}
                    data-last_reviewed={String(lastReviewedMs)}
                  >
                    <td style="font-weight:500; color:var(--color-text-primary);">{workflow.name ?? '—'}</td>
                    <td style="max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{workflow.purpose ?? '—'}</td>
                    <td>{workflow.status ?? '—'}</td>
                    <td>{workflow.area ?? '—'}</td>
                    <td>{workflow.version_label ?? '—'}</td>
                    <td>{workflow.verification_status ?? '—'}</td>
                    <td>{formatDate(workflow.last_reviewed)}</td>
                  </tr>
                )
              })}
            </tbody>
            <tfoot>
              <tr class="show-more-row" id="workflow-show-more-row" style="display:none;">
                <td colspan="7">
                  <button class="show-more-btn" id="workflow-show-more-btn">Show more</button>
                  <button class="view-all-btn" id="workflow-view-all-btn">View all →</button>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- Run logs panel -->
        <div id="tab-runlogs" class="tab-panel">
          {runLogs.length === 0 ? (
            <p class="placeholder-text">Run logs coming soon — agent execution history will appear here.</p>
          ) : (
            <table class="logs-table">
              <thead>
                <tr>
                  <th>Agent key</th>
                  <th>Status</th>
                  <th>Started</th>
                  <th>Completed</th>
                  <th>Summary</th>
                </tr>
              </thead>
              <tbody>
                {(runLogs as any[]).map((log) => (
                  <tr>
                    <td style="font-weight:500; color:var(--color-text-primary);">{log.agent_key ?? '—'}</td>
                    <td>{log.status ?? '—'}</td>
                    <td>{formatRelative(log.run_started_at)}</td>
                    <td>{formatRelative(log.run_completed_at)}</td>
                    <td style="color:var(--color-text-tertiary); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{log.action_summary ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

      </div>

      <!-- ── Needs attention rail ───────────────────────────────── -->
      <aside class="needs-rail">
        <div class="rail-heading">Needs attention</div>
        {needsAttention.length === 0 ? (
          <div class="rail-healthy">All agents healthy</div>
        ) : (
          (needsAttention as NeedsItem[]).map((item) => (
            <div class="rail-item">
              <a href={`/dashboard/agents/${item.id}`}>{item.name}</a>
              <span style="color:var(--color-text-tertiary);"> — {item.label}</span>
            </div>
          ))
        )}
      </aside>

    </div>
    <!-- /content-grid -->

  </div>
  <!-- /dashboard-content -->

  <!-- ── Builder slide-over ──────────────────────────────────── -->
  <div id="builder-panel" class="builder-panel" aria-hidden="true">
    <div class="builder-inner">
      <div class="builder-header">
        <div style="flex:1; min-width:0;">
          <h2>Agent Builder</h2>
          <p>Claude asks questions one at a time. Answer each in turn — it will confirm before saving.</p>
        </div>
        <button id="btn-close-panel" class="btn-close-panel" aria-label="Close panel">✕</button>
      </div>
      <div class="builder-messages" id="builder-messages"></div>
      <div class="builder-footer">
        <div class="builder-input-row">
          <textarea
            id="builder-input"
            class="builder-input"
            rows="2"
            placeholder="Type your answer… (Enter to send)"
          ></textarea>
          <button id="builder-send" class="btn-send">Send</button>
        </div>
        <div id="builder-save-status" class="save-status" style="display:none;"></div>
      </div>
    </div>
  </div>

</div>
<!-- /main-area -->
</div>
<!-- /page-content-wrapper -->

<script>
// ── TABS ─────────────────────────────────────────────────────────────────────
const tabBtns = Array.from(document.querySelectorAll('.tab-btn')) as HTMLButtonElement[]
const tabPanels = Array.from(document.querySelectorAll('.tab-panel')) as HTMLElement[]

function activateTab(tabId: string) {
  tabBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tabId))
  tabPanels.forEach(p => p.classList.toggle('active-panel', p.id === `tab-${tabId}`))
}

tabBtns.forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab!)))

// ── STAT CARD CLICKS ─────────────────────────────────────────────────────────
document.querySelectorAll('.stat-card[data-card-tab]').forEach(card => {
  const el = card as HTMLElement
  function handleCardClick() {
    activateTab(el.dataset.cardTab!)
    const filter = el.dataset.cardFilter ?? 'all'
    setStatusFilter(filter)
  }
  el.addEventListener('click', handleCardClick)
  el.addEventListener('keydown', (e: Event) => {
    if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') handleCardClick()
  })
})

// ── REGISTRY TABLE FILTERS ────────────────────────────────────────────────────
let currentSearch = ''
let currentStatus = 'all'
let showAll = false
let sortKey = ''
let sortDir = 1

function getDataRows(): HTMLTableRowElement[] {
  return Array.from(document.querySelectorAll('#registry-tbody tr')) as HTMLTableRowElement[]
}

function setStatusFilter(status: string) {
  currentStatus = status
  document.querySelectorAll('.status-pill').forEach(p => {
    const el = p as HTMLElement
    el.classList.toggle('active', el.dataset.status === status)
  })
  showAll = false
  applyFilters()
}

function applyFilters() {
  const rows = getDataRows()
  rows.forEach(row => {
    const nameMatch = !currentSearch || (row.dataset.name ?? '').includes(currentSearch)
    const statusMatch = currentStatus === 'all' || row.dataset.status === currentStatus
    row.dataset.filtered = nameMatch && statusMatch ? '0' : '1'
  })
  applyRowCap()
}

function applyRowCap() {
  const rows = getDataRows()
  const visible = rows.filter(r => r.dataset.filtered !== '1')
  const hidden = rows.filter(r => r.dataset.filtered === '1')

  hidden.forEach(r => { r.style.display = 'none' })

  const showMoreRow = document.getElementById('show-more-row')!
  const showMoreBtn = document.getElementById('show-more-btn')!

  if (showAll || visible.length <= 10) {
    visible.forEach(r => { r.style.display = '' })
    showMoreRow.style.display = 'none'
    return
  }

  visible.forEach((r, i) => { r.style.display = i < 10 ? '' : 'none' })
  showMoreBtn.textContent = `Show ${visible.length - 10} more`
  showMoreRow.style.display = ''
}

// Search
document.getElementById('agent-search')!.addEventListener('input', (e) => {
  currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim()
  showAll = false
  applyFilters()
})

// Status pills
document.querySelectorAll('.status-pill').forEach(pill => {
  pill.addEventListener('click', () => setStatusFilter((pill as HTMLElement).dataset.status!))
})

// Show more
document.getElementById('show-more-btn')!.addEventListener('click', () => {
  showAll = true
  applyRowCap()
})

// View all
document.getElementById('view-all-btn')!.addEventListener('click', () => {
  currentSearch = '';
  (document.getElementById('agent-search') as HTMLInputElement).value = ''
  setStatusFilter('all')
  showAll = true
  applyFilters()
})

// ── SORT ─────────────────────────────────────────────────────────────────────
document.querySelectorAll('.sortable[data-sort]').forEach(th => {
  th.addEventListener('click', () => {
    const key = (th as HTMLElement).dataset.sort!
    if (sortKey === key) {
      sortDir = sortDir === 1 ? -1 : 1
    } else {
      sortKey = key
      sortDir = 1
    }
    sortRows()
  })
})

function sortRows() {
  const tbody = document.getElementById('registry-tbody')!
  const rows = getDataRows()
  rows.sort((a, b) => {
    let va: string | number
    let vb: string | number
    if (sortKey === 'name') {
      va = a.dataset.name ?? ''
      vb = b.dataset.name ?? ''
    } else {
      // last_run — treat 0 (never) as always last
      const na = parseInt(a.dataset.lastrun ?? '0', 10)
      const nb = parseInt(b.dataset.lastrun ?? '0', 10)
      if (na === 0 && nb === 0) return 0
      if (na === 0) return 1
      if (nb === 0) return -1
      va = na
      vb = nb
    }
    if (va < vb) return -sortDir
    if (va > vb) return sortDir
    return 0
  })
  rows.forEach(r => tbody.appendChild(r))
  applyRowCap()
}

// ── COLUMN TOGGLE ─────────────────────────────────────────────────────────────
const COL_KEY = 'agents-columns'

function getColState(): Record<string, boolean> {
  try {
    const stored = localStorage.getItem(COL_KEY)
    if (stored) return JSON.parse(stored) as Record<string, boolean>
  } catch { /* ignore */ }
  return { area: true, status: true, last_run: true, health: true }
}

function saveColState(state: Record<string, boolean>) {
  try { localStorage.setItem(COL_KEY, JSON.stringify(state)) } catch { /* ignore */ }
}

function applyColVisibility(state: Record<string, boolean>) {
  Object.entries(state).forEach(([col, visible]) => {
    document.querySelectorAll(`[data-col="${col}"]`).forEach(el => {
      el.classList.toggle('hidden-col', !visible)
    })
  })
}

function initColumns() {
  const state = getColState()
  document.querySelectorAll('#col-dropdown input[type=checkbox]').forEach(cb => {
    const el = cb as HTMLInputElement
    const col = el.dataset.col!
    el.checked = state[col] !== false
  })
  applyColVisibility(state)
}

document.querySelectorAll('#col-dropdown input[type=checkbox]').forEach(cb => {
  cb.addEventListener('change', () => {
    const state = getColState()
    const el = cb as HTMLInputElement
    state[el.dataset.col!] = el.checked
    saveColState(state)
    applyColVisibility(state)
  })
})

const colToggle = document.getElementById('columns-toggle')!
const colDropdown = document.getElementById('col-dropdown')!

colToggle.addEventListener('click', (e) => {
  e.stopPropagation()
  colDropdown.classList.toggle('open')
})

document.addEventListener('click', () => colDropdown.classList.remove('open'))
colDropdown.addEventListener('click', (e) => e.stopPropagation())

initColumns()
applyFilters()

// ── WORKFLOWS TABLE ─────────────────────────────────────────────────────────
let workflowShowAll = false
let workflowSortKey = ''
let workflowSortDir = 1

function getWorkflowRows(): HTMLTableRowElement[] {
  return Array.from(document.querySelectorAll('#workflows-tbody tr')) as HTMLTableRowElement[]
}

function applyWorkflowRowCap() {
  const rows = getWorkflowRows()
  const showMoreRow = document.getElementById('workflow-show-more-row')!
  const showMoreBtn = document.getElementById('workflow-show-more-btn')!

  if (workflowShowAll || rows.length <= 10) {
    rows.forEach(r => { r.style.display = '' })
    showMoreRow.style.display = 'none'
    return
  }

  rows.forEach((r, i) => { r.style.display = i < 10 ? '' : 'none' })
  showMoreBtn.textContent = `Show ${rows.length - 10} more`
  showMoreRow.style.display = ''
}

document.querySelectorAll('[data-workflow-sort]').forEach(th => {
  th.addEventListener('click', () => {
    const key = (th as HTMLElement).dataset.workflowSort!
    if (workflowSortKey === key) {
      workflowSortDir = workflowSortDir === 1 ? -1 : 1
    } else {
      workflowSortKey = key
      workflowSortDir = 1
    }
    sortWorkflowRows()
  })
})

function sortWorkflowRows() {
  const tbody = document.getElementById('workflows-tbody')!
  const rows = getWorkflowRows()
  rows.sort((a, b) => {
    let va: string | number = a.dataset[workflowSortKey] ?? ''
    let vb: string | number = b.dataset[workflowSortKey] ?? ''
    if (workflowSortKey === 'last_reviewed') {
      va = parseInt(String(va), 10)
      vb = parseInt(String(vb), 10)
      if (va === 0 && vb === 0) return 0
      if (va === 0) return 1
      if (vb === 0) return -1
    }
    if (va < vb) return -workflowSortDir
    if (va > vb) return workflowSortDir
    return 0
  })
  rows.forEach(r => tbody.appendChild(r))
  applyWorkflowRowCap()
}

document.getElementById('workflow-show-more-btn')!.addEventListener('click', () => {
  workflowShowAll = true
  applyWorkflowRowCap()
})

document.getElementById('workflow-view-all-btn')!.addEventListener('click', () => {
  workflowShowAll = true
  applyWorkflowRowCap()
})

applyWorkflowRowCap()

// ── BUILDER PANEL TOGGLE ──────────────────────────────────────────────────────
const mainArea = document.getElementById('main-area')!
const builderPanel = document.getElementById('builder-panel')!
const btnOpen = document.getElementById('btn-new-agent')!
const btnClose = document.getElementById('btn-close-panel')!
let chatInitialised = false

btnOpen.addEventListener('click', () => {
  mainArea.classList.add('panel-open')
  builderPanel.setAttribute('aria-hidden', 'false')
  if (!chatInitialised) { initBuilderChat(); chatInitialised = true }
  ;(document.getElementById('builder-input') as HTMLTextAreaElement)?.focus()
})

btnClose.addEventListener('click', () => {
  mainArea.classList.remove('panel-open')
  builderPanel.setAttribute('aria-hidden', 'true')
})

// ── AGENT BUILDER CHAT ────────────────────────────────────────────────────────
const FIRST_MSG = "Let's register a new agent. What's the name?"
const messages: { role: string; content: string }[] = [
  { role: 'assistant', content: FIRST_MSG },
]
let isStreaming = false

function initBuilderChat() { appendMsg('assistant', FIRST_MSG) }

document.getElementById('builder-send')!.addEventListener('click', sendMsg)
document.getElementById('builder-input')!.addEventListener('keydown', (e: Event) => {
  const ke = e as KeyboardEvent
  if (ke.key === 'Enter' && !ke.shiftKey) { ke.preventDefault(); sendMsg() }
})
;(document.getElementById('builder-input') as HTMLTextAreaElement).addEventListener('input', function() {
  this.style.height = 'auto'
  this.style.height = `${Math.min(this.scrollHeight, 100)}px`
})

async function sendMsg() {
  if (isStreaming) return
  const input = document.getElementById('builder-input') as HTMLTextAreaElement
  const sendBtn = document.getElementById('builder-send') as HTMLButtonElement
  const text = input.value.trim()
  if (!text) return

  input.value = ''; input.style.height = 'auto'
  input.disabled = true; sendBtn.disabled = true; isStreaming = true
  messages.push({ role: 'user', content: text })
  appendMsg('user', text)
  const bubble = appendMsg('assistant', '')

  try {
    const res = await fetch('/api/agents/builder-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages }),
    })
    if (!res.ok || !res.body) { bubble.textContent = 'Error — could not reach the builder.'; return }

    const reader = res.body.getReader()
    const decoder = new TextDecoder()
    let fullText = ''

    while (true) {
      const { done, value } = await reader.read()
      if (done) break
      for (const line of decoder.decode(value, { stream: true }).split('\n')) {
        if (!line.startsWith('data: ')) continue
        const data = line.slice(6).trim()
        if (!data || data === '[DONE]') continue
        try {
          const parsed = JSON.parse(data)
          if (parsed.type === 'content_block_delta' && parsed.delta?.text) {
            fullText += parsed.delta.text as string
            bubble.innerHTML = renderText(fullText)
            scrollMsgs()
          }
        } catch { /* ignore malformed SSE */ }
      }
    }

    messages.push({ role: 'assistant', content: fullText })
    const match = fullText.match(/<AGENT_READY>([\s\S]*?)<\/AGENT_READY>/)
    if (match) {
      bubble.innerHTML = renderText(fullText)
      try { await createAgent(JSON.parse(match[1].trim())) }
      catch { showSaveStatus('Could not parse agent data — ask Claude to try again.', 'error') }
    }
  } finally {
    isStreaming = false; input.disabled = false; sendBtn.disabled = false; input.focus()
  }
}

function renderText(raw: string): string {
  return raw
    .replace(/<AGENT_READY>[\s\S]*?<\/AGENT_READY>/g, '')
    .replace(/<AGENT_READY>[\s\S]*$/, '')
    .trim()
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>')
}

function appendMsg(role: string, text: string): HTMLElement {
  const container = document.getElementById('builder-messages')!
  const el = document.createElement('div')
  el.className = `bld-msg bld-msg-${role}`
  if (text) el.innerHTML = renderText(text)
  container.appendChild(el)
  scrollMsgs()
  return el
}

function scrollMsgs() {
  const c = document.getElementById('builder-messages')!
  c.scrollTop = c.scrollHeight
}

async function createAgent(agentData: Record<string, unknown>) {
  showSaveStatus('Saving agent…', 'pending')
  try {
    const res = await fetch('/api/agents/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(agentData),
    })
    const result = await res.json() as { success?: boolean; agent_id?: string; error?: string }
    if (res.ok && result.success && result.agent_id) {
      showSaveStatus(
        `Agent registered — <a href="/dashboard/agents/${result.agent_id}" style="color:var(--color-text-success);font-weight:600;">View agent →</a>`,
        'success',
      )
      const sys = document.createElement('div')
      sys.className = 'bld-msg bld-msg-system'
      sys.textContent = 'Agent saved to agents_registry with status: to_build.'
      document.getElementById('builder-messages')!.appendChild(sys)
      scrollMsgs()
    } else {
      showSaveStatus(`Error: ${result.error ?? 'Unknown error'}`, 'error')
    }
  } catch { showSaveStatus('Network error — agent not saved. Try again.', 'error') }
}

function showSaveStatus(html: string, type: 'pending' | 'success' | 'error') {
  const el = document.getElementById('builder-save-status') as HTMLElement
  el.innerHTML = html
  el.className = `save-status save-status-${type}`
  el.style.display = ''
}
</script>
</DashboardLayout>
