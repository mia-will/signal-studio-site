---
export const prerender = false

import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const [agentsResult, logsResult] = await Promise.all([
  supabase.from('v_agent_dashboard').select('*'),
  supabase.from('agent_run_logs')
    .select('*')
    .order('run_started_at', { ascending: false })
    .limit(20),
])

const agents = agentsResult.data ?? []
const logs = logsResult.data ?? []

const liveCount = agents.filter((a: any) => a.status === 'live').length
const activeCount = agents.filter((a: any) => a.status === 'active').length
const draftCount = agents.filter((a: any) => a.status === 'draft').length
const inTestingCount = agents.filter((a: any) => a.qa_status === 'not_tested' && a.status !== 'draft').length
const needsReviewCount = agents.filter((a: any) => a.live_without_qa || a.live_without_security).length
const blockedCount = agents.filter((a: any) => a.last_status === 'error' || a.last_status === 'blocked').length

const today = new Date()
const runsToday = logs.filter((l: any) => {
  const d = new Date(l.run_started_at)
  return d.toDateString() === today.toDateString()
}).length

const needsApproval = logs.filter((l: any) => l.human_approval_required && !l.human_approved)
const liveWithoutQA = agents.filter((a: any) => a.live_without_qa)
const liveWithoutSecurity = agents.filter((a: any) => a.live_without_security)

const needsMichelleItems: { label: string; priority: string }[] = [
  ...liveWithoutQA.map((a: any) => ({ label: `QA sign-off needed: ${a.name}`, priority: 'medium' })),
  ...liveWithoutSecurity.map((a: any) => ({ label: `Security approval needed: ${a.name}`, priority: 'medium' })),
  ...needsApproval.map((l: any) => ({ label: l.action_summary ?? 'Agent run awaiting approval', priority: 'high' })),
]

const focusAgent: any = agents.find((a: any) => a.status === 'live' || a.status === 'active') ?? null

const toBuild = agents.filter((a: any) => a.status === 'draft')
const inTesting = agents.filter((a: any) => a.qa_status === 'not_tested' && a.status !== 'draft')
const safeActive = agents.filter((a: any) => a.qa_status === 'pass' || a.status === 'live')

const liveAgents = agents.filter((a: any) => a.status === 'live' || a.status === 'active').slice(0, 5)

const runningAgents = agents.filter((a: any) => a.status === 'live' || a.status === 'active')
const draftAgents = agents.filter((a: any) => a.status !== 'live' && a.status !== 'active')

function formatTime(ts: string | null): string {
  if (!ts) return '—'
  return new Date(ts).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' })
}

function formatRelative(ts: string | null): string {
  if (!ts) return 'Never'
  const diff = Date.now() - new Date(ts).getTime()
  const mins = Math.floor(diff / 60000)
  if (mins < 1) return 'Just now'
  if (mins < 60) return `${mins}m ago`
  const hours = Math.floor(mins / 60)
  if (hours < 24) return `${hours}h ago`
  return `${Math.floor(hours / 24)}d ago`
}

function joinArr(arr: string[] | null): string {
  if (!arr || arr.length === 0) return '—'
  return arr.join(', ')
}

function trunc(str: string | null, len: number): string {
  if (!str) return '—'
  return str.length > len ? str.slice(0, len) + '…' : str
}

function statusClass(s: string | null): string {
  if (!s) return 'status-draft'
  return `status-${s.replace(/[^a-z_]/g, '')}`
}

function resultBadge(log: any): { cls: string; label: string } {
  if (log.human_approval_required && !log.human_approved) return { cls: 'status-pending', label: 'Review' }
  if (log.status === 'success') return { cls: 'status-success', label: 'Success' }
  if (log.status === 'error') return { cls: 'status-error', label: 'Error' }
  return { cls: 'status-pending', label: 'Pending' }
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Signal OS — Agents</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F4F1;
      --surface: #FFFFFF;
      --text-primary: #2F2F2F;
      --text-secondary: #505050;
      --text-muted: #909090;
      --border: rgba(47,47,47,0.08);
      --teal: #3C8A7E;
      --orange: #FF8A33;
      --green: #7BBE9A;
      --aqua: #9DDCE3;
      --violet: #6F4BA2;
      --red: #C0392B;
      --dark: #111111;
      --heading: 'DM Sans', sans-serif;
      --body: 'Inter', sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--body);
    }

    .os-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
      min-height: 100vh;
    }

    /* ── SIDEBAR ─────────────────────────────── */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 20px 16px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border);
    }

    .nav-section-label {
      font-family: var(--body);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 20px 16px 4px;
    }

    .nav-item {
      display: block;
      font-family: var(--body);
      font-size: 13px;
      font-weight: 400;
      color: var(--text-secondary);
      padding: 6px 16px;
      border-radius: 6px;
      margin: 1px 8px;
      text-decoration: none;
      cursor: default;
    }

    .nav-item.active {
      background: rgba(60,138,126,0.10);
      color: var(--teal);
      font-weight: 500;
    }

    .sidebar-footer {
      margin-top: auto;
      padding: 14px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--teal);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 600;
      flex-shrink: 0;
    }

    .footer-name {
      font-family: var(--body);
      font-size: 12px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.2;
    }

    .footer-role {
      font-family: var(--body);
      font-size: 11px;
      color: var(--text-muted);
    }

    /* ── MAIN CONTENT ────────────────────────── */
    .content {
      padding: 28px 32px;
      overflow-x: hidden;
    }

    .page-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 24px;
      gap: 16px;
    }

    .page-header h1 {
      font-family: var(--heading);
      font-size: 32px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.1;
    }

    .page-header p {
      font-family: var(--body);
      font-size: 14px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      padding-top: 4px;
    }

    .search-mock {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 7px 12px;
      font-family: var(--body);
      font-size: 13px;
      color: var(--text-muted);
      background: var(--surface);
      width: 180px;
    }

    .btn-icon {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-secondary);
      padding: 7px 10px;
      font-size: 14px;
      cursor: default;
    }

    .btn-dark {
      background: var(--dark);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 7px 14px;
      font-family: var(--heading);
      font-size: 13px;
      font-weight: 600;
      cursor: default;
    }

    /* ── STAT CARDS ──────────────────────────── */
    .stat-cards {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 1px 3px rgba(47,47,47,0.06);
    }

    .stat-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 12px;
      font-size: 15px;
    }

    .stat-value {
      font-family: var(--heading);
      font-size: 28px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1;
    }

    .stat-label {
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* ── LAYOUT ──────────────────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 55fr 45fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }

    .panel-header {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .panel-header h2 {
      font-family: var(--heading);
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .panel-header a {
      margin-left: auto;
      font-family: var(--body);
      font-size: 12px;
      color: var(--teal);
      text-decoration: none;
    }

    .badge-count {
      background: var(--orange);
      color: white;
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      border-radius: 20px;
      padding: 1px 7px;
    }

    /* ── STATUS BADGES ───────────────────────── */
    .status-badge {
      display: inline-block;
      border-radius: 20px;
      padding: 2px 10px;
      font-size: 12px;
      font-weight: 500;
      font-family: var(--body);
    }

    .status-live, .status-active   { background: rgba(123,190,154,0.15); color: #2D5A35; }
    .status-draft                  { background: rgba(47,47,47,0.08);    color: var(--text-secondary); }
    .status-not_tested             { background: rgba(255,138,51,0.12);  color: #E07020; }
    .status-pass                   { background: rgba(45,90,53,0.12);    color: #2D5A35; }
    .status-error, .status-blocked { background: rgba(192,57,43,0.12);  color: var(--red); }
    .status-pending                { background: rgba(255,138,51,0.12);  color: #E07020; }
    .status-success                { background: rgba(123,190,154,0.15); color: #2D5A35; }

    /* ── NEEDS MICHELLE ──────────────────────── */
    .needs-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      border-bottom: 1px solid var(--border);
    }

    .needs-item:last-child { border-bottom: none; }

    .needs-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .needs-label {
      font-family: var(--body);
      font-size: 13px;
      color: var(--text-secondary);
      flex: 1;
    }

    .priority-high   { font-family: var(--body); font-size: 12px; font-weight: 500; color: var(--orange); }
    .priority-medium { font-family: var(--body); font-size: 12px; font-weight: 500; color: var(--text-muted); }

    .empty-state {
      padding: 24px 20px;
      font-family: var(--body);
      font-size: 13px;
      color: var(--text-muted);
      font-style: italic;
    }

    /* ── AGENT DETAIL ────────────────────────── */
    .agent-detail-col {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .agent-detail-body { padding: 16px 20px; }

    .agent-name-row {
      display: flex;
      align-items: center;
      gap: 7px;
      margin-bottom: 3px;
    }

    .agent-name-row span {
      font-family: var(--heading);
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .agent-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .agent-why {
      font-family: var(--body);
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 14px;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      gap: 12px;
    }

    .detail-row:last-child { border-bottom: none; }

    .detail-key {
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-muted);
      flex-shrink: 0;
      width: 90px;
    }

    .detail-val {
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-secondary);
      text-align: right;
    }

    /* ── READINESS BOARD ─────────────────────── */
    .readiness-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      padding: 16px 20px;
    }

    .readiness-col-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .agent-chip {
      display: flex;
      align-items: center;
      gap: 5px;
      font-family: var(--heading);
      font-size: 12px;
      color: var(--text-secondary);
      padding: 3px 0;
    }

    .chip-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── TABLES ──────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--body);
      font-size: 13px;
    }

    thead th {
      text-align: left;
      padding: 10px 16px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }

    tbody td {
      padding: 10px 16px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    tbody tr:last-child td { border-bottom: none; }

    .tick { color: #2D5A35; }
    .dash { color: var(--text-muted); }
  </style>
</head>
<body>
<div class="os-shell">

  <!-- ── SIDEBAR ────────────────────────────── -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <span>✦</span>
      <span>THE SIGNAL OS</span>
    </div>

    <div style="padding: 8px 0;">
      <span class="nav-item">🏠 Snapshot</span>

      <div class="nav-section-label">Relationships</div>
      <span class="nav-item">CRM</span>
      <span class="nav-item">Growth</span>
      <span class="nav-item">Clients</span>

      <div class="nav-section-label">Delivery</div>
      <span class="nav-item">Projects</span>
      <span class="nav-item">Pathways</span>
      <span class="nav-item">Events</span>

      <div class="nav-section-label">Content</div>
      <span class="nav-item">Content</span>
      <span class="nav-item">Campaigns</span>
      <span class="nav-item">EDMs</span>

      <div class="nav-section-label">Operations</div>
      <span class="nav-item">Finance</span>
      <a href="/dashboard/governance" class="nav-item">Governance</a>
      <span class="nav-item">Automations</span>
      <span class="nav-item active">Agents</span>
    </div>

    <div class="sidebar-footer">
      <div class="avatar">M</div>
      <div>
        <div class="footer-name">Michelle</div>
        <div class="footer-role">System Operator</div>
      </div>
    </div>
  </nav>

  <!-- ── MAIN ──────────────────────────────── -->
  <main class="content">

    <!-- Page header -->
    <header class="page-header">
      <div>
        <h1>Agents Dashboard</h1>
        <p>Visibility over agents, permissions, activity, risk and approvals</p>
      </div>
      <div class="header-actions">
        <div class="search-mock">Search agents… ⌘K</div>
        <button class="btn-icon" disabled>⚙</button>
        <button class="btn-dark" disabled>+ New Agent</button>
      </div>
    </header>

    <!-- Stat cards -->
    <section class="stat-cards">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(123,190,154,0.12);">
          <span style="color: #7BBE9A;">●</span>
        </div>
        <div class="stat-value">{liveCount + activeCount}</div>
        <div class="stat-label">Active Agents</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(157,220,227,0.12);">
          <span style="color: #9DDCE3;">●</span>
        </div>
        <div class="stat-value">{inTestingCount}</div>
        <div class="stat-label">In Testing</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(60,138,126,0.12);">
          <span style="color: #3C8A7E;">●</span>
        </div>
        <div class="stat-value">{draftCount}</div>
        <div class="stat-label">Draft Agents</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255,138,51,0.12);">
          <span style="color: #FF8A33;">●</span>
        </div>
        <div class="stat-value">{needsReviewCount}</div>
        <div class="stat-label">Needs Review</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(111,75,162,0.12);">
          <span style="color: #6F4BA2;">●</span>
        </div>
        <div class="stat-value">{runsToday}</div>
        <div class="stat-label">Runs Today</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(192,57,43,0.12);">
          <span style="color: #C0392B;">●</span>
        </div>
        <div class="stat-value">{blockedCount}</div>
        <div class="stat-label">Blocked</div>
      </div>
    </section>

    <!-- Agent Registry -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="panel-header">
        <h2>Agent Registry</h2>
        <a href="#" style="margin-left: auto;">View all →</a>
      </div>
      {agents.length === 0 ? (
        <div class="empty-state">No agents found</div>
      ) : (
        <div style="max-height: 320px; overflow-y: auto;">
          <table>
            <thead>
              <tr>
                <th>Agent</th>
                <th>Status</th>
                <th>Last run</th>
                <th style="width: 32px;"></th>
              </tr>
            </thead>
            <tbody>
              {runningAgents.map((agent: any) => (
                <tr style="cursor: pointer;" onclick={`location.href='/dashboard/agents/${agent.id}'`}>
                  <td style="font-weight: 500;">{agent.name}</td>
                  <td><span class={`status-badge ${statusClass(agent.status)}`}>{agent.status}</span></td>
                  <td style="color: var(--text-muted);">{formatRelative(agent.last_run)}</td>
                  <td style="color: var(--text-muted); text-align: center;">›</td>
                </tr>
              ))}
              {draftAgents.length > 0 && (
                <tr>
                  <td colspan="4" style="padding: 6px 16px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #909090; background: #F5F4F1; border-top: 1px solid rgba(47,47,47,0.08);">
                    Draft · {draftAgents.length}
                  </td>
                </tr>
              )}
              {draftAgents.map((agent: any) => (
                <tr style="opacity: 0.65; cursor: pointer;" onclick={`location.href='/dashboard/agents/${agent.id}'`}>
                  <td style="font-weight: 500;">{agent.name}</td>
                  <td><span class={`status-badge ${statusClass(agent.status)}`}>{agent.status}</span></td>
                  <td style="color: var(--text-muted);">{formatRelative(agent.last_run)}</td>
                  <td style="color: var(--text-muted); text-align: center;">›</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Row 1: Needs Michelle + Agent Detail col -->
    <div class="two-col">

      <!-- Needs Michelle -->
      <div class="panel">
        <div class="panel-header">
          <h2>Needs Michelle</h2>
          {needsMichelleItems.length > 0 && (
            <span class="badge-count">{needsMichelleItems.length}</span>
          )}
        </div>
        {needsMichelleItems.length === 0 ? (
          <div class="empty-state">No items awaiting approval</div>
        ) : (
          needsMichelleItems.map((item) => (
            <div class="needs-item">
              <div
                class="needs-dot"
                style={`background: ${item.priority === 'high' ? '#FF8A33' : '#909090'};`}
              ></div>
              <span class="needs-label">{item.label}</span>
              <span class={item.priority === 'high' ? 'priority-high' : 'priority-medium'}>
                {item.priority === 'high' ? 'High priority' : 'Medium priority'}
              </span>
              <span style="color: var(--text-muted); font-size: 14px;">›</span>
            </div>
          ))
        )}
      </div>

      <!-- Agent Detail col (stacked) -->
      <div class="agent-detail-col">

        <!-- Agent Detail -->
        <div class="panel">
          <div class="panel-header">
            <h2>Agent Detail</h2>
          </div>
          {focusAgent ? (
            <div class="agent-detail-body">
              <div class="agent-name-row">
                <div
                  class="agent-dot"
                  style={`background: ${focusAgent.status === 'live' || focusAgent.status === 'active' ? '#7BBE9A' : '#C8C8C8'};`}
                ></div>
                <span>{focusAgent.name}</span>
              </div>
              <div class="agent-why">{focusAgent.why ?? '—'}</div>

              <div class="detail-row">
                <span class="detail-key">Status</span>
                <span class={`status-badge ${statusClass(focusAgent.status)}`}>{focusAgent.status}</span>
              </div>
              <div class="detail-row">
                <span class="detail-key">Risk level</span>
                <span class="detail-val" style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {focusAgent.can_it_break ? (
                    <span class="status-badge status-not_tested">{trunc(focusAgent.can_it_break, 30)}</span>
                  ) : '—'}
                </span>
              </div>
              <div class="detail-row">
                <span class="detail-key">Last run</span>
                <span class="detail-val">{formatRelative(focusAgent.last_run)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-key">Last result</span>
                <span class="detail-val">
                  {focusAgent.last_status ? (
                    <span class={`status-badge ${statusClass(focusAgent.last_status)}`}>{focusAgent.last_status}</span>
                  ) : '—'}
                </span>
              </div>
              <div class="detail-row">
                <span class="detail-key">📋 Reads from</span>
                <span class="detail-val">{joinArr(focusAgent.reads_from)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-key">✏️ Writes to</span>
                <span class="detail-val">{joinArr(focusAgent.writes_to)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-key">🌐 External</span>
                <span class="detail-val">{joinArr(focusAgent.calls_external)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-key">👤 Notes</span>
                <span class="detail-val">{trunc(focusAgent.notes, 60)}</span>
              </div>
            </div>
          ) : (
            <div class="empty-state">No live or active agents</div>
          )}
        </div>

        <!-- Readiness Board -->
        <div class="panel">
          <div class="panel-header">
            <h2>Agent Readiness Board</h2>
          </div>
          <div class="readiness-grid">
            <div>
              <div class="readiness-col-label">To Build</div>
              {toBuild.length === 0 ? (
                <div class="agent-chip" style="color: var(--text-muted); font-style: italic;">None</div>
              ) : toBuild.map((a: any) => (
                <div class="agent-chip">
                  <div class="chip-dot" style="background: #C8C8C8;"></div>
                  {a.name}
                </div>
              ))}
            </div>
            <div>
              <div class="readiness-col-label">In Testing</div>
              {inTesting.length === 0 ? (
                <div class="agent-chip" style="color: var(--text-muted); font-style: italic;">None</div>
              ) : inTesting.map((a: any) => (
                <div class="agent-chip">
                  <div class="chip-dot" style="background: #9DDCE3;"></div>
                  {a.name}
                </div>
              ))}
            </div>
            <div>
              <div class="readiness-col-label">Safe / Active</div>
              {safeActive.length === 0 ? (
                <div class="agent-chip" style="color: var(--text-muted); font-style: italic;">None</div>
              ) : safeActive.map((a: any) => (
                <div class="agent-chip">
                  <div class="chip-dot" style="background: #7BBE9A;"></div>
                  {a.name}
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Row 2: Recent Activity + Permissions -->
    <div class="two-col">

      <!-- Recent Agent Activity -->
      <div class="panel">
        <div class="panel-header">
          <h2>Recent Agent Activity</h2>
          <a href="#">View all →</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>Agent</th>
              <th>Action</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody>
            {logs.length === 0 ? (
              <tr>
                <td colspan="4" style="color: var(--text-muted); font-style: italic; text-align: center;">
                  No agent activity recorded yet
                </td>
              </tr>
            ) : logs.map((log: any) => {
              const badge = resultBadge(log)
              return (
                <tr>
                  <td style="color: var(--text-muted); white-space: nowrap;">{formatTime(log.run_started_at)}</td>
                  <td style="font-weight: 500;">{log.agent_key}</td>
                  <td style="color: var(--text-muted);">{trunc(log.action_summary, 40)}</td>
                  <td><span class={`status-badge ${badge.cls}`}>{badge.label}</span></td>
                </tr>
              )
            })}
          </tbody>
        </table>
      </div>

      <!-- Permissions + Safety -->
      <div class="panel">
        <div class="panel-header">
          <h2>Permissions + Safety</h2>
          <a href="#">View all →</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Agent</th>
              <th>Can Read</th>
              <th>Can Write</th>
              <th>Approval Req.</th>
            </tr>
          </thead>
          <tbody>
            {liveAgents.length === 0 ? (
              <tr>
                <td colspan="4" style="color: var(--text-muted); font-style: italic; text-align: center;">
                  No live agents
                </td>
              </tr>
            ) : liveAgents.map((agent: any) => (
              <tr>
                <td style="font-weight: 500;">{agent.name}</td>
                <td>
                  {agent.reads_from && agent.reads_from.length > 0
                    ? <span class="tick">✓</span>
                    : <span class="dash">—</span>
                  }
                </td>
                <td>
                  {agent.writes_to && agent.writes_to.length > 0
                    ? <span class="tick">✓</span>
                    : <span class="dash">—</span>
                  }
                </td>
                <td>
                  <span class={agent.security_approved ? 'status-badge status-pass' : 'status-badge status-not_tested'}>
                    {agent.security_approved ? 'No' : 'Yes'}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

    </div>

  </main>
</div>
</body>
</html>
