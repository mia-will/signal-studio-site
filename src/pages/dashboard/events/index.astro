---
export const prerender = false
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin'
import DashboardLayout from '../../../layouts/DashboardLayout.astro'

const { data: rawEvents } = await supabase
  .from('v_events_dashboard')
  .select('*')

const events = rawEvents ?? []

const planned  = events.filter((e: any) => e.event_timing === 'draft')
const upcoming = events
  .filter((e: any) => e.event_timing === 'upcoming')
  .sort((a: any, b: any) => new Date(a.start_at).getTime() - new Date(b.start_at).getTime())
const past = events
  .filter((e: any) => e.event_timing === 'past')
  .sort((a: any, b: any) => new Date(b.start_at).getTime() - new Date(a.start_at).getTime())

const totalCount    = events.length
const upcomingCount = upcoming.length
const plannedCount  = planned.length
const pastVisible   = past
const pastHidden    = []

function fmtDate(ts: string | null, tz?: string | null): string {
  if (!ts) return 'No date set'
  return new Date(ts).toLocaleDateString('en-AU', {
    day: 'numeric', month: 'short', year: 'numeric',
    timeZone: tz ?? 'Australia/Sydney',
  })
}

const trackOrder = ['builders', 'appliers']
const trackValues = Array.from(new Set(events.map((e: any) => e.audience_track).filter(Boolean).map((v: string) => v.toLowerCase())))
  .sort((a: string, b: string) => {
    const ai = trackOrder.indexOf(a)
    const bi = trackOrder.indexOf(b)
    if (ai !== -1 || bi !== -1) return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi)
    return a.localeCompare(b)
  })

const formatValues = Array.from(new Set(events.map((e: any) => formatFilterValue(e)).filter(Boolean)))
const canShowOutOfArea = formatValues.includes('out-of-area')
const orderedFormats = ['online', 'in-person', ...(canShowOutOfArea ? ['out-of-area'] : [])].filter(v => formatValues.includes(v))

function labelFromValue(value: string): string {
  return value.split(/[-_\s]+/).filter(Boolean).map(part => part.charAt(0).toUpperCase() + part.slice(1)).join(' ')
}

function formatFilterValue(e: any): string {
  const format = String(e.event_format ?? '').toLowerCase()
  const location = String(e.location_name ?? '').toLowerCase()
  if (format.includes('online') || location === 'online' || location.includes('zoom')) return 'online'
  if (format.includes('online')) return 'online'
  if (e.location_name || format.includes('person') || format.includes('venue')) {
    if (location && !location.includes('byron') && !location.includes('sae')) return 'out-of-area'
    return 'in-person'
  }
  return ''
}

function trackBadgeHtml(track: string | null): string {
  if (!track) return ''
  const map: Record<string, [string, string, string]> = {
    builders: ['#E6F1FB', '#185FA5', 'Builders'],
    appliers:  ['#E1F5EE', '#0F6E56', 'Appliers'],
    both:      ['#EEEDFE', '#3C3489', 'Both'],
  }
  const entry = map[track.toLowerCase()]
  if (!entry) return ''
  return `<span class="track-badge" style="background:${entry[0]};color:${entry[1]}">${entry[2]}</span>`
}

function dotColor(e: any): string {
  if (e.event_timing === 'draft') return 'rgba(47,47,47,0.22)'
  if (e.event_timing === 'upcoming') {
    return (e.loops_connected && e.stripe_connected && Number(e.open_actions) === 0)
      ? '#7BBE9A' : '#E07020'
  }
  return Number(e.open_actions) > 0 ? '#E07020' : '#7BBE9A'
}

function missingConns(e: any): string[] {
  const m: string[] = []
  if (!e.loops_connected) m.push('Loops missing')
  if (!e.stripe_connected) m.push('Stripe missing')
  return m
}

function locationLine(e: any): string {
  const parts = [fmtDate(e.start_at, e.timezone)]
  if (e.location_name) parts.push(e.location_name)
  return parts.join(' · ')
}

---

<DashboardLayout title="The Signal OS — Events">
<style>
  .content { padding: 28px 32px; overflow-x: hidden; min-height: 100vh; }

  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 24px;
  }
  .page-header h1 { font-family: var(--heading); font-size: 22px; font-weight: 500; color: var(--text-primary); line-height: 1.2; }
  .page-header-sub { font-size: 13px; color: var(--text-muted); margin-top: 3px; }

  .section { margin-bottom: 28px; }
  .section-title {
    font-family: var(--body); font-size: 10px; font-weight: 600;
    letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-muted);
    margin-bottom: 8px;
  }

  .filter-bar {
    display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
    margin: -6px 0 24px; padding: 10px 0; border-block: 0.5px solid var(--border);
  }
  .filter-group { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .filter-label { font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-right: 2px; }
  .filter-pill {
    font-family: var(--body); font-size: 11px; font-weight: 500;
    border: 0.5px solid var(--border); border-radius: 999px;
    background: var(--surface); color: var(--text-secondary);
    padding: 4px 10px; cursor: pointer; transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .filter-pill:hover { color: var(--text-primary); border-color: rgba(47,47,47,0.22); }
  .filter-pill.is-active { background: rgba(60,138,126,0.10); color: var(--teal); border-color: rgba(60,138,126,0.22); }

  .event-list {
    border: 0.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
  }

  .event-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px;
    border-bottom: 0.5px solid var(--border);
    text-decoration: none;
    transition: background 0.1s;
    cursor: pointer;
  }
  .event-row:last-child { border-bottom: none; }
  .event-row:hover { background: rgba(47,47,47,0.025); }

  .ev-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  }

  .ev-main { flex: 1; min-width: 0; }
  .ev-title {
    font-size: 13px; font-weight: 500; color: var(--text-primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .ev-sub {
    font-size: 11px; color: var(--text-muted); margin-top: 1px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .track-badge {
    font-size: 10px; font-weight: 500; border-radius: 4px;
    padding: 2px 7px; flex-shrink: 0; display: inline-block;
  }

  .ev-status {
    display: flex; flex-direction: column; align-items: flex-end;
    gap: 3px; flex-shrink: 0; min-width: 120px; text-align: right;
  }

  .badge-draft {
    display: inline-block;
    font-size: 10px; font-weight: 500; border-radius: 4px;
    padding: 2px 7px; background: rgba(47,47,47,0.07); color: var(--text-muted);
  }

  .ev-reg-count { font-size: 12px; font-weight: 500; color: var(--text-secondary); }
  .ev-missing   { font-size: 11px; color: #E07020; }
  .ev-open-actions { font-size: 11px; color: #E07020; }
  .ev-insights  { font-size: 11px; color: #0F6E56; }
  .ev-no-actions { font-size: 11px; color: var(--text-muted); }
  .ev-rating    { font-size: 12px; font-weight: 500; color: var(--text-secondary); }

  .show-more-btn {
    display: flex; align-items: center; justify-content: center;
    padding: 10px 16px;
    font-family: var(--body); font-size: 12px; color: var(--text-muted);
    background: none; border: none; border-top: 0.5px solid var(--border);
    cursor: pointer; width: 100%;
    transition: color 0.12s, background 0.12s;
  }
  .show-more-btn:hover { color: var(--text-primary); background: rgba(47,47,47,0.02); }

  .event-row.is-hidden { display: none; }
  .event-row.is-overflow-hidden { display: none; }
  .empty-filter-state { display: none; padding: 18px 16px; font-size: 13px; color: var(--text-muted); text-align: center; }
</style>

<main class="content">

  <header class="page-header">
    <div>
      <h1>Events</h1>
      <p class="page-header-sub">{totalCount} total · {upcomingCount} upcoming · {plannedCount} planned</p>
    </div>
    <a href="/dashboard/events/new" style="font-family:var(--body);font-size:13px;font-weight:500;background:var(--teal);color:#fff;border-radius:8px;padding:7px 16px;text-decoration:none;flex-shrink:0;display:inline-flex;align-items:center;gap:5px;">+ New Event</a>
  </header>

  <div class="filter-bar" data-event-filters>
    <div class="filter-group" aria-label="Filter by time">
      <span class="filter-label">Time</span>
      {[['upcoming', 'Upcoming'], ['past', 'Past']].map(([value, label]) => (
        <button class:list={["filter-pill", { "is-active": value === 'upcoming' }]} type="button" data-filter-group="time" data-filter-value={value} aria-pressed={value === 'upcoming' ? 'true' : 'false'}>{label}</button>
      ))}
    </div>
    <div class="filter-group" aria-label="Filter by audience">
      <span class="filter-label">Audience</span>
      <button class="filter-pill is-active" type="button" data-filter-group="audience" data-filter-value="all" aria-pressed="true">All</button>
      {trackValues.map((track: string) => (
        <button class="filter-pill" type="button" data-filter-group="audience" data-filter-value={track} aria-pressed="false">{labelFromValue(track)}</button>
      ))}
    </div>
    <div class="filter-group" aria-label="Filter by format or location">
      <span class="filter-label">Format</span>
      <button class="filter-pill is-active" type="button" data-filter-group="format" data-filter-value="all" aria-pressed="true">All</button>
      {orderedFormats.map((format: string) => (
        <button class="filter-pill" type="button" data-filter-group="format" data-filter-value={format} aria-pressed="false">{format === 'out-of-area' ? 'Out of area' : labelFromValue(format)}</button>
      ))}
    </div>
  </div>

  <!-- Planned -->
  {planned.length > 0 && (
    <section class="section" data-event-section>
      <p class="section-title">Planned</p>
      <div class="event-list">
        {planned.map((e: any) => (
          <a href={`/dashboard/events/${e.event_id}`} class="event-row" data-event-row data-time={e.event_timing} data-audience={(e.audience_track ?? '').toLowerCase()} data-format={formatFilterValue(e)}>
            <span class="ev-dot" style={`background:${dotColor(e)}`}></span>
            <div class="ev-main">
              <div class="ev-title">{e.title}</div>
              <div class="ev-sub">{locationLine(e)}</div>
            </div>
            <Fragment set:html={trackBadgeHtml(e.audience_track)} />
            <div class="ev-status">
              <span class="badge-draft">draft</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Upcoming -->
  {upcoming.length > 0 && (
    <section class="section" data-event-section>
      <p class="section-title">Upcoming</p>
      <div class="event-list">
        {upcoming.map((e: any) => {
          const missing = missingConns(e)
          return (
            <a href={`/dashboard/events/${e.event_id}`} class="event-row" data-event-row data-time={e.event_timing} data-audience={(e.audience_track ?? '').toLowerCase()} data-format={formatFilterValue(e)}>
              <span class="ev-dot" style={`background:${dotColor(e)}`}></span>
              <div class="ev-main">
                <div class="ev-title">{e.title}</div>
                <div class="ev-sub">{locationLine(e)}</div>
              </div>
              <Fragment set:html={trackBadgeHtml(e.audience_track)} />
              <div class="ev-status">
                <span class="ev-reg-count">{e.registered_count ?? 0} registered</span>
                {missing.map(m => <span class="ev-missing">{m}</span>)}
              </div>
            </a>
          )
        })}
      </div>
    </section>
  )}

  <!-- Past -->
  {past.length > 0 && (
    <section class="section" data-event-section>
      <p class="section-title">Past</p>
      <div class="event-list" id="past-list">
        {pastVisible.map((e: any) => {
          const openActions = Number(e.open_actions ?? 0)
          return (
            <a href={`/dashboard/events/${e.event_id}`} class="event-row" data-event-row data-time={e.event_timing} data-audience={(e.audience_track ?? '').toLowerCase()} data-format={formatFilterValue(e)}>
              <span class="ev-dot" style={`background:${dotColor(e)}`}></span>
              <div class="ev-main">
                <div class="ev-title">{e.title}</div>
                <div class="ev-sub">{locationLine(e)}</div>
              </div>
              <Fragment set:html={trackBadgeHtml(e.audience_track)} />
              <div class="ev-status">
                {e.avg_rating
                  ? <span class="ev-rating">★ {e.avg_rating} ({e.feedback_count})</span>
                  : e.feedback_count > 0
                    ? <span class="ev-rating">{e.feedback_count} responses</span>
                    : <span class="ev-no-actions">—</span>
                }
                {openActions > 0
                  ? <span class="ev-open-actions">{openActions} action{openActions !== 1 ? 's' : ''} open</span>
                  : e.has_insights
                    ? <span class="ev-insights">insights captured</span>
                    : Number(e.total_actions ?? 0) === 0
                      ? <span class="ev-no-actions">no actions yet</span>
                      : null
                }
              </div>
            </a>
          )
        })}
        {pastHidden.map((e: any) => {
          const openActions = Number(e.open_actions ?? 0)
          return (
            <a href={`/dashboard/events/${e.event_id}`} class="event-row" data-event-row data-time={e.event_timing} data-audience={(e.audience_track ?? '').toLowerCase()} data-format={formatFilterValue(e)}>
              <span class="ev-dot" style={`background:${dotColor(e)}`}></span>
              <div class="ev-main">
                <div class="ev-title">{e.title}</div>
                <div class="ev-sub">{locationLine(e)}</div>
              </div>
              <Fragment set:html={trackBadgeHtml(e.audience_track)} />
              <div class="ev-status">
                {e.avg_rating
                  ? <span class="ev-rating">★ {e.avg_rating} ({e.feedback_count})</span>
                  : e.feedback_count > 0
                    ? <span class="ev-rating">{e.feedback_count} responses</span>
                    : <span class="ev-no-actions">—</span>
                }
                {openActions > 0
                  ? <span class="ev-open-actions">{openActions} action{openActions !== 1 ? 's' : ''} open</span>
                  : e.has_insights
                    ? <span class="ev-insights">insights captured</span>
                    : Number(e.total_actions ?? 0) === 0
                      ? <span class="ev-no-actions">no actions yet</span>
                      : null
                }
              </div>
            </a>
          )
        })}
      </div>
    </section>
  )}

  <button class="show-more-btn" id="show-more-filtered" type="button" style="display:none">Show more</button>
  <div class="empty-filter-state" id="empty-filter-state">No events match these filters.</div>

</main>

<script>
  const filterState = { time: 'upcoming', audience: 'all', format: 'all' }
  let expanded = false
  const rows = Array.from(document.querySelectorAll<HTMLElement>('[data-event-row]'))
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-group]'))
  const moreBtn = document.getElementById('show-more-filtered') as HTMLButtonElement | null
  const emptyState = document.getElementById('empty-filter-state') as HTMLElement | null
  const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-event-section]'))

  function applyFilters() {
    const matches = rows.filter(row => {
      const timeOk = row.dataset.time === filterState.time || (filterState.time === 'upcoming' && row.dataset.time === 'draft')
      const audienceOk = filterState.audience === 'all' || row.dataset.audience === filterState.audience
      const formatOk = filterState.format === 'all' || row.dataset.format === filterState.format
      return timeOk && audienceOk && formatOk
    })

    rows.forEach(row => {
      row.classList.add('is-hidden')
      row.classList.remove('is-overflow-hidden')
    })

    matches.forEach((row, index) => {
      row.classList.remove('is-hidden')
      if (!expanded && index >= 10) row.classList.add('is-overflow-hidden')
    })

    if (moreBtn) {
      const remaining = Math.max(matches.length - 10, 0)
      moreBtn.style.display = !expanded && remaining > 0 ? 'flex' : 'none'
      moreBtn.textContent = `Show ${remaining} more`
    }
    sections.forEach(section => {
      const visibleRows = section.querySelectorAll('[data-event-row]:not(.is-hidden)').length
      section.style.display = visibleRows > 0 ? '' : 'none'
    })
    if (emptyState) emptyState.style.display = matches.length === 0 ? 'block' : 'none'
  }

  pills.forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.filterGroup as keyof typeof filterState
      filterState[group] = btn.dataset.filterValue ?? 'all'
      expanded = false
      pills.filter(p => p.dataset.filterGroup === group).forEach(p => {
        const active = p === btn
        p.classList.toggle('is-active', active)
        p.setAttribute('aria-pressed', active ? 'true' : 'false')
      })
      applyFilters()
    })
  })

  moreBtn?.addEventListener('click', () => {
    expanded = true
    applyFilters()
  })

  applyFilters()

</script>
</DashboardLayout>
