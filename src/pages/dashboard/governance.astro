---
export const prerender = false

import { supabaseAdmin } from '../../lib/supabase-admin'
import DashboardLayout from '../../layouts/DashboardLayout.astro'

const MAX_ROWS = 10

const [
  agentsRes,
  dataGovRes,
  decisionsRes,
  processesRes,
  strategyRes,
  principlesRes,
  incidentsRes,
  systemAuditRes,
  openSecChecksRes,
  liveNoSecRes,
  liveNoQaRes,
  noRlsRes,
  overdueRes,
  openIncRes,
  openSecCountRes,
] = await Promise.all([
  supabaseAdmin.from('agents_registry').select('*').order('status').order('name'),
  supabaseAdmin.from('data_governance').select('*').order('table_name'),
  supabaseAdmin.from('decisions').select('*').order('made_at', { ascending: false }),
  supabaseAdmin.from('processes').select('*').order('category').order('name'),
  supabaseAdmin.from('strategy').select('*').order('sort_order', { ascending: true, nullsFirst: false }).order('title'),
  supabaseAdmin.from('operating_principles').select('*').eq('is_active', true).order('domain').order('priority'),
  supabaseAdmin.from('incident_log').select('*').order('detected_at', { ascending: false }),
  supabaseAdmin.from('system_audit').select('*').order('audit_date', { ascending: false }).limit(1).maybeSingle(),
  supabaseAdmin.from('security_checks').select('*').eq('status', 'open').order('created_at', { ascending: false }),
  supabaseAdmin.from('agents_registry').select('id', { count: 'exact', head: true }).in('status', ['live','active']).or('security_approved.is.null,security_approved.eq.false'),
  supabaseAdmin.from('agents_registry').select('id', { count: 'exact', head: true }).in('status', ['live','active']).not('qa_status', 'eq', 'pass'),
  supabaseAdmin.rpc('count_public_tables_without_rls'),
  supabaseAdmin.from('data_governance').select('id', { count: 'exact', head: true }).lt('review_due', new Date().toISOString()),
  supabaseAdmin.from('incident_log').select('id', { count: 'exact', head: true }).is('resolved_at', null),
  supabaseAdmin.from('security_checks').select('id', { count: 'exact', head: true }).eq('status', 'open'),
])

const agents          = agentsRes.data ?? []
const dataGov         = dataGovRes.data ?? []
const decisions       = decisionsRes.data ?? []
const processes       = processesRes.data ?? []
const strategy        = strategyRes.data ?? []
const principles      = principlesRes.data ?? []
const incidents       = incidentsRes.data ?? []
const systemAudit     = systemAuditRes.data
const openSecChecks   = openSecChecksRes.data ?? []

const liveWithoutSecurity   = liveNoSecRes.count ?? 0
const liveWithoutQA         = liveNoQaRes.count ?? 0
const tablesWithoutRLS      = noRlsRes.error ? 0 : (noRlsRes.data ?? 0)
const overdueReviews        = overdueRes.count ?? 0
const openIncidents         = openIncRes.count ?? 0
const openSecurityChecks    = openSecCountRes.count ?? 0

const redCount    = liveWithoutSecurity + openIncidents
const amberCount  = liveWithoutQA + tablesWithoutRLS + overdueReviews
const securityRAG = redCount > 0 ? 'red' : amberCount > 0 ? 'amber' : 'green'

const nextAuditDue  = systemAudit?.next_audit_due ? new Date(systemAudit.next_audit_due) : null
const auditOverdue  = nextAuditDue ? nextAuditDue < new Date() : false
const ragBorderColor = securityRAG === 'red' ? '#C0392B' : securityRAG === 'amber' ? '#FF8A33' : '#7BBE9A'

const govAgents = agents.filter((a: any) => a.status === 'live' || a.status === 'active')

const CLASS_ORDER = ['restricted','confidential','internal','public']
const dataGovSorted = [...dataGov].sort((a: any, b: any) => {
  const ai = CLASS_ORDER.indexOf(a.classification_label) !== -1 ? CLASS_ORDER.indexOf(a.classification_label) : 99
  const bi = CLASS_ORDER.indexOf(b.classification_label) !== -1 ? CLASS_ORDER.indexOf(b.classification_label) : 99
  return ai - bi
})

const PROCESS_CATEGORY_ORDER = ['studio','events','governance','crm','email','operations','system','build']
function groupBy<T>(arr: T[], key: keyof T): Record<string, T[]> {
  return arr.reduce((acc: any, item: any) => {
    const k = item[key] ?? 'other'
    acc[k] = acc[k] ?? []
    acc[k].push(item)
    return acc
  }, {})
}
const processesByCategory = groupBy(processes, 'category')
const allCategories = [
  ...PROCESS_CATEGORY_ORDER.filter(c => processesByCategory[c]),
  ...Object.keys(processesByCategory).filter(c => !PROCESS_CATEGORY_ORDER.includes(c))
]

function formatDateShort(d: string | null | undefined): string {
  if (!d) return '—'
  return new Date(d).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })
}

function isOverdue(d: string | null | undefined): boolean {
  if (!d) return false
  return new Date(d) < new Date()
}
---

<DashboardLayout title="The Signal OS — Governance">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg:             #F5F4F1;
    --color-surface:        #FFFFFF;
    --color-text-primary:   #2F2F2F;
    --color-text-secondary: #505050;
    --color-text-muted:     #909090;
    --color-border:         rgba(47,47,47,0.08);
    --color-teal:           #3C8A7E;
    --color-orange:         #FF8A33;
    --color-green:          #7BBE9A;
    --color-red:            #C0392B;
    --color-violet:         #6F4BA2;
    --font-heading:         'DM Sans', sans-serif;
    --font-body:            'Inter', sans-serif;
    --radius-card:          12px;
    --shadow-sm:            0 1px 3px rgba(47,47,47,0.06);
  }

  /* ── MAIN CONTENT ─────────────────────────── */
  .content {
    padding: 28px 32px;
    overflow-x: hidden;
  }

  .page-header { margin-bottom: 24px; }
  .page-header h1 {
    font-family: var(--font-heading);
    font-size: 28px; font-weight: 700;
    color: var(--color-text-primary); line-height: 1.1;
  }
  .page-header p {
    font-family: var(--font-body);
    font-size: 14px; color: var(--color-text-muted); margin-top: 4px;
  }

  /* ── PANELS ──────────────────────────────── */
  .panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border);
    display: flex; align-items: center; gap: 8px;
  }
  .panel-header h2 {
    font-family: var(--font-heading);
    font-size: 15px; font-weight: 600;
    color: var(--color-text-primary);
  }
  .panel-header a {
    margin-left: auto;
    font-family: var(--font-body);
    font-size: 12px; color: var(--color-teal); text-decoration: none;
  }

  /* ── TWO COLUMN ──────────────────────────── */
  .two-col-50-50 {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; margin-bottom: 16px;
  }
  .two-col-50-50 > .panel { margin-bottom: 0; }

  /* ── TABLES ──────────────────────────────── */
  table { width: 100%; border-collapse: collapse; font-family: var(--font-body); font-size: 13px; }

  thead th {
    text-align: left; padding: 10px 16px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border); white-space: nowrap;
  }

  tbody td {
    padding: 10px 16px; color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border); vertical-align: middle;
  }
  tbody tr:last-child td { border-bottom: none; }

  .clickable-row { cursor: pointer; transition: background 0.1s; }
  .clickable-row:hover td { background: rgba(47,47,47,0.025); }

  .row-amber td:first-child { border-left: 3px solid var(--color-orange); }
  .row-amber td { background: rgba(255,138,51,0.04); }

  /* ── VIEW ALL FOOTER ─────────────────────── */
  .view-all-footer {
    padding: 10px 16px;
    font-family: var(--font-body); font-size: 12px;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  /* ── BADGES ──────────────────────────────── */
  .badge {
    display: inline-block; border-radius: 20px; padding: 2px 10px;
    font-size: 11px; font-weight: 500; font-family: var(--font-body); white-space: nowrap;
  }
  .badge-green   { background: rgba(123,190,154,0.15); color: #2D5A35; }
  .badge-red     { background: rgba(192,57,43,0.12);   color: var(--color-red); }
  .badge-amber   { background: rgba(255,138,51,0.12);  color: #E07020; }
  .badge-grey    { background: rgba(47,47,47,0.08);    color: var(--color-text-secondary); }
  .badge-teal    { background: rgba(60,138,126,0.12);  color: var(--color-teal); }
  .badge-violet  { background: rgba(111,75,162,0.12);  color: var(--color-violet); }
  .badge-blue    { background: rgba(37,99,235,0.10);   color: #2563EB; }

  .badge-restricted   { background: rgba(192,57,43,0.15);   color: var(--color-red); }
  .badge-confidential { background: rgba(255,138,51,0.15);  color: #E07020; }
  .badge-internal     { background: rgba(47,47,47,0.08);    color: var(--color-text-secondary); }
  .badge-public       { background: rgba(123,190,154,0.15); color: #2D5A35; }

  .rag-green { background: #7BBE9A; color: white; font-family: var(--font-body); font-size: 11px; font-weight: 600; border-radius: 20px; padding: 2px 10px; }
  .rag-amber { background: #FF8A33; color: white; font-family: var(--font-body); font-size: 11px; font-weight: 600; border-radius: 20px; padding: 2px 10px; }
  .rag-red   { background: #C0392B; color: white; font-family: var(--font-body); font-size: 11px; font-weight: 600; border-radius: 20px; padding: 2px 10px; }

  /* ── SECURITY HEALTH ─────────────────────── */
  .health-header { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .health-header h2 { font-family: var(--font-heading); font-size: 15px; font-weight: 600; color: var(--color-text-primary); }
  .health-meta { font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted); }

  .stat-chips { display: flex; gap: 10px; flex-wrap: wrap; padding: 14px 20px; border-bottom: 1px solid var(--color-border); }
  .stat-chip {
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 8px; padding: 8px 14px;
    display: flex; flex-direction: column; gap: 2px; min-width: 110px;
  }
  .chip-value { font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1; }
  .chip-label { font-family: var(--font-body); font-size: 11px; color: var(--color-text-muted); }

  .check-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px; border-bottom: 1px solid var(--color-border);
    font-family: var(--font-body); font-size: 12px; color: var(--color-text-secondary);
  }
  .check-row:last-child { border-bottom: none; }

  /* ── PROCESSES ───────────────────────────── */
  details { border-bottom: 1px solid var(--color-border); }
  details:last-child { border-bottom: none; }
  details summary {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-body); font-size: 11px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-text-muted); cursor: pointer; list-style: none; user-select: none;
  }
  details summary::before { content: '▶'; font-size: 9px; transition: transform 0.15s; flex-shrink: 0; }
  details[open] summary::before { transform: rotate(90deg); }

  .process-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 20px 8px 36px;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-body); font-size: 13px;
    cursor: pointer; transition: background 0.1s;
  }
  .process-row:hover { background: rgba(47,47,47,0.025); }
  .process-name { flex: 1; color: var(--color-text-primary); font-weight: 500; }
  .process-owner { font-size: 12px; color: var(--color-text-muted); }

  /* ── PRINCIPLE CARDS ─────────────────────── */
  .principles-grid { display: flex; flex-direction: column; }
  .principle-card {
    padding: 12px 20px;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer; transition: background 0.1s;
  }
  .principle-card:last-child { border-bottom: none; }
  .principle-card:hover { background: rgba(47,47,47,0.025); }
  .principle-text { font-family: var(--font-body); font-size: 14px; color: var(--color-text-primary); margin-top: 6px; line-height: 1.5; }

  /* ── ICON MARKS ──────────────────────────── */
  .tick  { color: #2D5A35; font-weight: 600; }
  .cross { color: var(--color-red); font-weight: 600; }
  .dash  { color: var(--color-text-muted); }

  .empty-state { padding: 20px; font-family: var(--font-body); font-size: 13px; color: var(--color-text-muted); font-style: italic; }
  .strike { text-decoration: line-through; color: var(--color-text-muted); }

  /* ── SLIDE-OVER PANEL ────────────────────── */
  #panel-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.28);
    z-index: 100;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s;
  }
  #panel-overlay.open { opacity: 1; pointer-events: auto; }

  #detail-panel {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: 480px; max-width: 100vw;
    background: var(--color-surface);
    border-left: 1px solid rgba(47,47,47,0.12);
    box-shadow: -4px 0 24px rgba(0,0,0,0.08);
    z-index: 101;
    transform: translateX(100%);
    transition: transform 0.25s ease;
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  #detail-panel.open { transform: translateX(0); }

  .panel-topbar {
    display: flex; align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    gap: 10px; flex-shrink: 0;
  }
  #panel-title {
    font-family: var(--font-heading);
    font-size: 15px; font-weight: 600;
    color: var(--color-text-primary); flex: 1;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  #panel-section-badge {
    font-family: var(--font-body); font-size: 10px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgba(47,47,47,0.06); border-radius: 4px;
    padding: 2px 7px; flex-shrink: 0;
  }
  #panel-close {
    background: none; border: none; cursor: pointer;
    font-size: 16px; color: var(--color-text-muted);
    padding: 4px 8px; border-radius: 4px; line-height: 1; flex-shrink: 0;
  }
  #panel-close:hover { background: rgba(47,47,47,0.06); }

  #panel-body {
    flex: 1; overflow-y: auto;
    padding: 20px;
    display: flex; flex-direction: column; gap: 14px;
  }

  .pf-row { display: flex; flex-direction: column; gap: 4px; }
  .pf-label {
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .pf-value { font-size: 13px; color: var(--color-text-secondary); line-height: 1.6; }
  .pf-null { color: var(--color-text-muted); }

  .pill-yes { display: inline-block; border-radius: 20px; padding: 2px 10px; font-size: 11px; font-weight: 500; background: rgba(123,190,154,0.15); color: #2D5A35; }
  .pill-no  { display: inline-block; border-radius: 20px; padding: 2px 10px; font-size: 11px; font-weight: 500; background: rgba(47,47,47,0.08); color: var(--color-text-secondary); }
  .pill-tag { display: inline-block; border-radius: 4px; padding: 2px 8px; font-size: 11px; font-weight: 500; background: rgba(47,47,47,0.06); color: var(--color-text-secondary); margin: 2px 2px 2px 0; }

  .steps-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .steps-list li { display: flex; gap: 8px; font-size: 13px; line-height: 1.5; }
  .step-num { font-weight: 600; color: var(--color-teal); min-width: 22px; flex-shrink: 0; }

  .json-pre { font-size: 11px; background: rgba(47,47,47,0.04); padding: 8px; border-radius: 4px; overflow-x: auto; white-space: pre-wrap; word-break: break-all; font-family: monospace; }
</style>

<!-- Slide-over overlay + panel -->
<div id="panel-overlay" aria-hidden="true"></div>
<aside id="detail-panel" aria-hidden="true">
  <div class="panel-topbar">
    <span id="panel-title"></span>
    <span id="panel-section-badge"></span>
    <button id="panel-close" aria-label="Close panel">✕</button>
  </div>
  <div id="panel-body"></div>
</aside>

<main class="content">

  <header class="page-header">
    <h1>Governance</h1>
    <p>Agent governance, data governance, SOPs, strategy and operating principles</p>
  </header>

  <!-- ── SECTION 1: Security Health ─────────────── -->
  <div class="panel" style={`border-left: 4px solid ${ragBorderColor};`}>
    <div class="panel-header">
      <div class="health-header">
        <h2>Security Health</h2>
        <span class={`rag-${securityRAG}`}>{securityRAG.toUpperCase()}</span>
        {systemAudit && (
          <span class="health-meta">Last audit: {formatDateShort(systemAudit.audit_date)}</span>
        )}
        {nextAuditDue && (
          <span class="health-meta" style={auditOverdue ? 'color: var(--color-red); font-weight: 500;' : ''}>
            Next due: {formatDateShort(systemAudit?.next_audit_due)}{auditOverdue ? ' — OVERDUE' : ''}
          </span>
        )}
      </div>
    </div>

    <div class="stat-chips">
      <div class="stat-chip">
        <span class="chip-value" style={liveWithoutSecurity > 0 ? 'color: var(--color-red);' : 'color: #2D5A35;'}>
          {liveWithoutSecurity}
        </span>
        <span class="chip-label">Live without security</span>
      </div>
      <div class="stat-chip">
        <span class="chip-value" style={liveWithoutQA > 0 ? 'color: var(--color-red);' : 'color: #2D5A35;'}>
          {liveWithoutQA}
        </span>
        <span class="chip-label">Live without QA</span>
      </div>
      <div class="stat-chip">
        <span class="chip-value" style={tablesWithoutRLS > 0 ? 'color: var(--color-orange);' : 'color: #2D5A35;'}>
          {tablesWithoutRLS}
        </span>
        <span class="chip-label">Tables without RLS</span>
      </div>
      <div class="stat-chip">
        <span class="chip-value" style={overdueReviews > 0 ? 'color: var(--color-orange);' : 'color: #2D5A35;'}>
          {overdueReviews}
        </span>
        <span class="chip-label">Overdue reviews</span>
      </div>
      <div class="stat-chip">
        <span class="chip-value" style={openIncidents > 0 ? 'color: var(--color-red);' : 'color: #2D5A35;'}>
          {openIncidents}
        </span>
        <span class="chip-label">Open incidents</span>
      </div>
      <div class="stat-chip">
        <span class="chip-value" style={openSecurityChecks > 0 ? 'color: var(--color-orange);' : 'color: #2D5A35;'}>
          {openSecurityChecks}
        </span>
        <span class="chip-label">Open security checks</span>
      </div>
    </div>

    {openSecChecks.length === 0 ? (
      <div class="check-row" style="color: #2D5A35; font-style: italic;">
        No open security checks — system is clean
      </div>
    ) : openSecChecks.map((c: any) => (
      <div class="check-row">
        <span class="badge badge-amber">{c.check_type ?? '—'}</span>
        <span style="flex: 1; font-weight: 500;">{c.subject ?? '—'}</span>
        <span style="color: var(--color-text-muted); flex: 2;">{c.detail ?? '—'}</span>
        <span style="color: var(--color-text-muted);">{formatDateShort(c.due_date)}</span>
        {c.action_required && <span class="badge badge-red">{c.action_required}</span>}
      </div>
    ))}
  </div>

  <!-- ── SECTION 2: Agent Governance ────────────── -->
  <div class="panel">
    <div class="panel-header">
      <h2>Agent Governance</h2>
      <a href="/dashboard/agents">View all agents →</a>
    </div>
    {govAgents.length === 0 ? (
      <div class="empty-state">No live or active agents</div>
    ) : (
      <>
        <table>
          <thead>
            <tr>
              <th>Agent</th>
              <th>Status</th>
              <th>Category</th>
              <th>QA</th>
              <th>Security</th>
            </tr>
          </thead>
          <tbody>
            {govAgents.slice(0, MAX_ROWS).map((a: any) => {
              const flagged = !a.security_approved || a.qa_status !== 'pass'
              return (
                <tr
                  class={`clickable-row${flagged ? ' row-amber' : ''}`}
                  data-record={JSON.stringify(a)}
                  data-title-field="name"
                  data-section="Agent"
                >
                  <td style="font-weight: 500;">{a.name ?? '—'}</td>
                  <td><span class="badge badge-green">{a.status}</span></td>
                  <td style="font-size: 12px; color: var(--color-text-muted);">{a.category ?? '—'}</td>
                  <td>
                    {a.qa_status === 'pass'
                      ? <span class="badge badge-green">Pass</span>
                      : <span class="badge badge-amber">{a.qa_status ?? 'Not tested'}</span>
                    }
                  </td>
                  <td>
                    {a.security_approved
                      ? <span class="tick">✓</span>
                      : <span class="cross">✕</span>
                    }
                  </td>
                </tr>
              )
            })}
          </tbody>
        </table>
        {govAgents.length > MAX_ROWS && (
          <div class="view-all-footer">Showing {MAX_ROWS} of {govAgents.length} agents</div>
        )}
      </>
    )}
  </div>

  <!-- ── SECTION 3: Data Governance ─────────────── -->
  <div class="panel">
    <div class="panel-header">
      <h2>Data Governance</h2>
    </div>
    {dataGovSorted.length === 0 ? (
      <div class="empty-state">No data governance records</div>
    ) : (
      <>
        <table>
          <thead>
            <tr>
              <th>Table</th>
              <th>Classification</th>
              <th>Owner</th>
              <th>Agent access</th>
              <th>RLS</th>
              <th>Review due</th>
            </tr>
          </thead>
          <tbody>
            {dataGovSorted.slice(0, MAX_ROWS).map((d: any) => {
              const rlsIssue    = d.rls_required && !d.rls_enabled
              const reviewIssue = d.review_due && isOverdue(d.review_due)
              const rowFlag     = rlsIssue || reviewIssue
              return (
                <tr
                  class={`clickable-row${rowFlag ? ' row-amber' : ''}`}
                  data-record={JSON.stringify(d)}
                  data-title-field="table_name"
                  data-section="Data Governance"
                >
                  <td style="font-weight: 500; font-size: 12px; font-family: monospace;">{d.table_name}</td>
                  <td>
                    <span class={`badge badge-${d.classification_label ?? 'grey'}`}>
                      {d.classification_label ?? '—'}
                    </span>
                  </td>
                  <td style="font-size: 12px; color: var(--color-text-muted);">{d.owner ?? '—'}</td>
                  <td style="font-size: 12px; color: var(--color-text-muted);">{d.agent_access ?? '—'}</td>
                  <td>
                    {d.rls_enabled
                      ? <span class="tick">✓</span>
                      : d.rls_required
                        ? <span class="cross">✕</span>
                        : <span class="dash">—</span>
                    }
                  </td>
                  <td style={`font-size: 12px; ${reviewIssue ? 'color: var(--color-red); font-weight: 500;' : 'color: var(--color-text-muted);'}`}>
                    {formatDateShort(d.review_due)}
                  </td>
                </tr>
              )
            })}
          </tbody>
        </table>
        {dataGovSorted.length > MAX_ROWS && (
          <div class="view-all-footer">Showing {MAX_ROWS} of {dataGovSorted.length} tables</div>
        )}
      </>
    )}
  </div>

  <!-- ── SECTION 4: Decisions + Incidents ───────── -->
  <div class="two-col-50-50">

    <!-- Decisions -->
    <div class="panel">
      <div class="panel-header">
        <h2>Decisions</h2>
      </div>
      {decisions.length === 0 ? (
        <div class="empty-state">No decisions recorded</div>
      ) : (
        <>
          <table>
            <thead>
              <tr>
                <th>Summary</th>
                <th>Type</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              {decisions.slice(0, MAX_ROWS).map((d: any) => {
                const superseded = d.status === 'superseded'
                const statusBadgeClass = d.status === 'active'
                  ? 'badge-green'
                  : d.status === 'under_review'
                    ? 'badge-amber'
                    : 'badge-grey'
                const typeBadgeClass = d.decision_type === 'security'
                  ? 'badge-red'
                  : d.decision_type === 'architecture'
                    ? 'badge-violet'
                    : d.decision_type === 'governance'
                      ? 'badge-teal'
                      : 'badge-grey'
                return (
                  <tr
                    class="clickable-row"
                    data-record={JSON.stringify(d)}
                    data-title-field="summary"
                    data-section="Decision"
                  >
                    <td style="font-weight: 500; max-width: 200px;">
                      <span class={superseded ? 'strike' : ''}>{d.summary ?? '—'}</span>
                    </td>
                    <td>
                      {d.decision_type && (
                        <span class={`badge ${typeBadgeClass}`}>{d.decision_type}</span>
                      )}
                    </td>
                    <td>
                      <span class={`badge ${statusBadgeClass}`}>{d.status ?? '—'}</span>
                    </td>
                    <td style="font-size: 12px; color: var(--color-text-muted); white-space: nowrap;">
                      {formatDateShort(d.made_at)}
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
          {decisions.length > MAX_ROWS && (
            <div class="view-all-footer">Showing {MAX_ROWS} of {decisions.length} decisions</div>
          )}
        </>
      )}
    </div>

    <!-- Incidents -->
    <div class="panel">
      <div class="panel-header">
        <h2>Incidents</h2>
      </div>
      {incidents.length === 0 ? (
        <div class="empty-state">No incidents recorded</div>
      ) : (
        <>
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Severity</th>
                <th>Type</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {incidents.slice(0, MAX_ROWS).map((i: any) => {
                const sevClass = i.severity === 'critical'
                  ? 'badge-red'
                  : i.severity === 'high'
                    ? 'badge-amber'
                    : 'badge-grey'
                const title = i.description || i.type || i.incident_type || formatDateShort(i.detected_at)
                return (
                  <tr
                    class="clickable-row"
                    data-record={JSON.stringify(i)}
                    data-title-field="description"
                    data-section="Incident"
                  >
                    <td style="font-size: 12px; color: var(--color-text-muted); white-space: nowrap;">
                      {formatDateShort(i.detected_at)}
                    </td>
                    <td>
                      <span class={`badge ${sevClass}`}>{i.severity ?? '—'}</span>
                    </td>
                    <td style="font-size: 12px; color: var(--color-text-muted);">
                      {i.type ?? i.incident_type ?? '—'}
                    </td>
                    <td>
                      {i.resolved_at
                        ? <span class="badge badge-green">Resolved</span>
                        : <span class="badge badge-red">Open</span>
                      }
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
          {incidents.length > MAX_ROWS && (
            <div class="view-all-footer">Showing {MAX_ROWS} of {incidents.length} incidents</div>
          )}
        </>
      )}
    </div>

  </div>

  <!-- ── SECTION 5: SOPs & Processes ────────────── -->
  <div class="panel">
    <div class="panel-header">
      <h2>SOPs &amp; Processes</h2>
      <span style="margin-left: auto; font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted);">
        {processes.length} total
      </span>
    </div>
    {processes.length === 0 ? (
      <div class="empty-state">No processes recorded</div>
    ) : allCategories.map((cat) => {
      const rows = processesByCategory[cat] ?? []
      return (
        <details>
          <summary>
            {cat}
            <span style="margin-left: 4px; font-weight: 400; font-size: 11px; color: var(--color-text-muted);">({rows.length})</span>
          </summary>
          {rows.map((p: any) => {
            const noSteps = !p.steps || (Array.isArray(p.steps) && p.steps.length === 0)
            const statusClass = p.status === 'active'
              ? 'badge-green'
              : p.status === 'draft'
                ? 'badge-grey'
                : p.status === 'in_progress'
                  ? 'badge-amber'
                  : p.status === 'completed'
                    ? 'badge-teal'
                    : 'badge-grey'
            return (
              <div
                class="process-row"
                data-record={JSON.stringify(p)}
                data-title-field="name"
                data-section="Process"
              >
                <span class="process-name">
                  {p.name}
                  {noSteps && <span class="badge badge-amber" style="margin-left: 8px;">Steps TBC</span>}
                </span>
                {p.frequency && <span class="badge badge-grey">{p.frequency}</span>}
                <span class={`badge ${statusClass}`}>{p.status ?? '—'}</span>
                {p.owner && <span class="process-owner">{p.owner}</span>}
              </div>
            )
          })}
        </details>
      )
    })}
  </div>

  <!-- ── SECTION 6: Strategy + Principles ──────── -->
  <div class="two-col-50-50">

    <!-- Strategy -->
    <div class="panel">
      <div class="panel-header">
        <h2>Strategy</h2>
      </div>
      {strategy.length === 0 ? (
        <div class="empty-state">No strategy entries</div>
      ) : (
        <>
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Status</th>
                <th>Review</th>
              </tr>
            </thead>
            <tbody>
              {strategy.slice(0, MAX_ROWS).map((s: any) => {
                const statusClass = s.status === 'active'
                  ? 'badge-green'
                  : s.status === 'under_review'
                    ? 'badge-amber'
                    : 'badge-grey'
                const reviewOverdue = s.review_date && isOverdue(s.review_date)
                return (
                  <tr
                    class="clickable-row"
                    data-record={JSON.stringify(s)}
                    data-title-field="title"
                    data-section="Strategy"
                  >
                    <td style="font-weight: 500;">{s.title ?? '—'}</td>
                    <td>
                      {s.strategy_type && <span class="badge badge-grey">{s.strategy_type}</span>}
                    </td>
                    <td><span class={`badge ${statusClass}`}>{s.status ?? '—'}</span></td>
                    <td style={`font-size: 12px; ${reviewOverdue ? 'color: var(--color-red); font-weight: 500;' : 'color: var(--color-text-muted);'}`}>
                      {formatDateShort(s.review_date)}
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
          {strategy.length > MAX_ROWS && (
            <div class="view-all-footer">Showing {MAX_ROWS} of {strategy.length} entries</div>
          )}
        </>
      )}
    </div>

    <!-- Operating Principles -->
    <div class="panel">
      <div class="panel-header">
        <h2>Operating Principles</h2>
      </div>
      {principles.length === 0 ? (
        <div class="empty-state">No operating principles</div>
      ) : (
        <>
          <div class="principles-grid">
            {principles.slice(0, MAX_ROWS).map((p: any) => {
              const domainClass = p.domain === 'system'
                ? 'badge-teal'
                : p.domain === 'agents'
                  ? 'badge-violet'
                  : p.domain === 'security'
                    ? 'badge-red'
                    : p.domain === 'web'
                      ? 'badge-blue'
                      : p.domain === 'client_ops'
                        ? 'badge-green'
                        : 'badge-grey'
              return (
                <div
                  class="principle-card"
                  data-record={JSON.stringify(p)}
                  data-title-field="principle"
                  data-section="Principle"
                >
                  <span class={`badge ${domainClass}`}>{p.domain}</span>
                  <p class="principle-text">{p.principle}</p>
                </div>
              )
            })}
          </div>
          {principles.length > MAX_ROWS && (
            <div class="view-all-footer">Showing {MAX_ROWS} of {principles.length} principles</div>
          )}
        </>
      )}
    </div>

  </div>

</main>

<script>
  const overlay     = document.getElementById('panel-overlay')!
  const panel       = document.getElementById('detail-panel')!
  const panelTitle  = document.getElementById('panel-title')!
  const panelBadge  = document.getElementById('panel-section-badge')!
  const panelBody   = document.getElementById('panel-body')!
  const panelClose  = document.getElementById('panel-close')!

  // Fields to always skip in the detail view
  const SKIP_FIELDS = new Set(['id'])

  // Fields that are timestamps
  const TS_FIELDS = new Set([
    'detected_at','resolved_at','made_at','created_at','updated_at',
    'review_due','review_date','last_run','rotation_due_at','last_rotated_at',
    'last_active','audit_date','next_audit_due',
  ])

  function formatTs(val: string): string {
    const d = new Date(val)
    if (isNaN(d.getTime())) return val
    return d.toLocaleString('en-AU', {
      day: 'numeric', month: 'short', year: 'numeric',
      hour: 'numeric', minute: '2-digit', hour12: true,
    })
  }

  function esc(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  function renderFieldValue(key: string, val: unknown): string {
    if (val === null || val === undefined) {
      return '<span class="pf-null">—</span>'
    }
    if (typeof val === 'boolean') {
      return val
        ? '<span class="pill-yes">Yes</span>'
        : '<span class="pill-no">No</span>'
    }
    if (key === 'steps' && Array.isArray(val)) {
      if (val.length === 0) return '<span class="pf-null">—</span>'
      const items = (val as any[]).map((s, i) => {
        const text = s.description || s.action || s.step || JSON.stringify(s)
        const num  = s.order ?? (i + 1)
        return `<li><span class="step-num">${num}.</span><span>${esc(String(text))}</span></li>`
      }).join('')
      return `<ol class="steps-list">${items}</ol>`
    }
    if (Array.isArray(val)) {
      if (val.length === 0) return '<span class="pf-null">—</span>'
      return (val as any[]).map(v => `<span class="pill-tag">${esc(String(v))}</span>`).join(' ')
    }
    if (typeof val === 'object') {
      return `<pre class="json-pre">${esc(JSON.stringify(val, null, 2))}</pre>`
    }
    if (TS_FIELDS.has(key) || (typeof val === 'string' && /^\d{4}-\d{2}-\d{2}T/.test(val))) {
      return esc(formatTs(val as string))
    }
    return esc(String(val))
  }

  function renderRecord(record: Record<string, unknown>): string {
    return Object.entries(record)
      .filter(([k]) => !SKIP_FIELDS.has(k))
      .map(([k, v]) => {
        const label = k.replace(/_/g, ' ')
        const value = renderFieldValue(k, v)
        return `<div class="pf-row"><div class="pf-label">${esc(label)}</div><div class="pf-value">${value}</div></div>`
      })
      .join('')
  }

  function openPanel(record: Record<string, unknown>, titleField: string, section: string) {
    const title = record[titleField] as string | null | undefined
    panelTitle.textContent = title ? String(title) : 'Record detail'
    panelBadge.textContent = section
    panelBody.innerHTML = renderRecord(record)
    panel.setAttribute('aria-hidden', 'false')
    overlay.setAttribute('aria-hidden', 'false')
    panel.classList.add('open')
    overlay.classList.add('open')
    document.body.style.overflow = 'hidden'
  }

  function closePanel() {
    panel.classList.remove('open')
    overlay.classList.remove('open')
    panel.setAttribute('aria-hidden', 'true')
    overlay.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  overlay.addEventListener('click', closePanel)
  panelClose.addEventListener('click', closePanel)
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closePanel()
  })

  document.querySelectorAll<HTMLElement>('[data-record]').forEach(el => {
    el.addEventListener('click', (e: Event) => {
      if ((e.target as HTMLElement).tagName === 'A') return
      try {
        const record: Record<string, unknown> = JSON.parse(el.dataset.record!)
        const titleField = el.dataset.titleField ?? Object.keys(record)[0]
        const section    = el.dataset.section ?? ''
        openPanel(record, titleField, section)
      } catch {}
    })
  })
</script>
</DashboardLayout>
