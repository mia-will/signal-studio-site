---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BlockRenderer from '../components/blocks/BlockRenderer.astro';
import { supabase } from '../lib/supabase';

import {
  getSite,
  getHomepagePage,
  getEnabledBlocks,
  getPageSEO,
  getNavItems,
  getMediaAssets,
  getFaqItems,
} from '../lib/queries';

const SITE_SLUG = 'signal_studio';
const { isPreview } = Astro.locals;

// ── Fetch core structure ──────────────────────────────────────
const [site, page, headerNav, footerNav] = await Promise.all([
  getSite(SITE_SLUG),
  getHomepagePage(SITE_SLUG, 'about', isPreview),
  getNavItems(SITE_SLUG, 'header'),
  getNavItems(SITE_SLUG, 'footer'),
]);

if (!site || !page) return Astro.redirect('/500');

// ── Fetch blocks and SEO ──────────────────────────────────────
const [blocks, seo] = await Promise.all([
  getEnabledBlocks(page.id, isPreview),
  getPageSEO(page.id),
]);

// ── Batch fetch media assets referenced in blocks ─────────────
const mediaIds = blocks
  .map((b) => b.media_asset_id)
  .filter((id): id is string => Boolean(id));

// ── Identify which block types are on this page ───────────────
const blockKeys = new Set(blocks.map((b) => b.block_type_key));

// ── Fetch content data in parallel ───────────────────────────
const [mediaAssets, faqItems] = await Promise.all([
  getMediaAssets(mediaIds),
  blockKeys.has('faq') ? getFaqItems(page.id) : Promise.resolve([]),
]);

// ── Enrich source-linked blocks ──────────────────────────────
const sourceBlocks = blocks.filter(
  b => b.block_type_key === 'page_intro' && b.source_table === 'people_bios' && b.source_key
);
let enrichedBlocks = [...blocks];
if (sourceBlocks.length > 0) {
  const bios = await Promise.all(
    sourceBlocks.map(b =>
      supabase
        .from('people_bios')
        .select('display_name, title, bio_long')
        .eq(b.source_filter ?? 'public_slug', b.source_key!)
        .maybeSingle()
    )
  );
  enrichedBlocks = blocks.map(b => {
    const idx = sourceBlocks.indexOf(b);
    if (idx === -1) return b;
    const bio = bios[idx].data;
    if (!bio) return b;
    return {
      ...b,
      title:    bio.display_name ?? b.title,
      subtitle: bio.title        ?? b.subtitle,
      props: {
        ...b.props,
        body_html: bio.bio_long ?? null,
      },
    };
  });
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

// ── SEO values ────────────────────────────────────────────────
const seoTitle       = seo?.seo_title_override ?? page.title ?? null;
const seoDescription = seo?.seo_description_override ?? site.meta_description ?? null;
if (!site.primary_domain) throw new Error('Missing: sites.primary_domain for slug=signal_studio');
if (!site.brand_key)      throw new Error('Missing: sites.brand_key for slug=signal_studio');
if (!page.robots)         throw new Error('Missing: site_pages.robots for page=about');
const canonicalUrl   = `https://${site.primary_domain}/about`;
const robots         = page.robots;
const jsonld         = seo?.jsonld || [];
const aeoSummary     = seo?.aeo_summary || undefined;
---

<Layout
  title={seoTitle}
  description={seoDescription}
  canonical={canonicalUrl}
  robots={robots}
  jsonld={jsonld}
  aeoSummary={aeoSummary}
  siteName={site.name}
  brandKey={site.brand_key}
>
  <Nav navItems={headerNav} site={site} />

  <main id="main-content">
    {enrichedBlocks.map((block) => (
      <BlockRenderer
        block={block}
        mediaAssets={mediaAssets}
        offers={[]}
        posts={[]}
        events={[]}
        testimonials={[]}
        faqItems={faqItems}
      />
    ))}
  </main>

  <Footer footerItems={footerNav} site={site} acknowledgement={site.acknowledgement} />
</Layout>
