---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BlockRenderer from '../components/blocks/BlockRenderer.astro';
import OfferGroup from '../components/blocks/OfferGroup.astro';
import MichelleHomePage from '../sites/michelle/pages/index.astro';

import {
  getSite,
  getHomepagePage,
  getEnabledBlocks,
  getPageSEO,
  getNavItems,
  getMediaAssets,
  getOffers,
  getPosts,
  getHomepageEvents,
  getBuilderEvents,
  getTestimonials,
  getFaqItems,
  getOfferGroups,
} from '../lib/queries';

const SITE_SLUG = process.env.SITE_SLUG;
if (!SITE_SLUG) throw new Error('Missing env var: SITE_SLUG');
const isMichelle = SITE_SLUG === 'michelle';
const isSignalStudio = SITE_SLUG === 'signal_studio';
const { isPreview } = Astro.locals;

let site: Awaited<ReturnType<typeof getSite>> = null;
let page: Awaited<ReturnType<typeof getHomepagePage>> = null;
let headerNav: Awaited<ReturnType<typeof getNavItems>> = [];
let footerNav: Awaited<ReturnType<typeof getNavItems>> = [];
let blocks: Awaited<ReturnType<typeof getEnabledBlocks>> = [];
let seo: Awaited<ReturnType<typeof getPageSEO>> = null;
let mediaAssets: Awaited<ReturnType<typeof getMediaAssets>> = {};
let offers: Awaited<ReturnType<typeof getOffers>> = [];
let posts: Awaited<ReturnType<typeof getPosts>> = [];
let events: Awaited<ReturnType<typeof getHomepageEvents>> = [];
let builderEvents: Awaited<ReturnType<typeof getBuilderEvents>> = [];
let testimonials: Awaited<ReturnType<typeof getTestimonials>> = [];
let faqItems: Awaited<ReturnType<typeof getFaqItems>> = [];
let offerGroups: Awaited<ReturnType<typeof getOfferGroups>> = [];

if (!isMichelle) {
  // ── Fetch core structure ──────────────────────────────────────
  [site, page, headerNav, footerNav] = await Promise.all([
    getSite(SITE_SLUG).then((result) => {
      console.log('[signal-studio-site:index]', {
        SITE_SLUG: import.meta.env.SITE_SLUG,
        site: result,
      });
      return result;
    }),
    getHomepagePage(SITE_SLUG, 'home', isPreview),
    getNavItems(SITE_SLUG, 'header'),
    getNavItems(SITE_SLUG, 'footer'),
  ]);

  if (!site || !page) {
    return Astro.redirect('/500');
  }

  // ── Fetch blocks and SEO ──────────────────────────────────────
  [blocks, seo] = await Promise.all([
    getEnabledBlocks(page.id, isPreview),
    getPageSEO(page.id),
  ]);

  // ── Batch fetch media assets referenced in blocks ─────────────
  const mediaIds = blocks
    .map((b) => b.media_asset_id)
    .filter((id): id is string => Boolean(id));

  // ── Identify which block types are on this page ───────────────
  const blockKeys = new Set(blocks.map((b) => b.block_type_key));

  const offersBlock = blocks.find((b) => b.block_type_key === 'offers_grid');
  const postsBlock  = blocks.find((b) => b.block_type_key === 'latest_posts');
  const eventsBlock = blocks.find((b) => b.block_type_key === 'events_list');

  // ── Fetch content data + media in parallel ────────────────────
  [
    mediaAssets,
    offers,
    posts,
    events,
    builderEvents,
    testimonials,
    faqItems,
  ] = await Promise.all([
    getMediaAssets(mediaIds),
    blockKeys.has('offers_grid') ? getOffers(SITE_SLUG, offersBlock?.limit ?? 4) : Promise.resolve([]),
    blockKeys.has('latest_posts') ? getPosts(SITE_SLUG, postsBlock?.limit ?? 3) : Promise.resolve([]),
    blockKeys.has('events_list') ? getHomepageEvents(eventsBlock?.limit ?? 3) : Promise.resolve([]),
    blockKeys.has('events_list') ? getBuilderEvents(8) : Promise.resolve([]),
    blockKeys.has('testimonials') ? getTestimonials(3) : Promise.resolve([]),
    blockKeys.has('faq') ? getFaqItems(page.id) : Promise.resolve([]),
  ]);

  offerGroups = isSignalStudio ? await getOfferGroups(SITE_SLUG) : [];
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

// ── SEO values ────────────────────────────────────────────────
if (!isMichelle) {
  if (!site?.primary_domain) throw new Error(`Missing: sites.primary_domain for slug=${SITE_SLUG}`);
  if (!site?.brand_key)      throw new Error(`Missing: sites.brand_key for slug=${SITE_SLUG}`);
  if (!page?.robots)         throw new Error(`Missing: site_pages.robots for slug=${SITE_SLUG} page=home`);
}

const seoTitle       = seo?.seo_title_override ?? page?.title ?? null;
const seoDescription = seo?.seo_description_override ?? site?.meta_description ?? null;
const canonicalUrl   = page?.canonical_url || `https://${site?.primary_domain}/`;
const robots         = page?.robots ?? '';
const jsonld         = seo?.jsonld || [];
const aeoSummary     = seo?.aeo_summary || undefined;
---

{isMichelle ? (
  <MichelleHomePage />
) : (
  <Layout
    title={seoTitle}
    description={seoDescription}
    canonical={canonicalUrl}
    robots={robots}
    jsonld={jsonld}
    aeoSummary={aeoSummary}
    siteName={site?.name ?? ''}
    brandKey={site?.brand_key ?? ''}
  >
    <Nav navItems={headerNav} site={site!} />

    <main id="main-content">
      {blocks.map((block) => (
        <BlockRenderer
          block={block}
          mediaAssets={mediaAssets}
          offers={offers}
          offerGroups={offerGroups}
          posts={posts}
          events={events}
          builderEvents={builderEvents}
          testimonials={testimonials}
          faqItems={faqItems}
        />
      ))}
    </main>

    <Footer footerItems={footerNav} site={site!} acknowledgement={site?.acknowledgement} />
  </Layout>
)}
