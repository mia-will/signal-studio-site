---
import type { PageBlock } from '../../types/content';

interface Props {
  block: PageBlock;
}

const { block } = Astro.props;

interface EcosystemItem {
  title?: string;
  name?: string;
  subtitle?: string;
  tagline?: string;
  body?: string;
  description?: string;
  link_url?: string;
  href?: string;
  link_label?: string;
  cta_label?: string;
  is_current?: boolean;
  is_external?: boolean;
}

const rawItems: EcosystemItem[] = block.props?.items ?? [];
const items = rawItems.map((item) => ({
  label:      item.title      ?? item.name      ?? '',
  sub:        item.subtitle   ?? item.tagline   ?? '',
  desc:       item.body       ?? item.description ?? '',
  href:       item.link_url   ?? item.href      ?? '#',
  ctaLabel:   item.link_label ?? item.cta_label ?? '',
  isCurrent:  item.is_current ?? false,
  isExternal: item.is_external ?? item.link_url?.startsWith('http') ?? item.href?.startsWith('http') ?? false,
}));

const hasDescriptions = items.some((item) => item.desc);
---

<section class="ecosystem-block" style="padding: 64px 0; border-top: 1px solid var(--color_border);">
  <div class="ecosystem-inner" style="max-width: 1200px; margin-inline: auto; padding-inline: 48px;">

    <!-- Header -->
    <div style="margin-bottom: 40px;">
      {block.props?.eyebrow && (
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_cta_primary); margin: 0 0 10px;">
          {block.props.eyebrow}
        </p>
      )}
      {(block.props?.title ?? block.title) && (
        <h2 style="font-family: var(--font_heading); font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; color: var(--color_text_heading); margin: 0 0 12px; line-height: 1.15;">
          {block.props?.title ?? block.title}
        </h2>
      )}
      {(block.props?.intro ?? block.props?.subtitle) && (
        <p style="font-size: 15px; color: var(--color_text_secondary); margin: 0; max-width: 52ch; line-height: 1.6;">
          {block.props?.intro ?? block.props?.subtitle}
        </p>
      )}
    </div>

    {hasDescriptions ? (
      <!-- Card grid when items have descriptions -->
      <div class="ecosystem-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">
        {items.map((item) => (
          <a
            class="ecosystem-card"
            href={item.href}
            target={item.isExternal ? '_blank' : undefined}
            rel={item.isExternal ? 'noopener noreferrer' : undefined}
            style={`display: flex; flex-direction: column; gap: 8px; padding: 24px; border-radius: var(--radius_md); border: 1.5px solid ${item.isCurrent ? 'var(--color_cta_primary)' : 'var(--color_border)'}; background: var(--color_surface_alt); text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;`}
            onmouseover="this.style.borderColor='var(--color_cta_primary)';this.style.boxShadow='var(--shadow_sm)';this.style.transform='translateY(-2px)'"
            onmouseout={`this.style.borderColor='${item.isCurrent ? 'var(--color_cta_primary)' : 'var(--color_border)'}';this.style.boxShadow='none';this.style.transform=''`}
          >
            <span style="font-size: 14px; font-weight: 700; color: var(--color_text_heading);">
              {item.label}
            </span>
            {item.sub && (
              <span style="font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color_cta_primary); opacity: 0.75;">
                {item.sub}
              </span>
            )}
            {item.desc && (
              <span style="font-size: 13px; color: var(--color_text_secondary); line-height: 1.55; flex: 1;">
                {item.desc}
              </span>
            )}
            {item.ctaLabel && (
              <span style="font-size: 12px; font-weight: 600; color: var(--color_cta_primary); margin-top: 4px;">
                {item.ctaLabel}
              </span>
            )}
          </a>
        ))}
      </div>
    ) : (
      <!-- Pill links when items have no descriptions -->
      <div class="ecosystem-pills" style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
        {items.map((item) => (
          <a
            class="ecosystem-pill"
            href={item.href}
            target={item.isExternal ? '_blank' : undefined}
            rel={item.isExternal ? 'noopener noreferrer' : undefined}
            style="display: inline-flex; flex-direction: column; gap: 2px; padding: 14px 24px; border-radius: var(--radius_full, 9999px); border: 1.5px solid var(--color_border); background: var(--color_surface_alt); text-decoration: none; transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;"
            onmouseover="this.style.borderColor='var(--color_cta_primary)';this.style.boxShadow='var(--shadow_sm)';this.style.transform='translateY(-2px)'"
            onmouseout="this.style.borderColor='var(--color_border)';this.style.boxShadow='none';this.style.transform=''"
          >
            <span style="font-size: 14px; font-weight: 700; color: var(--color_text_heading); white-space: nowrap;">
              {item.label}
            </span>
            {item.sub && (
              <span style="font-size: 11px; color: var(--color_text_secondary); white-space: nowrap;">
                {item.sub}
              </span>
            )}
          </a>
        ))}
      </div>
    )}

  </div>
</section>

<style>
  .ecosystem-block,
  .ecosystem-inner,
  .ecosystem-grid,
  .ecosystem-card,
  .ecosystem-pills,
  .ecosystem-pill {
    box-sizing: border-box;
  }

  .ecosystem-block {
    overflow: hidden;
  }

  .ecosystem-card,
  .ecosystem-pill {
    min-width: 0;
    max-width: 100%;
  }

  @media (max-width: 768px) {
    .ecosystem-inner {
      width: 100%;
      max-width: 100%;
      padding-inline: var(--layout_padding_x) !important;
    }

    .ecosystem-grid {
      grid-template-columns: 1fr !important;
      width: 100%;
    }

    .ecosystem-pills {
      width: 100%;
    }

    .ecosystem-pill span {
      white-space: normal !important;
    }
  }
</style>
