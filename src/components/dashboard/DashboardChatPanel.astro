---
interface Props {
  currentPath: string
}
const { currentPath } = Astro.props
---

{!currentPath.endsWith('/new') && (
  <>
    <button id="chat-toggle-btn" class="chat-toggle-btn" aria-label="Ask Signal OS">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      Ask Signal OS
    </button>

    <div id="chat-panel" class="chat-panel" aria-hidden="true" role="complementary" aria-label="Signal OS chat">
      <div class="chat-panel-header">
        <span class="chat-panel-title">Signal OS</span>
        <button id="chat-close-btn" class="chat-close-btn" aria-label="Close chat">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div id="chat-messages" class="chat-messages" aria-live="polite" aria-label="Chat messages"></div>

      <div class="chat-input-area">
        <div id="attach-tooltip" class="attach-tooltip" role="tooltip" hidden>Image and PDF attachments coming soon</div>
        <div class="chat-input-row">
          <button id="chat-attach-btn" class="chat-attach-btn" aria-label="Attach file (coming soon)" type="button">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
            </svg>
          </button>
          <textarea
            id="chat-input"
            class="chat-input"
            placeholder="Ask anything…"
            rows="1"
            aria-label="Message"
          ></textarea>
          <button id="chat-send-btn" class="chat-send-btn" type="button" aria-label="Send message">Send</button>
        </div>
      </div>
    </div>
  </>
)}

<style>
  .chat-toggle-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    background: var(--teal, #3C8A7E);
    color: #fff;
    border: none;
    border-radius: 20px;
    font-family: var(--body, sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    z-index: 900;
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s;
  }
  .chat-toggle-btn:hover {
    background: #317368;
  }
  .chat-toggle-btn.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.85);
  }

  .chat-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 380px;
    height: 100vh;
    background: var(--color-background-primary, #fff);
    border-left: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.12));
    display: flex;
    flex-direction: column;
    z-index: 800;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  .chat-panel.open {
    transform: translateX(0);
  }

  .chat-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.12));
    flex-shrink: 0;
  }
  .chat-panel-title {
    font-family: var(--heading, sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a1a);
    letter-spacing: 0.01em;
  }
  .chat-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-text-secondary, #666);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  .chat-close-btn:hover {
    color: var(--color-text-primary, #1a1a1a);
    background: var(--color-background-tertiary, #f2f1ef);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .chat-msg {
    max-width: 86%;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 0.8125rem;
    line-height: 1.5;
    word-break: break-word;
    white-space: pre-wrap;
  }
  .chat-msg--user {
    align-self: flex-end;
    background: var(--teal, #3C8A7E);
    color: #fff;
    border-bottom-right-radius: 3px;
  }
  .chat-msg--assistant {
    align-self: flex-start;
    background: var(--color-background-secondary, #f9f9f8);
    color: var(--color-text-primary, #1a1a1a);
    border: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    border-bottom-left-radius: 3px;
  }
  .chat-msg--loading {
    align-self: flex-start;
    background: var(--color-background-secondary, #f9f9f8);
    color: var(--color-text-tertiary, #999);
    border: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    border-bottom-left-radius: 3px;
    font-style: italic;
  }

  .chat-input-area {
    flex-shrink: 0;
    border-top: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.12));
    padding: 12px;
    position: relative;
  }
  .attach-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 12px;
    background: var(--dark, #111);
    color: #fff;
    font-size: 0.75rem;
    padding: 5px 9px;
    border-radius: 5px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
  }
  .attach-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 12px;
    border: 4px solid transparent;
    border-top-color: var(--dark, #111);
  }
  .chat-input-row {
    display: flex;
    align-items: flex-end;
    gap: 6px;
  }
  .chat-attach-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.15));
    border-radius: 6px;
    color: var(--color-text-tertiary, #999);
    cursor: pointer;
    padding: 6px;
    transition: color 0.15s, border-color 0.15s;
  }
  .chat-attach-btn:hover {
    color: var(--color-text-secondary, #666);
    border-color: var(--color-border-secondary, rgba(0,0,0,0.25));
  }
  .chat-input {
    flex: 1;
    resize: none;
    border: 1px solid var(--color-border-tertiary, rgba(0,0,0,0.15));
    border-radius: 6px;
    padding: 7px 10px;
    font-family: var(--body, sans-serif);
    font-size: 0.8125rem;
    color: var(--color-text-primary, #1a1a1a);
    background: var(--color-background-primary, #fff);
    line-height: 1.45;
    max-height: 120px;
    overflow-y: auto;
    outline: none;
    transition: border-color 0.15s;
  }
  .chat-input:focus {
    border-color: var(--teal, #3C8A7E);
  }
  .chat-input:disabled {
    opacity: 0.6;
  }
  .chat-send-btn {
    flex-shrink: 0;
    background: var(--teal, #3C8A7E);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 7px 13px;
    font-family: var(--body, sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .chat-send-btn:hover:not(:disabled) {
    background: #317368;
  }
  .chat-send-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }
</style>

<script>
  const toggleBtn = document.getElementById('chat-toggle-btn') as HTMLButtonElement | null
  const closeBtn = document.getElementById('chat-close-btn') as HTMLButtonElement | null
  const panel = document.getElementById('chat-panel') as HTMLDivElement | null
  const messagesEl = document.getElementById('chat-messages') as HTMLDivElement | null
  const inputEl = document.getElementById('chat-input') as HTMLTextAreaElement | null
  const sendBtn = document.getElementById('chat-send-btn') as HTMLButtonElement | null
  const attachBtn = document.getElementById('chat-attach-btn') as HTMLButtonElement | null
  const attachTooltip = document.getElementById('attach-tooltip') as HTMLDivElement | null

  if (!toggleBtn || !closeBtn || !panel || !messagesEl || !inputEl || !sendBtn || !attachBtn) {
    // Elements not present (suppressed page) — nothing to wire up
  } else {
    const sessionId = crypto.randomUUID()
    const pagePath = window.location.pathname
    const history: { role: 'user' | 'assistant'; content: string }[] = []

    function openPanel() {
      document.body.classList.add('chat-open')
      panel.classList.add('open')
      panel.setAttribute('aria-hidden', 'false')
      toggleBtn!.classList.add('hidden')
      inputEl!.focus()
    }

    function closePanel() {
      document.body.classList.remove('chat-open')
      panel.classList.remove('open')
      panel.setAttribute('aria-hidden', 'true')
      toggleBtn!.classList.remove('hidden')
    }

    toggleBtn.addEventListener('click', openPanel)
    closeBtn.addEventListener('click', closePanel)

    // Escape key closes panel
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.classList.contains('open')) closePanel()
    })

    // Paperclip tooltip
    let tooltipTimeout: ReturnType<typeof setTimeout> | null = null
    attachBtn.addEventListener('click', () => {
      if (!attachTooltip) return
      attachTooltip.hidden = false
      if (tooltipTimeout) clearTimeout(tooltipTimeout)
      tooltipTimeout = setTimeout(() => {
        if (attachTooltip) attachTooltip.hidden = true
      }, 2500)
    })

    // Auto-resize textarea
    inputEl.addEventListener('input', () => {
      inputEl.style.height = 'auto'
      inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px'
    })

    // Send on Enter (Shift+Enter = newline)
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        doSend()
      }
    })

    sendBtn.addEventListener('click', doSend)

    function appendMessage(role: 'user' | 'assistant' | 'loading', content: string): HTMLDivElement {
      const div = document.createElement('div')
      div.className = `chat-msg chat-msg--${role}`
      div.textContent = content
      messagesEl!.appendChild(div)
      messagesEl!.scrollTop = messagesEl!.scrollHeight
      return div
    }

    function setLoading(loading: boolean) {
      sendBtn!.disabled = loading
      inputEl!.disabled = loading
      sendBtn!.textContent = loading ? '…' : 'Send'
    }

    async function doSend() {
      const message = inputEl!.value.trim()
      if (!message) return

      inputEl!.value = ''
      inputEl!.style.height = 'auto'
      appendMessage('user', message)
      const loadingEl = appendMessage('loading', 'Thinking…')
      setLoading(true)

      const payload = {
        message,
        history: history.slice(-20),
        page_path: pagePath,
        session_id: sessionId,
        attachments: []
      }

      try {
        const res = await fetch('/api/dashboard/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        const data = await res.json() as { response?: string; error?: string }
        const responseText = data.response ?? 'Something went wrong.'
        loadingEl.remove()
        appendMessage('assistant', responseText)
        history.push({ role: 'user', content: message })
        history.push({ role: 'assistant', content: responseText })
      } catch {
        loadingEl.remove()
        appendMessage('assistant', 'Could not reach Signal OS. Please try again.')
      } finally {
        setLoading(false)
        inputEl!.focus()
      }
    }
  }
</script>
