---
interface FeedPost {
  id: string;
  title: string;
  slug: string;
  summary: string | null;
  published_at: string | null;
  category: string | null;
  tags: string[] | null;
  reading_time_minutes: number | null;
}

interface Props {
  post: FeedPost;
  imageUrl: string | null;
  imageAlt: string | null;
}

const { post, imageUrl, imageAlt } = Astro.props;

function formatCategoryLabel(value: string): string {
  return value.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

const displayTags = (post.tags ?? []).slice(0, 3);
const tagsForAttr = (post.tags ?? []).join(',');
---

<article
  data-feed-item
  data-category={post.category ?? ''}
  data-tags={tagsForAttr}
  style="border-top: 1px solid var(--color_border); padding-block: clamp(1.25rem, 2.5vw, 1.75rem);"
  class:list={['feed-item', { 'feed-item--has-image': Boolean(imageUrl) }]}
>
  <div class="feed-item-inner">

    <div class="feed-item-content">

      {post.category && (
        <p style="font-size: var(--text_xs); font-weight: var(--font_weight_semibold); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_text_secondary); margin: 0 0 var(--gap_xs); font-family: var(--font_body);">
          {formatCategoryLabel(post.category)}
        </p>
      )}

      <h3 style="font-family: var(--font_heading); font-size: clamp(1.05rem, 1.4vw, 1.3rem); font-weight: var(--font_weight_bold); line-height: var(--leading_tight); letter-spacing: -0.01em; color: var(--color_text_heading); margin: 0 0 var(--gap_xs);">
        {post.title}
      </h3>

      {post.summary && (
        <p
          style="font-family: var(--font_body); font-size: var(--text_base); line-height: var(--leading_relaxed); color: var(--color_text_secondary); margin: 0 0 var(--gap_sm);"
          class="feed-item-summary"
        >
          {post.summary}
        </p>
      )}

      <div style="display: flex; align-items: center; gap: var(--gap_sm); flex-wrap: wrap; font-size: var(--text_sm); font-family: var(--font_body); color: var(--color_text_secondary); margin-bottom: var(--gap_sm);">
        {post.published_at && <span>{formatDate(post.published_at)}</span>}
        {post.reading_time_minutes && (
          <>
            <span aria-hidden="true">·</span>
            <span>{post.reading_time_minutes} min read</span>
          </>
        )}
        {displayTags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <span>{displayTags.join(' · ')}</span>
          </>
        )}
      </div>

      <a
        href={`/latest/${post.slug}`}
        style="font-size: var(--text_sm); font-weight: var(--font_weight_semibold); color: var(--color_cta_primary); text-decoration: none;"
      >
        Read →
      </a>

    </div>

    {imageUrl && (
      <div class="feed-item-thumb">
        <img
          src={imageUrl}
          alt={imageAlt ?? post.title}
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}

  </div>
</article>

<style>
  .feed-item-inner {
    display: flex;
    gap: var(--gap_lg);
    align-items: flex-start;
  }

  .feed-item-content {
    flex: 1;
    min-width: 0;
  }

  .feed-item-summary {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .feed-item-thumb {
    flex-shrink: 0;
    width: 96px;
    height: 72px;
    overflow: hidden;
    border-radius: 4px;
    align-self: flex-start;
  }

  @media (max-width: 560px) {
    .feed-item--has-image .feed-item-inner {
      flex-direction: column-reverse;
    }

    .feed-item-thumb {
      width: 100%;
      height: 160px;
    }
  }
</style>
