---
export interface FeaturedPost {
  id: string;
  title: string;
  slug: string;
  summary: string | null;
  published_at: string | null;
  category: string | null;
  tags: string[] | null;
  reading_time_minutes: number | null;
}

interface Props {
  post: FeaturedPost;
  imageUrl: string | null;
  imageAlt: string | null;
}

const { post, imageUrl, imageAlt } = Astro.props;

function formatCategoryLabel(value: string): string {
  return value.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

const displayTags = (post.tags ?? []).slice(0, 3);
---

<section style="background: var(--color_background); border-bottom: 1px solid var(--color_border);">
  <div
    style="max-width: var(--layout_max_width); margin-inline: auto; padding-inline: var(--layout_padding_x);"
    class="featured-inner"
  >

    {imageUrl && (
      <div class="featured-image-wrap">
        <img
          src={imageUrl}
          alt={imageAlt ?? post.title}
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
          loading="eager"
          decoding="async"
        />
        <div class="featured-fade" aria-hidden="true"></div>
      </div>
    )}

    <div class:list={['featured-content', { 'featured-content--full': !imageUrl }]}>

      {post.category && (
        <p style="font-size: var(--text_xs); font-weight: var(--font_weight_semibold); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_text_secondary); margin: 0 0 var(--gap_sm); font-family: var(--font_body);">
          {formatCategoryLabel(post.category)}
        </p>
      )}

      <h2 style="font-family: var(--font_heading); font-size: clamp(1.75rem, 3vw, 2.75rem); font-weight: var(--font_weight_bold); line-height: var(--leading_tight); letter-spacing: -0.02em; color: var(--color_text_heading); margin: 0 0 var(--gap_md);">
        {post.title}
      </h2>

      {post.summary && (
        <p style="font-size: var(--text_lg); font-family: var(--font_body); line-height: var(--leading_relaxed); color: var(--color_text_secondary); margin: 0 0 var(--gap_md); max-width: 54ch;">
          {post.summary}
        </p>
      )}

      <div style="display: flex; align-items: center; gap: var(--gap_sm); flex-wrap: wrap; font-size: var(--text_sm); font-family: var(--font_body); color: var(--color_text_secondary); margin-bottom: var(--gap_md);">
        {post.published_at && <span>{formatDate(post.published_at)}</span>}
        {post.reading_time_minutes && (
          <>
            <span aria-hidden="true">·</span>
            <span>{post.reading_time_minutes} min read</span>
          </>
        )}
        {displayTags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <span>{displayTags.join(' · ')}</span>
          </>
        )}
      </div>

      <a
        href={`/latest/${post.slug}`}
        style="font-size: var(--text_base); font-weight: var(--font_weight_semibold); color: var(--color_cta_primary); text-decoration: none;"
      >
        Read more →
      </a>

    </div>

  </div>
</section>

<style>
  .featured-inner {
    display: flex;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: stretch;
    min-height: 400px;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    overflow: hidden;
  }

  .featured-image-wrap {
    position: relative;
    flex: 0 0 50%;
    overflow: hidden;
    min-width: 0;
  }

  .featured-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 55%, var(--color_background));
    pointer-events: none;
  }

  .featured-content {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .featured-content--full {
    max-width: 60ch;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  @media (max-width: 768px) {
    .featured-inner {
      flex-direction: column;
      min-height: unset;
    }

    .featured-image-wrap {
      flex: none;
      width: 100%;
      height: 220px;
    }

    .featured-fade {
      display: none;
    }

    .featured-content {
      padding-block: var(--gap_xl);
    }
  }
</style>
