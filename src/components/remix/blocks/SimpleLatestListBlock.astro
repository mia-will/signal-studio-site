---
interface Props {
  block: any;
  posts: any[];
  excludeIds?: string[];
}

const { block, posts = [], excludeIds = [] } = Astro.props;

const limit          = Number(block.props?.limit ?? 9);
const showThumbnail  = block.props?.show_thumbnail === true;
const categoryLabels = (block.props?.category_labels ?? {}) as Record<string, string>;

const filteredPosts = posts
  .filter((p: any) => !excludeIds.includes(p.id))
  .slice(0, limit);

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{filteredPosts.length > 0 && (
  <section style="padding-block: var(--space_xl);">
    <div style="max-width: var(--layout_max_width); margin-inline: auto; padding-inline: var(--layout_padding_x);">
      <div>
        {filteredPosts.map((post: any) => (
          <div style="display: flex; gap: var(--gap_lg); align-items: flex-start; padding-block: var(--space_lg); border-top: 1px solid var(--color_border);">

            {showThumbnail && post.featured_image_url && (
              <a href={`/posts/${post.slug}`} style="flex-shrink: 0;" aria-tabindex="-1">
                <img
                  src={post.featured_image_url}
                  alt={post.title}
                  style="width: var(--size_thumbnail, 120px); aspect-ratio: 3 / 2; object-fit: cover; border-radius: var(--radius_sm); display: block;"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}

            <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: var(--space_xs);">
              {categoryLabels[post.category] && (
                <p style="font-size: var(--text_xs); font-weight: var(--font_weight_semibold); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_cta_primary); margin: 0;">
                  {categoryLabels[post.category]}
                </p>
              )}

              <a href={`/posts/${post.slug}`} style="text-decoration: none; color: inherit;">
                <h3 style="font-family: var(--font_heading); font-size: var(--text_lg); font-weight: var(--font_weight_bold); line-height: var(--leading_tight); color: var(--color_text_heading); margin: 0;">
                  {post.title}
                </h3>
              </a>

              {post.summary && (
                <p class="sll-summary" style="font-size: var(--text_sm); color: var(--color_text_secondary); margin: 0; line-height: var(--leading_relaxed);">
                  {post.summary}
                </p>
              )}

              <p style="font-size: var(--text_xs); color: var(--color_text_secondary); margin: 0; opacity: 0.65;">
                {formatDate(post.published_at)}
              </p>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .sll-summary {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
