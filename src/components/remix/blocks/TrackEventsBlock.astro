---
import type { PageBlock } from '../../../types/content';
import { supabase } from '../../../lib/supabase';
import { cleanRemixUrl } from '../../../lib/cleanRemixUrl';

interface Props {
  block: PageBlock;
}

const { block } = Astro.props;

const eyebrow      = block.eyebrow        ?? block.props?.eyebrow;
const title        = block.props?.title   ?? block.title;
const subtitle     = block.props?.subtitle ?? block.subtitle;
const _ctaPrimary  = block.props?.cta_primary as { href?: string; label?: string } | undefined;
const ctaPrimary   = _ctaPrimary ? { ..._ctaPrimary, href: cleanRemixUrl(_ctaPrimary.href) } : undefined;
const emptyMessage = block.props?.empty_message ?? 'More events coming soon — join the list to be first to know.';
const now          = new Date().toISOString();

const variant       = block.props?.variant ?? '';
const featuredCount = Number(block.props?.featured_count ?? 1);
const supportCount  = Number(block.props?.support_count  ?? 2);
const totalLimit    = featuredCount + supportCount;
const isFeatureTiles = variant === 'program_tiles' || variant === 'feature_plus_tiles';

// Visual system props
const featuredCardStyle = block.props?.featured_card_style as string | undefined;
const supportCardStyle  = block.props?.support_card_style  as string | undefined;
const cardBorderProp    = block.props?.card_border          as string | undefined;
const noBorder          = cardBorderProp === 'none';

// Featured card computed styles
const featuredBg     = 'var(--color_surface_panel_applier)';
const featuredBorder = 'none';
const featuredShadow = '0 12px 32px rgba(17,17,17,0.12)';

// Support card computed styles
const supportBg     = 'var(--color_surface_alt)';
const supportBorder = 'none';
const supportShadow = '0 6px 18px rgba(17,17,17,0.06)';

// audience_track filter from props — no hardcoded lookup
const trackFilter = (block.props?.filter?.audience_track ?? ['applier', 'appliers', 'both']) as string[];

const eventsLimit = isFeatureTiles ? totalLimit : Number(block.props?.limit ?? 6);

const { data: eventsRaw } = await supabase
  .from('events')
  .select(`
    id, title, slug, summary, start_at, end_at, venue_name, suburb, state,
    registration_url, audience_track, event_format, image_position,
    media_assets!events_featured_image_asset_id_fkey ( image_url, alt_text )
  `)
  .eq('show_on_remix', true)
  .eq('publish_status', 'published')
  .in('audience_track', trackFilter)
  .gt('start_at', now)
  .order('start_at', { ascending: true })
  .limit(eventsLimit);

const events = (eventsRaw ?? []).map((e: any) => ({
  ...e,
  resolved_image_url: e.media_assets?.image_url ?? null,
  resolved_image_alt: e.media_assets?.alt_text  ?? null,
  resolved_image_position: e.image_position ?? 'center',
}));

const featuredEvents = isFeatureTiles ? events.slice(0, featuredCount) : [];
const supportEvents  = isFeatureTiles ? events.slice(featuredCount, featuredCount + supportCount) : [];

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'Australia/Sydney' });
}

function fmtVenue(ev: any): string {
  return [ev.venue_name, ev.suburb, ev.state].filter(Boolean).join(', ');
}
---

<section style="padding: 56px 0; background: var(--color_surface_events);">
  <div style="max-width: 1280px; margin-inline: auto; padding-inline: 48px;">

    <!-- Section header -->
    <div style="margin-bottom: 36px; display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
      <div>
        {eyebrow && (
          <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_track_applier); margin: 0 0 8px;">
            {eyebrow}
          </p>
        )}
        {title && (
          <h2 style="font-family: var(--font_heading); font-size: 32px; font-weight: 700; color: var(--color_text_heading); margin: 0 0 8px; line-height: 1.1;">
            {title}
          </h2>
        )}
        <div style="width: 40px; height: 3px; background: var(--color_track_applier); border-radius: 2px; margin-bottom: 12px;"></div>
        {subtitle && (
          <p style="font-size: 15px; color: var(--color_text_secondary); margin: 0; max-width: 480px; line-height: 1.6;">
            {subtitle}
          </p>
        )}
      </div>
      {ctaPrimary?.href && (
        <a
          href={ctaPrimary.href}
          style="flex-shrink: 0; font-size: 14px; font-weight: 600; color: var(--color_track_applier); text-decoration: none; white-space: nowrap;"
        >
          {ctaPrimary.label}
        </a>
      )}
    </div>

    <!-- Empty state — support-card styling -->
    {events.length === 0 && (
      <div style={`background: ${supportBg}; border-radius: 18px; padding: 40px 28px; text-align: center; box-shadow: ${supportShadow};`}>
        <p style="font-size: 15px; color: var(--color_text_secondary); margin: 0; line-height: 1.6;">
          {emptyMessage}
        </p>
      </div>
    )}

    <!-- feature_plus_tiles: 1 featured + support tiles -->
    {isFeatureTiles && events.length > 0 && (
      <div class="te-feature-grid">

        <!-- Featured card -->
        {featuredEvents.map((ev: any) => (
          <div class="te-featured-card" style={`border: ${featuredBorder}; background: ${featuredBg}; display: flex; flex-direction: column; overflow: hidden; border-radius: 22px; box-shadow: ${featuredShadow};`}>
            {ev.resolved_image_url && (
              <div style="aspect-ratio: 16 / 9; overflow: hidden; flex-shrink: 0;">
                <img
                  src={`${ev.resolved_image_url}?width=800&quality=80`}
                  alt={ev.resolved_image_alt ?? ev.title}
                  style={`width: 100%; height: 100%; object-fit: cover; object-position: ${ev.resolved_image_position}; display: block;`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div style="padding: 32px 28px; display: flex; flex-direction: column; gap: 12px; flex: 1;">
              <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                {ev.start_at && (
                  <span style="font-size: 13px; font-weight: 700; color: var(--color_track_applier);">
                    {fmtDate(ev.start_at)}
                  </span>
                )}
                {ev.event_format && (
                  <span style="font-size: var(--badge_font_size); font-weight: var(--badge_font_weight); letter-spacing: var(--badge_letter_spacing); text-transform: uppercase; color: var(--color_text_secondary); background: var(--color_surface); padding: var(--badge_padding); border-radius: var(--badge_radius);">
                    {ev.event_format}
                  </span>
                )}
              </div>
              <h3 style="font-family: var(--font_heading); font-size: 22px; font-weight: 800; color: var(--color_text_heading); margin: 0; line-height: 1.2;">
                {ev.title}
              </h3>
              {fmtVenue(ev) && (
                <p style="font-size: 13px; color: var(--color_text_secondary); margin: 0;">
                  {fmtVenue(ev)}
                </p>
              )}
              {ev.summary && (
                <p style="font-size: 14px; color: var(--color_text_secondary); margin: 0; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                  {ev.summary}
                </p>
              )}
              {ev.registration_url && (
                <a
                  href={ev.registration_url}
                  style="margin-top: auto; padding-top: 12px; font-size: 14px; font-weight: 700; color: var(--color_track_applier); text-decoration: none; align-self: flex-start;"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Register →
                </a>
              )}
            </div>
          </div>
        ))}

        <!-- Support tiles -->
        <div class="te-support-col">
          {supportEvents.map((ev: any) => (
            <div style={`border: ${supportBorder}; background: ${supportBg}; border-radius: 18px; display: flex; flex-direction: column; padding: 22px 20px; gap: 8px; box-shadow: ${supportShadow};`}>
              <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                {ev.start_at && (
                  <span style="font-size: 12px; font-weight: 700; color: var(--color_track_applier);">
                    {fmtDate(ev.start_at)}
                  </span>
                )}
                {ev.event_format && (
                  <span style="font-size: var(--badge_font_size); font-weight: var(--badge_font_weight); letter-spacing: var(--badge_letter_spacing); text-transform: uppercase; color: var(--color_text_secondary); background: var(--color_surface); padding: var(--badge_padding); border-radius: var(--badge_radius);">
                    {ev.event_format}
                  </span>
                )}
              </div>
              <h3 style="font-family: var(--font_heading); font-size: 15px; font-weight: 700; color: var(--color_text_heading); margin: 0; line-height: 1.3;">
                {ev.title}
              </h3>
              {fmtVenue(ev) && (
                <p style="font-size: 12px; color: var(--color_text_secondary); margin: 0;">
                  {fmtVenue(ev)}
                </p>
              )}
              {ev.registration_url && (
                <a
                  href={ev.registration_url}
                  style="font-size: 12px; font-weight: 700; color: var(--color_track_applier); text-decoration: none; align-self: flex-start; margin-top: 4px;"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Register →
                </a>
              )}
            </div>
          ))}
        </div>

      </div>
    )}

    <!-- Default grid layout -->
    {!isFeatureTiles && events.length > 0 && (
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
        {events.map((ev: any) => (
          <div style="border: var(--card_border); border-top: 4px solid var(--color_track_applier); background: var(--card_bg); display: flex; flex-direction: column; box-shadow: var(--shadow_sm); overflow: hidden;">
            {ev.resolved_image_url && (
              <div style="aspect-ratio: 16 / 9; overflow: hidden; flex-shrink: 0;">
                <img
                  src={`${ev.resolved_image_url}?width=600&quality=80`}
                  alt={ev.resolved_image_alt ?? ev.title}
                  style={`width: 100%; height: 100%; object-fit: cover; object-position: ${ev.resolved_image_position}; display: block;`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div style="padding: 24px; display: flex; flex-direction: column; gap: 10px; flex: 1;">
              <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                {ev.start_at && (
                  <span style="font-size: 12px; font-weight: 600; color: var(--color_track_applier);">
                    {fmtDate(ev.start_at)}
                  </span>
                )}
                {ev.event_format && (
                  <span style="font-size: var(--badge_font_size); font-weight: var(--badge_font_weight); letter-spacing: var(--badge_letter_spacing); text-transform: uppercase; color: var(--color_text_secondary); background: var(--color_surface); padding: var(--badge_padding); border-radius: var(--badge_radius);">
                    {ev.event_format}
                  </span>
                )}
              </div>
              <h3 style="font-family: var(--font_heading); font-size: 16px; font-weight: 700; color: var(--color_text_heading); margin: 0; line-height: 1.3;">
                {ev.title}
              </h3>
              {fmtVenue(ev) && (
                <p style="font-size: 13px; color: var(--color_text_secondary); margin: 0;">
                  {fmtVenue(ev)}
                </p>
              )}
              {ev.summary && (
                <p style="font-size: 13px; color: var(--color_text_secondary); margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                  {ev.summary}
                </p>
              )}
              {ev.registration_url && (
                <a
                  href={ev.registration_url}
                  style="margin-top: auto; padding-top: 8px; font-size: 13px; font-weight: 700; color: var(--color_track_applier); text-decoration: none; align-self: flex-start;"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Register →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

  </div>
</section>

<style>
  .te-feature-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 24px;
    align-items: start;
  }

  .te-support-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 768px) {
    .te-feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
