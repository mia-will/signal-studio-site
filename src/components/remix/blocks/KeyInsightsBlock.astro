---
import type { PageBlock } from '../../../types/content';

interface Props {
  block: PageBlock;
}

const { block } = Astro.props;

const eyebrow  = block.eyebrow     ?? block.props?.eyebrow;
const title    = block.props?.title ?? block.title;
const intro    = block.props?.intro ?? block.props?.subtitle;
const insights = (block.props?.insights ?? []) as {
  id?: string;
  tag?: string;
  theme: string;
  body: string;
}[];
---

<section style="padding: 64px 0;">
  <div style="max-width: 1280px; margin-inline: auto; padding-inline: 48px;">

    <div style="margin-bottom: 40px;">
      {eyebrow && (
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color_track_applier); margin: 0 0 8px;">
          {eyebrow}
        </p>
      )}
      {title && (
        <h2 style="font-family: var(--font_heading); font-size: 32px; font-weight: 700; color: var(--color_text_heading); margin: 0 0 8px; line-height: 1.1;">
          {title}
        </h2>
      )}
      <div style="width: 40px; height: 3px; background: var(--color_track_applier); border-radius: 2px; margin-bottom: 12px;"></div>
      {intro && (
        <p style="font-size: 15px; color: var(--color_text_secondary); margin: 0; max-width: 520px; line-height: 1.6;">
          {intro}
        </p>
      )}
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;">
      {insights.map((insight) => (
        <div style="border: var(--card_border); border-top: 4px solid var(--color_track_applier); padding: 28px; background: var(--card_bg); display: flex; flex-direction: column; gap: 14px; box-shadow: var(--shadow_sm);">

          {insight.tag && (
            <span style="display: inline-block; align-self: flex-start; font-size: var(--badge_font_size); font-weight: var(--badge_font_weight); letter-spacing: var(--badge_letter_spacing); text-transform: uppercase; color: var(--color_track_applier); background: var(--card_bg_applier); padding: var(--badge_padding); border-radius: var(--badge_radius);">
              {insight.tag}
            </span>
          )}

          <h3 style="font-family: var(--font_heading); font-size: 16px; font-weight: 700; color: var(--color_text_heading); margin: 0; line-height: 1.3;">
            {insight.theme}
          </h3>

          <p style="font-size: 14px; color: var(--color_text_secondary); margin: 0; line-height: 1.65; flex: 1;">
            {insight.body}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>
