---
import type { PageBlock } from '../../../types/content';

interface Props {
  block: PageBlock;
}

const { block } = Astro.props;

const eyebrow  = block.eyebrow            ?? block.props?.eyebrow;
const title    = block.title              ?? block.props?.title;
const body     = block.body               ?? block.props?.body;
const ctaLabel = block.cta_primary_label;
const ctaHref  = block.cta_primary_href;
---

<section style="padding: 40px 0;">
  <div style="max-width: 1280px; margin-inline: auto; padding-inline: 48px;">

    <div style="border: var(--card_border); border-left: 4px solid var(--color_text_secondary); padding: 32px 36px; background: var(--color_surface); display: flex; align-items: center; gap: 40px; flex-wrap: wrap;">

      <div style="flex: 1; min-width: 220px;">
        {eyebrow && (
          <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color_text_secondary); margin: 0 0 6px;">
            {eyebrow}
          </p>
        )}
        {title && (
          <h3 style="font-family: var(--font_heading); font-size: 18px; font-weight: 700; color: var(--color_text_heading); margin: 0 0 8px; line-height: 1.3;">
            {title}
          </h3>
        )}
        {body && (
          <p style="font-size: 15px; color: var(--color_text_secondary); margin: 0; line-height: 1.65; max-width: 60ch;">
            {body}
          </p>
        )}
      </div>

      {ctaHref && ctaLabel && (
        <a
          href={ctaHref}
          style="flex-shrink: 0; display: inline-flex; align-items: center; padding: 10px 24px; background: transparent; color: var(--color_text_heading); font-family: var(--font_body); font-size: 14px; font-weight: var(--font_weight_semibold); border-radius: var(--btn_radius_pill); border: 1px solid var(--color_border); text-decoration: none; white-space: nowrap;"
        >
          {ctaLabel}
        </a>
      )}

    </div>
  </div>
</section>
