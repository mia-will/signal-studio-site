---
import type { PageBlock } from '../../../../types/content';

interface Props {
  block: PageBlock;
  pathway: any;
}

const { block, pathway } = Astro.props;

const eyebrow = block.props?.eyebrow ?? block.eyebrow;
const title   = block.props?.title   ?? block.title;
const summary = block.props?.body    ?? block.body ?? pathway?.what_you_leave_with ?? null;

const outcomes = (pathway?.key_outcomes ?? []) as string[];
---

<section class="pout">
  <div class="pout-inner">

    <div class="pout-header">
      {eyebrow && (
        <p class="pout-eyebrow">{eyebrow}</p>
      )}
      {title && (
        <h2 class="pout-title">{title}</h2>
      )}
      {summary && (
        <p class="pout-summary">{summary}</p>
      )}
    </div>

    {outcomes.length > 0 && (
      <ul class="pout-list">
        {outcomes.map((item: string) => (
          <li class="pout-item">
            <span class="pout-check" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    )}

  </div>
</section>

<style>
  .pout {
    padding-block: var(--space_2xl);
    border-top: 1px solid var(--color_border);
  }

  .pout-inner {
    max-width: var(--layout_max_width);
    margin-inline: auto;
    padding-inline: var(--layout_padding_x);
  }

  .pout-header {
    max-width: 720px;
    margin-bottom: var(--space_lg);
  }

  .pout-eyebrow {
    font-size: var(--text_xs);
    font-weight: var(--font_weight_semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color_cta_primary);
    margin: 0 0 12px;
  }

  .pout-title {
    font-family: var(--font_heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: var(--font_weight_bold);
    color: var(--color_text_heading);
    line-height: var(--leading_tight);
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .pout-summary {
    font-size: var(--text_base);
    line-height: var(--leading_relaxed);
    color: var(--color_text_secondary);
    margin: 0;
  }

  .pout-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--gap_md);
  }

  .pout-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: var(--space_lg);
    background: var(--color_surface_panel, var(--color_surface));
    border: 1px solid var(--color_border);
    border-radius: var(--radius_md);
    font-size: var(--text_sm);
    line-height: var(--leading_relaxed);
    color: var(--color_text_primary);
  }

  .pout-check {
    color: var(--color_accent_teal, var(--color_cta_primary));
    flex-shrink: 0;
    margin-top: 2px;
  }
</style>
