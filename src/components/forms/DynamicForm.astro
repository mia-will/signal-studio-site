---
import { supabase } from '../../lib/supabase';

interface Props {
  formKey: string;
  siteSlug: string;
  eventId?: string;
  successMessage?: string;
}

const {
  formKey,
  siteSlug,
  eventId,
  successMessage = "Thanks — we'll be in touch with the right things for you.",
} = Astro.props;

const [{ data: questions }, { data: site }] = await Promise.all([
  supabase
    .from('intake_questions')
    .select('question_key, question_text, question_hint, input_type, required, populates_field, options')
    .contains('appears_in', [formKey])
    .eq('active', true)
    .order('display_order'),
  supabase
    .from('sites')
    .select('brand_color')
    .eq('slug', siteSlug)
    .maybeSingle(),
]);

const brandColor = site?.brand_color ?? '#2F5D50';
---

<div class="dynamic-form-wrapper" style={`--brand: ${brandColor};`}>
  <form id="dynamic-form" novalidate>
    <input type="hidden" name="formKey" value={formKey} />
    <input type="hidden" name="siteSlug" value={siteSlug} />
    {eventId && <input type="hidden" name="eventId" value={eventId} />}

    <!-- Always-present contact fields -->
    <fieldset class="field-group">
      <div class="field-row">
        <div class="field">
          <label for="first_name">First name <span class="required">*</span></label>
          <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
        </div>
        <div class="field">
          <label for="last_name">Last name <span class="required">*</span></label>
          <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
        </div>
      </div>
      <div class="field">
        <label for="email">Email <span class="required">*</span></label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>
    </fieldset>

    <!-- Dynamic questions from intake_questions -->
    {questions?.map((q) => (
      <div class="field" data-question-key={q.question_key}>
        <label class={q.required ? 'required-label' : ''}>
          {q.question_text}
          {q.required && <span class="required">*</span>}
        </label>
        {q.question_hint && <p class="field-hint">{q.question_hint}</p>}

        {q.input_type === 'text' && (
          <input
            type="text"
            name={q.question_key}
            required={q.required}
          />
        )}

        {q.input_type === 'tel' && (
          <input
            type="tel"
            name={q.question_key}
            required={q.required}
            autocomplete="tel"
          />
        )}

        {q.input_type === 'textarea' && (
          <textarea
            name={q.question_key}
            rows={4}
            required={q.required}
          />
        )}

        {q.input_type === 'single_select' && q.options && (
          <div class="radio-group" role="radiogroup">
            {(q.options as Array<{label: string; value: string}>).map((opt) => (
              <label class="radio-option">
                <input
                  type="radio"
                  name={q.question_key}
                  value={opt.value}
                  required={q.required}
                  data-option={JSON.stringify(opt)}
                />
                <span>{opt.label}</span>
              </label>
            ))}
          </div>
        )}

        {q.input_type === 'multi_select' && q.options && (
          <div
            class="checkbox-group"
            data-max={q.question_key === 'interests' || q.question_key === 'reengagement_interests' ? '3' : undefined}
          >
            {(q.options as Array<{label: string; value: string}>).map((opt) => (
              <label class="checkbox-option">
                <input
                  type="checkbox"
                  name={q.question_key}
                  value={opt.value}
                />
                <span>{opt.label}</span>
              </label>
            ))}
          </div>
        )}

        {q.input_type === 'boolean' && (
          <div class="toggle-group" role="radiogroup">
            <label class="radio-option">
              <input type="radio" name={q.question_key} value="true" />
              <span>Yes</span>
            </label>
            <label class="radio-option">
              <input type="radio" name={q.question_key} value="false" />
              <span>No</span>
            </label>
          </div>
        )}
      </div>
    ))}

    <div class="form-actions">
      <button type="submit" class="submit-btn">Submit</button>
    </div>

    <p class="form-error" id="form-error" aria-live="polite" hidden></p>
  </form>

  <div id="form-success" class="form-success" hidden>
    <p>{successMessage}</p>
  </div>
</div>

<script>
  const form = document.getElementById('dynamic-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error') as HTMLElement | null;

  // Enforce multi_select max limits
  document.querySelectorAll('.checkbox-group[data-max]').forEach((group) => {
    const max = parseInt((group as HTMLElement).dataset.max ?? '99', 10);
    group.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
      cb.addEventListener('change', () => {
        const checked = group.querySelectorAll('input[type="checkbox"]:checked');
        if (checked.length >= max) {
          group.querySelectorAll('input[type="checkbox"]:not(:checked)').forEach((u) => {
            (u as HTMLInputElement).disabled = true;
          });
        } else {
          group.querySelectorAll('input[type="checkbox"]').forEach((u) => {
            (u as HTMLInputElement).disabled = false;
          });
        }
      });
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement | null;
    if (submitBtn) submitBtn.disabled = true;
    if (errorEl) errorEl.hidden = true;

    const data = new FormData(form);
    const formKey = data.get('formKey') as string;
    const siteSlug = data.get('siteSlug') as string;
    const eventId = data.get('eventId') as string | null;

    // Build answers map — multi-select fields become arrays
    const answers: Record<string, string | string[] | boolean> = {
      first_name: data.get('first_name') as string,
      last_name: data.get('last_name') as string,
      email: data.get('email') as string,
    };

    const seen = new Set(['formKey', 'siteSlug', 'eventId', 'first_name', 'last_name', 'email']);
    for (const [key, value] of data.entries()) {
      if (seen.has(key)) continue;
      seen.add(key);

      const allValues = data.getAll(key);
      if (allValues.length > 1) {
        answers[key] = allValues as string[];
      } else {
        const str = value as string;
        answers[key] = str === 'true' ? true : str === 'false' ? false : str;
      }
    }

    // For radio inputs that carry option metadata (sets_journey, sets_readiness),
    // attach the full option object so the edge function can read it
    form.querySelectorAll('input[type="radio"]:checked[data-option]').forEach((el) => {
      const input = el as HTMLInputElement;
      try {
        answers[`${input.name}__meta`] = input.dataset.option ?? '';
      } catch {}
    });

    const payload = { formKey, siteSlug, answers, ...(eventId ? { eventId } : {}) };

    try {
      const res = await fetch('/api/form-submission', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error((body as {error?: string}).error ?? 'Something went wrong.');
      }

      form.hidden = true;
      if (successEl) successEl.hidden = false;
    } catch (err) {
      if (errorEl) {
        errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        errorEl.hidden = false;
      }
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  .dynamic-form-wrapper {
    width: 100%;
    max-width: 600px;
  }

  .field-group {
    border: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 480px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text, #1a1a1a);
  }

  .field-hint {
    font-size: 0.8rem;
    color: var(--color-muted, #666);
    margin: 0;
  }

  .required {
    color: var(--brand);
    margin-left: 2px;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--color-surface, #fff);
    color: var(--color-text, #1a1a1a);
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  input[type="tel"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 15%, transparent);
  }

  textarea {
    resize: vertical;
    min-height: 90px;
  }

  .radio-group,
  .toggle-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .radio-option,
  .checkbox-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: normal;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    transition: border-color 0.15s, background 0.15s;
  }

  .radio-option:has(input:checked),
  .checkbox-option:has(input:checked) {
    border-color: var(--brand);
    background: color-mix(in srgb, var(--brand) 8%, transparent);
  }

  .radio-option input,
  .checkbox-option input {
    accent-color: var(--brand);
    flex-shrink: 0;
  }

  .checkbox-option:has(input:disabled) {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .form-actions {
    margin-top: 1.75rem;
  }

  .submit-btn {
    background: var(--brand);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.7rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-btn:hover {
    opacity: 0.88;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-error {
    margin-top: 1rem;
    color: #c0392b;
    font-size: 0.875rem;
  }

  .form-success {
    padding: 1.25rem;
    border-left: 3px solid var(--brand);
    background: color-mix(in srgb, var(--brand) 8%, transparent);
    border-radius: 0 6px 6px 0;
    font-size: 0.95rem;
  }
</style>
