---
import DashboardNav from '../components/dashboard/DashboardNav.astro'
import { supabaseAdmin as supabase } from '../lib/supabase-admin'

interface Props {
  title: string
}

const { title } = Astro.props

const { data: livePathways } = await supabase
  .from('pathways')
  .select('id, title')
  .eq('status', 'active')
  .in('pathway_status', ['open', 'coming_soon'])
  .order('sort_order', { ascending: true })
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:             #F5F4F1;
      --surface:        #FFFFFF;
      --text-primary:   #2F2F2F;
      --text-secondary: #505050;
      --text-muted:     #909090;
      --border:         rgba(47,47,47,0.08);
      --teal:           #3C8A7E;
      --orange:         #FF8A33;
      --green:          #7BBE9A;
      --red:            #C0392B;
      --dark:           #111111;
      --heading:        'DM Sans', sans-serif;
      --body:           'Inter', sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--body);
    }

    .dash-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
    }

    @media (max-width: 768px) {
      .dash-shell { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="dash-shell">
    <DashboardNav livePathways={livePathways ?? []} />
    <slot />
  </div>
</body>
</html>
