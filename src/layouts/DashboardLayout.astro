---
import DashboardNav from '../components/dashboard/DashboardNav.astro'
import { supabaseAdmin as supabase } from '../lib/supabase-admin'

interface Props {
  title: string
}

const { title } = Astro.props

const { data: livePathways } = await supabase
  .from('pathways')
  .select('id, title')
  .eq('status', 'active')
  .in('pathway_status', ['open', 'coming_soon'])
  .order('sort_order', { ascending: true })
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:             #F5F4F1;
      --surface:        #FFFFFF;
      --text-primary:   #2F2F2F;
      --text-secondary: #505050;
      --text-muted:     #909090;
      --border:         rgba(47,47,47,0.08);
      --teal:           #3C8A7E;
      --orange:         #FF8A33;
      --green:          #7BBE9A;
      --red:            #C0392B;
      --dark:           #111111;
      --heading:        'DM Sans', sans-serif;
      --body:           'Inter', sans-serif;

      /* ── Colour tokens ───────────────────── */
      --color-background-primary:   #ffffff;
      --color-background-secondary: #f9f9f8;
      --color-background-tertiary:  #f2f1ef;
      --color-text-primary:         #1a1a1a;
      --color-text-secondary:       #666666;
      --color-text-tertiary:        #999999;
      --color-text-info:            #185fa5;
      --color-text-success:         #3b6d11;
      --color-text-warning:         #854f0b;
      --color-text-danger:          #a32d2d;
      --color-border-primary:       rgba(0,0,0,0.4);
      --color-border-secondary:     rgba(0,0,0,0.3);
      --color-border-tertiary:      rgba(0,0,0,0.15);
      --color-border-info:          #378add;
      --color-border-success:       #639922;
      --color-border-warning:       #ba7517;
      --color-border-danger:        #e24b4a;
      --color-background-info:      #e6f1fb;
      --color-background-success:   #eaf3de;
      --color-background-warning:   #faeeda;
      --color-background-danger:    #fcebeb;
      --border-radius-sm:           4px;
      --border-radius-md:           8px;
      --border-radius-lg:           12px;
      --border-radius-xl:           16px;
    }

    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--body);
    }

    .dash-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
    }

    @media (max-width: 768px) {
      .dash-shell { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="dash-shell">
    <DashboardNav livePathways={livePathways ?? []} />
    <slot />
  </div>
</body>
</html>
